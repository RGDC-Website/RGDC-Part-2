@*<body id="body" ng-app="RGDCWebApplication" ng-controller="RGDCWebApplicationController">*@
<body id="body" ng-app="RGDCWebApplication" ng-controller="RGDCWebApplicationController">
    <div class="row" style="margin: 0;" ng-init="getSessionVariables()">
        @*sidebar nav*@
        <div class="col hide-on-small-only m3 l3 brown lighten-1 z-depth-3 white-text" style="min-height: 100vh; position: fixed;">
            <h5 style="font-weight:bold;">RGDC</h5>

            @*user pfp and name*@
            <div class="row center sidebar-profile" style="margin-top: 2rem;">
                <img ng-src="{{ currentUserPhoto || 'https://placehold.co/400' }}" alt="Profile" class="sidebar-profile-img modal-trigger" data-target="modalEditProfile" />
            </div>

            @*user name and role*@
            <div class="row center">
                <h5 style="font-weight:bold;">{{currentUserFullName}}</h5>
                <h6>{{userRole}}</h6>
            </div>

            @*Calendaryo CODESSS*@
            <div class="row center" style="margin-top: 0.5rem;">
                <div class="google-sync" style="display: inline-flex; align-items: center; justify-content: center; flex-wrap: wrap; margin-left:0;">

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <!-- Compiled and minified CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

    <!-- Compiled and minified JavaScript -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    <style>
        .navText{
            font-size: 1.5rem;
            padding-bottom: 0.5rem;
            padding-top: 0.5rem;
            padding-left: 1rem;
        }
        a:hover {
            background-color: rgba(255, 255, 255, 0.2);
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="row" style="margin: 0;">
        @*sidebar nav*@
        <div class="col m3 l3 brown lighten-1 z-depth-3 white-text" style="min-height: 100vh;">
            <h5 style="font-weight:bold;">RGDC</h5>

            @*user pfp and name*@
            <div class="row center" style="margin-top: 5rem;">
                @*lagyan nalang ng src for image source*@
                <img class="circle" />  
            </div>
            
            @*user name and role*@
            <div class="row center">
                <h5 style="font-weight:bold;">Name</h5>
                <h6>Role</h6>
            </div>

            @*nav tabs*@
            <div style="margin-top: 2rem; padding-left: 3rem; padding-right: 3rem;">
                <ul>
                    <li><a href="#!" class="white-text valign-wrapper navText"><i class="material-icons white-text" style="padding-right: 0.5rem;">home</i>Home</a></li>
                    <li><a href="#!" class="white-text valign-wrapper navText"><i class="material-icons white-text" style="padding-right: 0.5rem;">assignment_ind</i>Clinic Staff</a></li>
                    <li><a href="#!" class="white-text valign-wrapper navText"><i class="material-icons white-text" style="padding-right: 0.5rem;">group</i>Patients</a></li>
                    <li><a href="#!" class="white-text valign-wrapper navText"><i class="material-icons white-text" style="padding-right: 0.5rem;">calendar_today</i>Appointments</a></li>
                    <li><a href="#!" class="white-text valign-wrapper navText"><i class="material-icons white-text" style="padding-right: 0.5rem;">bar_chart</i>Finance</a></li>
                    @*insert contacts*@
                </ul>
            </div>

            @*date and time at the bottom of the screen*@
            <div class="row center" style="margin-top: auto; padding-bottom: 2rem;">
                <span>Month DD, YYYY | </span>
                <span>00:00 AM</span>
            </div>

        </div>

        @*content*@
        <div class="col s12 m9 l9">
            @RenderBody()
        </div>
    </div>

</body>
</html>

@{
    Layout = "~/Views/Shared/_adminLayout.cshtml";
}

@*<div class="dashContainer" ng-controller="RGDCWebApplicationController">*@
<div class="dashContainer">
    @*top part (title, refresh, logout)*@
    <div class="row brown-text lighten-1" style="margin-top: 1rem">
        @*user name*@
        <div class="col m8 l8"><h4 class="bold">Appointments</h4></div>
        @*refresh and logout buttons*@
        <div class="col hide-on-med-and-down l4">
            <span class="right">
                <div class="col valign-wrapper"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Refresh Dashboard"> <i class="material-icons brown-text lighten-1">refresh</i></a></div>
                <div class="col valign-wrapper" ng-click="logOut()"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Logout"> <i class="material-icons brown-text lighten-1">logout</i></a></div>
            </span>
        </div>
    </div>

    @*create new appointment button*@
    <div class="row m-0">
        <a  class="edit-btn modal-trigger left white-text" data-target="modalAddAppt"><i class="material-icons left">add</i>Create New Appointment</a>
    </div>

    <div class="card grey lighten-2" style="margin-top:5vh;">
        <nav class="nav-extended grey lighten-2 z-depth-0">
            <div class="nav-content p-1">
                <ul class="tabs tabs-transparent center-tabs">
                    <li class="tab px-1"><a class="brown-text p-0" href="#sched">Scheduled Appointments</a></li>
                    <li class="tab px-1"><a class="brown-text p-0" href="#req">Requested Appointments</a></li>
                    <li class="tab px-1"><a class="brown-text p-0" href="#past">Past Appointments</a></li>
                </ul>
            </div>
        </nav>

        <div class="card-content">
            @*Scheduled Appointments*@
            <div id="sched" class="containerOverflow-2 row m-0">
                <p class="bold brown-text lighten-1" style="margin-bottom: -3vh; font-size:1.5rem;">Scheduled Appointments</p>
                @*admin scheduled appointments table*@
                <div class="row responsive-data-table-div">
                    <table id="adminScheduledAppointment" class="hover tblClk">
                        @*table headers*@
                        <thead>
                            <tr class="brown-text lighten-1">
                                <th>Date</th>
                                <th>Time</th>
                                <th>Purpose</th>
                                <th>Dentist</th>
                                <th>Patient</th>
                                <th colspan="2">Status</th>
                            </tr>
                        </thead>
                        @*table content*@
                        <tbody>
                            <tr ng-if="(!adminAppointments || adminAppointments.length === 0)">
                                <td colspan="7" class="center-align">No scheduled appointments found.</td>
                            </tr>
                            <tr ng-repeat="appt in adminAppointments track by appt.apptID" data-href="#" title="View patient record" class="clkPointer">
                                <td>{{appt.date}}</td>
                                <td>{{appt.time}}</td>
                                <td>{{appt.purpose}}</td>
                                <td>{{appt.dentistName}}</td>
                                <td>{{appt.patientName}}</td>
                                <td>{{appt.displayStatus || appt.status}}</td>
                                <td class="actions-cell">
                                    <div class="appt-action-buttons" role="group" aria-label="Appointment actions">
                                        <a class="btn-floating btn-small brown lighten-4 p-0 smallBtn tooltipped redBtn modal-trigger"
                                           data-target="modalDeleteSchedAppt"
                                           ng-click="openDeleteApptModal(appt, 'scheduled')"
                                           data-position="bottom" data-tooltip="Delete Appointment"
                                           aria-label="Delete appointment">
                                            <i class="material-icons brown-text lighten-1">delete</i>
                                        </a>

                                        <a class="btn-floating btn-small brown lighten-4 p-0 smallBtn tooltipped modal-trigger"
                                           data-target="modalEditSchedAppt"
                                           ng-click="openEditApptModal(appt, $event)"
                                           data-position="bottom" data-tooltip="Edit Appointment"
                                           aria-label="Edit appointment">
                                            <i class="material-icons brown-text lighten-1">edit</i>
                                        </a>
                                    </div>
                            </tr>
                        </tbody>
                        @*table footer*@
                        <tfoot>
                            <tr class="brown-text lighten-1">
                                <th>Date</th>
                                <th>Time</th>
                                <th>Purpose</th>
                                <th>Dentist</th>
                                <th>Patient</th>
                                <th colspan="2">Status</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>


            @*Requested Appointments*@
            <div id="req" class="containerOverflow-2 row m-0">
                <p class="bold brown-text lighten-1" style="margin-bottom: -3vh; font-size:1.5rem;">Requested Appointments</p>
                @*admin requested appointments table*@
                <div class="row responsive-data-table-div">
                    <table id="adminRequestedAppointment" class="hover tblClk">
                        @*table headers*@
                        <thead>
                            <tr class="brown-text lighten-1">
                                <th>Date</th>
                                <th>Time</th>
                                <th>Purpose</th>
                                <th>Dentist</th>
                                <th>Patient</th>
                                <th colspan="2">Status</th>
                            </tr>
                        </thead>
                        @*table content*@
                        <tbody>
                            <tr ng-if="(!requestedAppointments || requestedAppointments.length === 0)">
                                <td colspan="7" class="center-align">No requested appointments found.</td>
                            </tr>
                            <tr ng-repeat="appt in requestedAppointments track by appt.apptID">
                                <td>{{appt.date}}</td>
                                <td>{{appt.time}}</td>
                                <td>{{appt.purpose}}</td>
                                <td>{{appt.dentistName}}</td>
                                <td>{{appt.patientName}}</td>
                                <td>{{appt.displayStatus || appt.status}}</td>
                                <td style="text-align:center; vertical-align:middle;">
                                    <div style="display:flex; flex-direction:column; align-items:center;">
                                        <a href="#" class="btn-floating btn-small waves-effect waves-light brown lighten-1 tooltipped modal-trigger"
                                           data-target="modalAcceptAppt"
                                           ng-click="acceptRequestedAppointment(appt.apptID)"
                                           data-position="right"
                                           data-tooltip="Confirm"
                                           style="margin-bottom:6px">
                                            <i class="material-icons tiny">check</i>
                                        </a>
                                        <a href="#" class="btn-floating btn-small waves-effect waves-light brown lighten-1 tooltipped modal-trigger"
                                           data-target="modalDenyAppt"
                                           ng-click="denyRequestedAppointment(appt.apptID)"
                                           data-position="right"
                                           data-tooltip="Deny">
                                            <i class="material-icons tiny">close</i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                        @*table footer*@
                        <tfoot>
                            <tr class="brown-text lighten-1">
                                <th>Date</th>
                                <th>Time</th>
                                <th>Purpose</th>
                                <th>Dentist</th>
                                <th>Patient</th>
                                <th colspan="2">Status</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>


            @*Past Appointments*@
            <div id="past" class="containerOverflow-2 row m-0">
                <p class="bold brown-text lighten-1" style="margin-bottom: -3vh; font-size:1.5rem;">Past Appointments</p>
                @*admin past appointments table*@
                <div class="row responsive-data-table-div">
                    <table id="adminPastAppointment" class="hover tblClk">
                        @*table headers*@
                        <thead>
                            <tr class="brown-text lighten-1">
                                <th>Date</th>
                                <th>Time</th>
                                <th>Purpose</th>
                                <th>Dentist</th>
                                <th>Patient</th>
                                <th colspan="2">Status</th>
                            </tr>
                        </thead>
                        @*table content*@
                        <tbody>
                            <tr ng-repeat="p in pastAppointments track by p.apptID">
                                <td>{{p.date}}</td>
                                <td>{{p.time}}</td>
                                <td>{{p.purpose}}</td>
                                <td>{{p.dentistName}}</td>
                                <td>{{p.patientName}}</td>
                                <td>{{p.displayStatus || p.status}}</td>
                                <td>
                                    <a class="btn-floating btn-small waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 redBtn btn-delete-appt modal-trigger"
                                       data-target="modalDeletePastAppt"
                                       ng-click="openDeleteApptModal(p, 'past')"
                                       data-position="bottom"
                                       data-tooltip="Delete Appointment"
                                       data-apptid="">
                                        <i class="material-icons brown-text lighten-1">delete</i>
                                    </a>
                                </td>
                            </tr>
                        </tbody>
                        @*table footer*@
                        <tfoot>
                            <tr class="brown-text lighten-1">
                                <th>Date</th>
                                <th>Time</th>
                                <th>Purpose</th>
                                <th>Dentist</th>
                                <th>Patient</th>
                                <th colspan="2">Status</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@*Add Appointment*@
<div id="modalAddAppt" class="modal appt-modal">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Add New Appointment</h5>

        <form novalidate>
            <div class="row">
                @*Date*@
                <div class="col s12 m6">
                    <label class="custom-label" for="addApptDate">Date <span class="required-mark">*</span></label>
                    <div class="datepicker-wrapper">
                        <input id="addApptDate"
                               type="text"
                               class="datepicker custom-input"
                               ng-model="newApptRequest.dateTime"
                               placeholder="MM/DD/YYYY"
                               min="{{minApptDate}}"
                               required />
                        <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                    </div>
                </div>

                <div class="col s12 m6">
                    <label class="custom-label" for="addApptTime">Time <span class="required-mark">*</span></label>

                    <select id="addApptTime"
                            class="custom-input"
                            ng-model="newApptRequest.time"
                            ng-options="t for t in timeOptions"
                            required>
                        <option value="">Select Time</option>

                    </select>


                    <span class="helper-text" style="color:#d32f2f;" ng-if="timeOptions && timeOptions.length === 0">
                        No available times for selected date and dentist.
                    </span>
                </div>
            </div>

            <div class="row">
                @*Dentist*@
                <div class="col s12 m6">
                    <label class="custom-label" for="addApptDentist">Dentist <span class="required-mark">*</span></label>
                    <div ng-if="currentUserAuthorization !== '2'">
                        <select id="addApptDentist" class="custom-input browser-default" ng-model="newApptRequest.dentistID" required>
                            <option value="">Select Dentist</option>
                            <option ng-repeat="dentist in dentistArray" ng-value="dentist.dentistID">{{dentist.dentistName}}</option>
                        </select>
                    </div>
                    <div ng-if="currentUserAuthorization === '2'">
                        <input type="text" class="custom-input" ng-model="currentDentist.dentistName" readonly />
                    </div>
                </div>

                @*Patient*@
                <div class="col s12 m6">
                    <label class="custom-label" for="addApptPatient">Patient <span class="required-mark">*</span></label>

                    <select id="addApptPatient" class="custom-input browser-default" ng-model="newApptRequest.patientID" required>
                        <option value="">Select Patient</option>
                        <option ng-repeat="patient in patientArray" value="{{patient.patientID}}">{{patient.patientName}}</option>
                    </select>
                </div>
            </div>

            <div class="row">
                @*Purpose*@
                <div class="col s12">
                    <label class="custom-label" for="addApptPurpose">Purpose <span class="required-mark">*</span></label>
                    <input id="addApptPurpose" type="text" class="custom-input" ng-model="newApptRequest.reason" placeholder="Purpose" required />
                </div>
            </div>

        </form>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight:500; margin: -.8vh 0 -1.2vh 2.3vh ">CANCEL</button>
        <button type="submit" class="edit-btn" ng-click="createNewAppointmentRequest()" style="font-weight:500; margin: -.8vh 2.3vh -1.2vh 0 ">ADD</button>
    </div>
</div>


@*ACCEPT scheduled appointment*@
<div id="modalAcceptAppt" class="modal appt-modal" style="width:30% !important">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Accept Appointment</h5>

        <p class="custom-label">Are you sure you want to accept this requested appointment?</p>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0">ACCEPT</button>
    </div>
</div>

@*DENY scheduled appointment*@
<div id="modalDenyAppt" class="modal appt-modal" style="width:30% !important">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Deny Appointment</h5>

        <p class="custom-label">Are you sure you want to deny this requested appointment?</p>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0">DENY</button>
    </div>
</div>


@*EDIT scheduled Appointment*@
<div id="modalEditSchedAppt" class="modal appt-modal">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Edit Scheduled Appointment</h5>

        <!-- Hidden field to store apptID separately -->
        <input type="hidden" id="hiddenApptID" value="">

        <div class="row">
            <div class="col s6">
                @*Date*@
                <label class="custom-label">Date</label>
                <div class="datepicker-wrapper">
                    <input id="date" type="text" class="datepicker custom-input" ng-model="editingAppt.dateObj" placeholder="MM/DD/YYYY" min="{{minApptDate}}">
                    <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                </div>

                @*Dentist*@
                <label class="custom-label">
                    Dentist
                    <input type="text" class="custom-input" ng-bind="editingAppt.dentistName" placeholder="Dentist" readonly>
                </label>
            </div>

            <div class="col s6">
                @*Time Dropdown*@
                <label class="custom-label">
                    Time
                    <select class="custom-input" ng-model="editingAppt.timeStr" ng-change="onTimeChange()">
                        <option value="">Select Time</option>
                        <option value="12:00 AM">12:00 AM</option>
                        <option value="1:00 AM">1:00 AM</option>
                        <option value="2:00 AM">2:00 AM</option>
                        <option value="3:00 AM">3:00 AM</option>
                        <option value="4:00 AM">4:00 AM</option>
                        <option value="5:00 AM">5:00 AM</option>
                        <option value="6:00 AM">6:00 AM</option>
                        <option value="7:00 AM">7:00 AM</option>
                        <option value="8:00 AM">8:00 AM</option>
                        <option value="9:00 AM">9:00 AM</option>
                        <option value="10:00 AM">10:00 AM</option>
                        <option value="11:00 AM">11:00 AM</option>
                        <option value="12:00 PM">12:00 PM</option>
                        <option value="1:00 PM">1:00 PM</option>
                        <option value="2:00 PM">2:00 PM</option>
                        <option value="3:00 PM">3:00 PM</option>
                        <option value="4:00 PM">4:00 PM</option>
                        <option value="5:00 PM">5:00 PM</option>
                        <option value="6:00 PM">6:00 PM</option>
                        <option value="7:00 PM">7:00 PM</option>
                        <option value="8:00 PM">8:00 PM</option>
                        <option value="9:00 PM">9:00 PM</option>
                        <option value="10:00 PM">10:00 PM</option>
                        <option value="11:00 PM">11:00 PM</option>
                    </select>
                </label>

                @*Patient*@
                <label class="custom-label">
                    Patient
                    <input type="text" class="custom-input" ng-bind="editingAppt.patientName" placeholder="Patient" readonly>
                </label>
            </div>

            <div class="col s12">
                @*Purpose*@
                <label class="custom-label">
                    Purpose
                    <input type="text" class="custom-input" ng-model="editingAppt.purpose" placeholder="Purpose">
                </label>
            </div>

        </div>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="button" ng-click="updateAppointment()" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0 ">UPDATE</button>
    </div>
</div>

@*DELETE scheduled appointment*@
<div id="modalDeleteSchedAppt" class="modal appt-modal" style="width:30% !important">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Delete Scheduled Appointment</h5>

        <p class="custom-label">Are you sure you want to delete this scheduled appointment? </p>
        @* Hidden backup field to store apptID so client can fallback if scope is lost *@
        <input type="hidden" id="hiddenDeleteApptID" value="" />
    </div>

    <div class="modal-footer footer-center">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" ng-click="deleteAppointment()" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0 ">DELETE</button>
    </div>
</div>


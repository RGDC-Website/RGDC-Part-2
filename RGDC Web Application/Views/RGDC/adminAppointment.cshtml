@{
    Layout = "~/Views/Shared/_adminLayout.cshtml";
}

@*<div class="dashContainer" ng-controller="RGDCWebApplicationController">*@
<div class="dashContainer">
    @*top part (title, refresh, logout)*@
    <div class="row brown-text lighten-1" style="margin-top: 1rem">
        @*user name*@
        <div class="col m8 l8"><h4 class="bold">{{isUserDentist ? "Schedules" : "Appointments"}}</h4></div>
        @*refresh and logout buttons*@
        <div class="col hide-on-med-and-down l4">
            <span class="right">
                <div class="col valign-wrapper"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Refresh Dashboard"> <i class="material-icons brown-text lighten-1">refresh</i></a></div>
                <div class="col valign-wrapper" ng-click="logOut()"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Logout"> <i class="material-icons brown-text lighten-1">logout</i></a></div>
            </span>
        </div>
    </div>

    @*create new appointment button*@
    <div class="row m-0">
        <a ng-show="!isUserDentist" ng-click="prepareNewAppointmentRequest()" class="edit-btn modal-trigger left white-text" data-target="modalAddAppt"><i class="material-icons left">add</i>Schedule Appointment</a>
    </div>

    <div class="card grey lighten-2" style="margin-top:5vh;">
        <nav class="nav-extended grey lighten-2 z-depth-0">
            <div class="nav-content p-1">
                <ul class="tabs tabs-transparent center-tabs">
                    <li class="tab px-1"><a class="brown-text p-0" href="#sched">Scheduled</a></li>
                    <li class="tab px-1"><a class="brown-text p-0" href="#req">Requested</a></li>
                    <li class="tab px-1"><a class="brown-text p-0" href="#past">Past</a></li>
                </ul>
            </div>
        </nav>

        <div class="card-content">
            @*Scheduled Appointments*@
            <div id="sched" class="containerOverflow-2 row m-0">
                <p class="bold brown-text lighten-1" style="margin-bottom: -3vh; font-size:1.5rem;">Scheduled Appointments</p>
                @*admin scheduled appointments table*@
                <div class="row responsive-data-table-div">
                    <table id="adminScheduledAppointment" class="hover tblClk">
                        @*table headers*@
                        <thead>
                            <tr class="brown-text lighten-1">
                                <th>Date</th>
                                <th>Time</th>
                                <th>Purpose</th>
                                <th>Notes</th>
                                <th>Dentist</th>
                                <th>Patient</th>
                                <th colspan="2">Status</th>
                            </tr>
                        </thead>
                        @*table content*@
                        <tbody>
                            <tr ng-if="(!adminAppointments || adminAppointments.length === 0)">
                                <td class="center-align">No scheduled appointments found.</td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                            </tr>
                            <tr ng-repeat="appt in adminAppointments track by appt.apptID" data-href="#" class="clkPointer">
                                <td>{{appt.date}}</td>
                                <td>{{appt.time}}</td>
                                <td>{{appt.purpose}}</td>
                                <td class="notes-cell" title="{{appt.remarks || ''}}" style="white-space: pre-line;">{{appt.remarks}}</td>
                                <td>{{appt.dentistName}}</td>
                                <td>{{appt.patientName}}</td>
                                <td>{{appt.displayStatus || appt.status}}</td>
                                <td class="actions-cell" ng-show="!isUserDentist">
                                    <div class="appt-action-buttons" role="group" aria-label="Appointment actions">
                                        <a class="btn-floating btn-small brown lighten-4 p-0 smallBtn tooltipped redBtn"
                                           ng-click="openDeleteApptModal(appt, 'scheduled')"
                                           data-position="bottom" data-tooltip="Delete Appointment"
                                           aria-label="Delete appointment">
                                            <i class="material-icons brown-text lighten-1">delete</i>
                                        </a>

                                        <a class="btn-floating btn-small brown lighten-4 p-0 smallBtn tooltipped"
                                           ng-click="openEditApptModal(appt, $event)"
                                           data-position="bottom" data-tooltip="Edit Appointment"
                                           aria-label="Edit appointment">
                                            <i class="material-icons brown-text lighten-1">edit</i>
                                        </a>
                                        <a class="btn-floating btn-small brown lighten-4 p-0 smallBtn tooltipped reschedule-btn"
                                           data-apptid="{{appt.apptID}}"
                                           data-position="bottom" data-tooltip="Request Reschedule"
                                           aria-label="Request reschedule">
                                            <i class="material-icons brown-text lighten-1">autorenew</i>
                                        </a>
                                    </div>
                            </tr>
                        </tbody>
                        @*table footer*@
                        <tfoot>
                            <tr class="brown-text lighten-1">
                                <th>Date</th>
                                <th>Time</th>
                                <th>Purpose</th>
                                <th>Dentist</th>
                                <th>Patient</th>
                                <th colspan="2">Status</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>


            @*Requested Appointments*@
            <div id="req" class="containerOverflow-2 row m-0">
                <p class="bold brown-text lighten-1" style="margin-bottom: -3vh; font-size:1.5rem;">Requested Appointments</p>
                @*admin requested appointments table*@
                <div class="row responsive-data-table-div">
                    <table id="adminRequestedAppointment" class="hover tblClk">
                        @*table headers*@
                        <thead>
                            <tr class="brown-text lighten-1">
                                <th>Date</th>
                                <th>Time</th>
                                <th>Purpose</th>
                                <th>Notes</th>
                                <th>Dentist</th>
                                <th>Patient</th>
                                <th>Status</th>
                                <th style="text-align:center;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr ng-if="(!requestedAppointments || requestedAppointments.length === 0)">
                                <td class="center-align" colspan="8">No requested appointments found.</td>
                            </tr>
                            <tr ng-repeat="appt in requestedAppointments track by appt.apptID">
                                <td>{{appt.date}}</td>
                                <td>{{appt.time}}</td>
                                <td>{{appt.purpose}}</td>
                                <td class="notes-cell" title="{{appt.remarks || ''}}" style="white-space: pre-line;">{{appt.remarks}}</td>
                                <td>{{appt.dentistName}}</td>
                                <td>{{appt.patientName}}</td>
                                <td>{{appt.displayStatus || appt.status}}</td>
                                <td style="text-align:center; vertical-align:middle;">
                                    <div ng-if="canActOnRequest(appt)" style="display:flex; flex-direction:column; align-items:center;">
                                        <a href="#" class="btn-floating btn-small waves-effect waves-light brown lighten-1 tooltipped" ng-show="!isUserDentist" ng-click="acceptRequestedAppointment(appt.apptID)" data-position="right" data-tooltip="Confirm" style="margin-bottom:6px" aria-label="Accept requested appointment">
                                            <i class="material-icons tiny">check</i>
                                        </a>
                                        <a href="#" class="btn-floating btn-small waves-effect waves-light brown lighten-1 tooltipped" ng-show="!isUserDentist" ng-click="denyRequestedAppointment(appt.apptID)" data-position="right" data-tooltip="Deny" aria-label="Deny requested appointment">
                                            <i class="material-icons tiny">close</i>
                                        </a>
                                    </div>
                                    <div ng-if="!canActOnRequest(appt) && isRequestCreator(appt) && isRequestedStatus(appt)" style="display:flex; flex-direction:column; align-items:center;">
                                        <a href="#"
                                           class="btn-floating btn-small waves-effect waves-light brown lighten-1 tooltipped"
                                           ng-click="cancelRequestedAppointment(appt)"
                                           data-position="right"
                                           data-tooltip="Cancel Request"
                                           aria-label="Cancel requested appointment">
                                            <i class="material-icons tiny">cancel</i>
                                        </a>
                                    </div>
                                    <div ng-if="!canActOnRequest(appt) && isRequestCreator(appt) && isDeniedStatus(appt)" style="display:flex; flex-direction:column; align-items:center; margin-top:6px;">
                                        <a href="#"
                                           class="btn-floating btn-small waves-effect waves-light brown lighten-1 tooltipped redBtn"
                                           ng-click="deleteDeniedRequest(appt)"
                                           data-position="right"
                                           data-tooltip="Delete (Move to Past)"
                                           aria-label="Delete denied request">
                                            <i class="material-icons tiny">delete</i>
                                        </a>
                                    </div>
                                    <!-- Creator (sender) can cancel their own request; others see accept/deny based on role -->
                                </td>
                            </tr>
                        </tbody>
                        @*table footer*@
                        <tfoot>
                            <tr class="brown-text lighten-1">
                                <th>Date</th>
                                <th>Time</th>
                                <th>Purpose</th>
                                <th>Notes</th>
                                <th>Dentist</th>
                                <th>Patient</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>


            @*Past Appointments*@
            <div id="past" class="containerOverflow-2 row m-0">
                <p class="bold brown-text lighten-1" style="margin-bottom: -3vh; font-size:1.5rem;">Past Appointments</p>
                @*admin past appointments table*@
                <div class="row responsive-data-table-div">
                    <table id="adminPastAppointment" class="hover tblClk">
                        @*table headers*@
                        <thead>
                            <tr class="brown-text lighten-1">
                                <th>Date</th>
                                <th>Time</th>
                                <th>Purpose</th>
                                <th>Notes</th>
                                <th>Dentist</th>
                                <th>Patient</th>
                                <th colspan="2">Status</th>
                            </tr>
                        </thead>
                        @*table content*@
                        <tbody>
                            <tr ng-repeat="p in pastAppointments track by p.apptID">
                                <td>{{p.date}}</td>
                                <td>{{p.time}}</td>
                                <td>{{p.purpose}}</td>
                                <td class="notes-cell" title="{{p.remarks || ''}}" style="white-space: pre-line;">{{p.remarks}}</td>
                                <td>{{p.dentistName}}</td>
                                <td>{{p.patientName}}</td>
                                <td>{{p.displayStatus || p.status}}</td>
                                <td>
                                    <a ng-show="!isUserDentist" class="btn-floating btn-small waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 redBtn btn-archive-appt" ng-click="openArchivePastApptModal(p)" data-position="bottom" data-tooltip="Archive Appointment">
                                        <i class="material-icons brown-text lighten-1">archive</i>
                                    </a>
                                </td>
                            </tr>
                        </tbody>
                        @*table footer*@
                        <tfoot>
                            <tr class="brown-text lighten-1">
                                <th>Date</th>
                                <th>Time</th>
                                <th>Purpose</th>
                                <th>Dentist</th>
                                <th>Patient</th>
                                <th colspan="2">Status</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@*Add Appointment*@
<div id="modalAddAppt" class="modal appt-modal">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Add New Appointment</h5>

        <form novalidate>
            <div class="row">
                @*Date*@
                <div class="col s12 m6">
                    <label class="custom-label" for="addApptDate">Date <span class="required-mark">*</span></label>
                    <div class="datepicker-wrapper">
                        <input id="addApptDate"
                               type="text"
                               class="datepicker custom-input"
                               ng-model="newApptRequest.dateTime"
                               ng-change="updateTimeOptions()"
                               placeholder="MM/DD/YYYY"
                               min="{{minApptDate}}"
                               required />
                        <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                    </div>
                </div>
                <div class="col s12 m6">
                    <label class="custom-label" for="addApptTime">Time <span class="required-mark">*</span></label>

                    <select id="addApptTime"
                            class="custom-input browser-default"
                            ng-model="newApptRequest.time"
                            ng-options="t for t in timeOptions"
                            required>
                        <option value="">Select Time</option>

                    </select>


                    <span class="helper-text" style="color:#d32f2f;"
                          ng-if="(timeOptions && timeOptions.length === 0) && newApptRequest.dentistID && newApptRequest.dateTime">
                        Dentist is not available on the selected date. Please choose another date or dentist.
                    </span>

                    <!-- If no dentist or date selected yet, show guidance -->
                    <span class="helper-text" style="color:#9e9e9e;"
                          ng-if="!(newApptRequest.dentistID && newApptRequest.dateTime)">
                        Select a dentist and date to see available time slots.
                    </span>
                </div>
            </div>

            <div class="row">
                @*Dentist*@
                <div class="col s12 m6">
                    <label class="custom-label" for="addApptDentist">Dentist <span class="required-mark">*</span></label>
                    <div ng-if="!(currentUserAuthorization === '2' && currentUserPermission === '1')">
                        <select id="addApptDentist"
                                class="custom-input browser-default"
                                ng-model="newApptRequest.dentistID"
                                ng-options="d.dentistID as d.dentistName for d in dentistArray"
                                ng-change="updateTimeOptions()"
                                required>
                            <option value="">Select Dentist</option>
                        </select>
                    </div>
                    <div ng-if="(currentUserAuthorization === '2' && currentUserPermission === '1')">
                        <input type="text" class="custom-input" ng-model="currentDentist.dentistName" readonly />
                    </div>
                </div>

                @*Patient*@
                <div class="col s12 m6">
                    <label class="custom-label" for="addApptPatient">Patient <span class="required-mark">*</span></label>

                    <div ng-if="isUserPatient">
                        <input id="addApptPatient"
                               type="text"
                               class="custom-input"
                               ng-model="currentPatient.patientName"
                               placeholder="Patient"
                               readonly />
                    </div>
                    <div ng-if="!isUserPatient">
                        <select id="addApptPatient"
                                class="custom-input browser-default"
                                ng-model="newApptRequest.patientID"
                                ng-options="p.patientID as p.patientName for p in patientArray"
                                ng-change="updateTimeOptions()"
                                required>
                            <option value="">Select Patient</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="row">
                @*Purpose*@
                <div class="col s12">
                    <label class="custom-label" for="addApptPurpose">Purpose <span class="required-mark">*</span></label>
                    <input id="addApptPurpose" type="text" class="custom-input" ng-model="newApptRequest.reason" placeholder="Purpose" required />
                </div>
            </div>


            <div class="row">
                <div class="col s12">
                    <label class="custom-label" for="addApptContact">Contact Number</label>
                    <input id="addApptContact" type="text" class="custom-input" ng-model="newApptRequest.contactNumber" placeholder="09#########" maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                </div>
            </div>

            <div class="row">
                <div class="col s12">
                    <label class="custom-label" for="addApptNotes">Notes (optional)</label>
                    <textarea id="addApptNotes" class="materialize-textarea custom-input" ng-model="newApptRequest.notes" placeholder="Additional notes (optional)"></textarea>
                </div>
            </div>

        </form>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight:500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" ng-click="createNewAppointmentRequest()" style="font-weight:500; margin: -.8vh 2.3vh -1.2vh 0">ADD</button>
    </div>
</div>

@*ACCEPT scheduled appointment*@
<div id="modalAcceptAppt" class="modal appt-modal" style="width:30% !important">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Accept Appointment</h5>

        <p class="custom-label">Are you sure you want to accept this requested appointment?</p>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0">ACCEPT</button>
    </div>
</div>

@*DENY scheduled appointment*@
<div id="modalDenyAppt" class="modal appt-modal" style="width:30% !important">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Deny Appointment</h5>

        <p class="custom-label">Are you sure you want to deny this requested appointment?</p>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0">DENY</button>
    </div>
</div>


@*EDIT scheduled Appointment*@
<div id="modalEditSchedAppt" class="modal appt-modal">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Edit Scheduled Appointment</h5>

        <!-- Hidden field to store apptID separately -->
        <input type="hidden" id="hiddenApptID" value="">

        <div class="row">
            <div class="col s6">
                @*Date*@
                <label class="custom-label">Date</label>
                <div class="datepicker-wrapper">
                    <input id="date" type="text" class="datepicker custom-input" ng-model="editingAppt.dateObj" placeholder="MM/DD/YYYY" min="{{minApptDate}}" disabled>
                    <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                </div>

                @*Dentist*@
                <label class="custom-label">
                    Dentist
                    <input type="text" class="custom-input" ng-model="editingAppt.dentistName" placeholder="Dentist" readonly disabled>
                </label>
            </div>

            <div class="col s6">
                @*Time (view-only)*@
                <label class="custom-label">
                    Time
                    <input type="text" class="custom-input" ng-model="editingAppt.timeStr" placeholder="Time" readonly disabled>
                </label>

                @*Patient*@
                <label class="custom-label">
                    Patient
                    <input type="text" class="custom-input" ng-model="editingAppt.patientName" placeholder="Patient" readonly disabled>
                </label>
            </div>

            <div class="col s12">
                <label class="custom-label">Status</label>
                <select class="custom-input browser-default"
                        ng-model="editingAppt.status"
                        ng-options="s for s in statusOptions"
                        ng-disabled="isUserPatient">
                    <option value="">Select Status</option>
                </select>
                <span class="helper-text" ng-if="isUserPatient" style="color: #666; font-size:0.9rem;">
                    Status can only be changed by dentist/clinic staff.
                </span>
            </div>

            <div class="col s12">
                @*Purpose*@
                <label class="custom-label">
                    Purpose
                    <input type="text" class="custom-input" ng-model="editingAppt.purpose" placeholder="Purpose">
                </label>
            </div>

            <div class="col s12">
                <label class="custom-label">
                    Notes
                    <textarea class="custom-input" ng-model="editingAppt.remarks" placeholder="Enter notes / procedure details"
                              ng-disabled="isUserPatient"></textarea>
                </label>
                <span class="helper-text" ng-if="isUserPatient" style="color: #666; font-size:0.9rem;">
                    Notes are read-only for patient users.
                </span>
            </div>

        </div>
    </div>

    <div class="modal-footer footer-center">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="button" ng-click="updateAppointment()" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0     ">UPDATE</button>
    </div>
</div>

@*DELETE scheduled appointment*@
<div id="modalDeleteSchedAppt" class="modal appt-modal" style="width:30% !important">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Delete Scheduled Appointment</h5>

        <p class="custom-label">Are you sure you want to delete this scheduled appointment? Please provide a reason (shown in Past Appointments).</p>

        <div class="row" style="margin-top:10px;">
            <div class="col s12">
                <label class="custom-label">Reason <span class="required-mark">*</span></label>
                <textarea id="deleteApptReason" class="custom-input" ng-model="deleteApptReason" placeholder="Enter reason for deletion/cancellation" required></textarea>
            </div>
        </div>

        <input type="hidden" id="hiddenDeleteApptID" value="" />
    </div>

    <div class="modal-footer footer-center">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" ng-click="deleteAppointment()" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0 ">DELETE</button>
    </div>
</div>

@*RESCHEDULE appointment*@
<div id="modalRescheduleAppt" class="modal appt-modal">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Request Reschedule</h5>

        <form novalidate>
            <input type="hidden" id="rescheduleOriginalApptID" ng-model="rescheduleRequest.originalApptID" />

            <div class="row">
                <div class="col s12 m6">
                    <label class="custom-label" for="rescheduleDate">New Date <span class="required-mark">*</span></label>
                    <div class="datepicker-wrapper">
                        <input id="rescheduleDate"
                               type="text"
                               class="datepicker custom-input"
                               ng-model="rescheduleRequest.dateTime"
                               placeholder="MM/DD/YYYY"
                               min="{{minApptDate}}"
                               required />
                        <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                    </div>
                </div>

                <div class="col s12 m6">
                    <label class="custom-label" for="rescheduleTime">New Time <span class="required-mark">*</span></label>
                    <select id="rescheduleTime"
                            class="custom-input browser-default"
                            ng-model="rescheduleRequest.time"
                            ng-options="t for t in rescheduleTimeOptions">
                        <option value="">Select Time</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col s12 m6">
                    <label class="custom-label">Dentist</label>
                    <input type="text" class="custom-input" ng-model="rescheduleRequest.dentistName" readonly />
                </div>

                <div class="col s12 m6">
                    <label class="custom-label">Patient</label>
                    <input type="text" class="custom-input" ng-model="rescheduleRequest.patientName" readonly />
                </div>
            </div>

            <div class="row">
                <div class="col s12">
                    <label class="custom-label">Reason <span class="required-mark">*</span></label>
                    <textarea class="custom-input" ng-model="rescheduleRequest.reason" placeholder="Reason for reschedule" required></textarea>
                </div>
            </div>

            <div class="row">
                <div class="col s12 m6">
                    <label class="custom-label">Your Name</label>
                    <input type="text" class="custom-input" ng-model="rescheduleRequest.requesterName" readonly />
                </div>
                <div class="col s12 m6">
                    <label class="custom-label">Contact Number <span class="required-mark">*</span></label>
                    <input type="tel"
                           id="rescheduleContactNumber"
                           class="custom-input"
                           ng-model="rescheduleRequest.contactNumber"
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                           placeholder="09XXXXXXXXX"
                           maxlength="11"
                           inputmode="numeric"
                           pattern="^09\\d{9}$"
                           required />
                </div>
            </div>
        </form>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight:500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="button" class="edit-btn" ng-click="createRescheduleRequest()" style="font-weight:500; margin: -.8vh 2.3vh -1.2vh 0">REQUEST</button>
    </div>
</div>

@*EDIT requested Appointment*@
<div id="modalEditReqAppt" class="modal appt-modal">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Edit Requested Appointment</h5>

        <div class="row">
            <div class="col s6">
                @*Date*@
                <label class="custom-label">Date</label>
                <div class="datepicker-wrapper">
                    <input id="date" type="text" class="datepicker custom-input" placeholder="MM/DD/YYYY">
                    <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                </div>

                @*Dentist*@
                <label class="custom-label">
                    Dentist
                    <input type="text" class="custom-input" placeholder="Dentist">
                </label>
            </div>

            <div class="col s6">
                @*Time*@
                <label class="custom-label">
                    Time
                    <input type="text" class="custom-input" placeholder="00:00 AM">
                </label>

                @*Patient*@
                <label class="custom-label">
                    Patient
                    <input type="text" class="custom-input" placeholder="Patient">
                </label>
            </div>

            <div class="col s12">
                @*Purpose*@
                <label class="custom-label">
                    Purpose
                    <input type="text" class="custom-input" placeholder="Purpose">
                </label>
            </div>

        </div>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0">EDIT</button>
    </div>
</div>

@*DELETE requested appointment*@
<div id="modalDeleteReqAppt" class="modal appt-modal" style="width:30% !important">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Delete Requested Appointment</h5>

        <p class="custom-label">Are you sure you want to delete this requested appointment?</p>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0">DELETE</button>
    </div>
</div>

@*ARCHIVE Past appointment*@
<div id="modalDeletePastAppt" class="modal appt-modal" style="width:30% !important">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Archive Past Appointment</h5>

        <p class="custom-label">Are you sure you want to archive this past appointment? It will be removed from the Past Appointments list.</p>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" ng-click="archivePastAppointment()" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0">ARCHIVE</button>
    </div>
</div>

@*VIEW scheduled Appointment*@
<div id="modalViewSchedAppt" class="modal appt-modal">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Scheduled Appointment</h5>

        <!-- Hidden field to store apptID separately -->
        <input type="hidden" id="hiddenApptID" value="">

        <div class="row">
            <div class="col s6">
                @*Date*@
                <label class="custom-label">Date</label>
                <div class="datepicker-wrapper">
                    <input id="date" type="text" class="datepicker custom-input" ng-model="editingAppt.dateObj" placeholder="MM/DD/YYYY" min="{{minApptDate}}" disabled>
                    <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                </div>

                @*Dentist*@
                <label class="custom-label">
                    Dentist
                    <input type="text" class="custom-input" ng-model="editingAppt.dentistName" placeholder="Dentist" readonly disabled>
                </label>
            </div>

            <div class="col s6">
                @*Time (view-only)*@
                <label class="custom-label">
                    Time
                    <input type="text" class="custom-input" ng-model="editingAppt.timeStr" placeholder="Time" readonly disabled>
                </label>

                @*Patient*@
                <label class="custom-label">
                    Patient
                    <input type="text" class="custom-input" ng-model="editingAppt.patientName" placeholder="Patient" readonly disabled>
                </label>
            </div>

            <div class="col s12">
                <label class="custom-label">Status</label>
                <select class="custom-input browser-default" disabled
                        ng-model="editingAppt.status"
                        ng-options="s for s in statusOptions">
                    <option value="">Select Status</option>
                </select>
                <span class="helper-text" ng-if="isUserPatient" style="color: #666; font-size:0.9rem;">
                    Status can only be changed by dentist/clinic staff.
                </span>
            </div>

            <div class="col s12">
                @*Purpose*@
                <label class="custom-label">
                    Purpose
                    <input disabled type="text" class="custom-input" ng-model="editingAppt.purpose" placeholder="Purpose">
                </label>
            </div>

            <div class="col s12">
                <label class="custom-label">
                    Notes
                    <textarea class="custom-input" ng-model="editingAppt.remarks" placeholder="Enter notes / procedure details"
                              disabled></textarea>
                </label>
                <span class="helper-text" ng-if="isUserPatient" style="color: #666; font-size:0.9rem;">
                    Notes are read-only for patient users.
                </span>
            </div>

        </div>
    </div>

    <div class="modal-footer footer-center">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
    </div>
</div>


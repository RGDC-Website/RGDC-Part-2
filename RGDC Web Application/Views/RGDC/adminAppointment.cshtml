@section Scripts {
    <script>
        (function () {
            if (typeof M !== 'undefined' && M.Modal) {
                var elems = document.querySelectorAll('.modal');
                M.Modal.init(elems);
            }

            var apptToDelete = null;

            $(document).on('click', '.btn-delete-appt', function (e) {
                e.preventDefault();
                // read data-apptid 
                apptToDelete = $(this).attr('data-apptid') || $(this).data('apptid') || null;

                var target = $(this).attr('data-target') || $(this).data('target');
                if (target) {
                    var $modal = $('#' + target);
                    if ($modal.length) {
                        if (typeof M !== 'undefined' && M.Modal) {
                            var instance = M.Modal.getInstance($modal[0]);
                            if (instance) instance.open();
                            else $modal.modal('open');
                        } else {
                            $modal.modal('open');
                        }
                    }
                }
            });

            // Confirm deletion buttons 
            $(document).on('click', '#modalDeleteSchedAppt .edit-btn, #modalDeleteReqAppt .edit-btn, #modalDeletePastAppt .edit-btn', function (e) {
                e.preventDefault();

                if (!apptToDelete) {
                    if (typeof M !== 'undefined' && M.toast) {
                        M.toast({ html: 'No appointment selected.' });
                    } else {
                        alert('No appointment selected.');
                    }
                    return;
                }

                // POST (form data)
                $.post('/RGDC/DeleteAppointment', { apptID: apptToDelete })
                    .done(function (res) {
                        if (res && res.success) {
                            // close open modal
                            var $openModal = $('.modal.open');
                            if ($openModal.length) {
                                if (typeof M !== 'undefined' && M.Modal) {
                                    var inst = M.Modal.getInstance($openModal[0]);
                                    if (inst) inst.close();
                                } else {
                                    $openModal.modal('close');
                                }
                            }

                            // remove rows that contain the same data-apptid
                            $('tr').filter(function () {
                                var $btn = $(this).find('.btn-delete-appt');
                                return $btn.length && ($btn.attr('data-apptid') == apptToDelete || $btn.data('apptid') == apptToDelete);
                            }).remove();

                            if (typeof M !== 'undefined' && M.toast) {
                                M.toast({ html: 'Appointment deleted.' });
                            } else {
                                alert('Appointment deleted.');
                            }
                        } else {
                            var msg = (res && res.message) ? res.message : 'Error deleting appointment.';
                            if (typeof M !== 'undefined' && M.toast) {
                                M.toast({ html: msg });
                            } else {
                                alert(msg);
                            }
                        }
                    })
                    .fail(function () {
                        if (typeof M !== 'undefined' && M.toast) {
                            M.toast({ html: 'Error deleting appointment (server error).' });
                        } else {
                            alert('Error deleting appointment (server error).');
                        }
                    });
            });
        })();
    </script>
}

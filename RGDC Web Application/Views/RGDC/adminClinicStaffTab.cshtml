@*EDIT Owner Information Form*@
<div id="ownerInformationFormEdit" class="modal patientInformationForm-modal">

    <input id="ownerPhotoInput" type="file" accept="image/*" style="display:none"
           onchange="angular.element(this).scope().onPhotoSelected(this.files, 'owner')" />
    <div>
        <h5 class="modal-form-title">Edit Owner Profile</h5>

        <form>
            <div class="row">
                <div class="col s4">
                    @*Photo upload*@
                    <div class="row s4 center-align" style="margin-top: 2.5vh; margin-left: 2.5vh;">
                        <div class="col s12">
                            <div class="photo-box" ng-click="pickPhoto('ownerEdit')" style="cursor:pointer;">
                                <img ng-if="ownerPhotoPreviewEdit" ng-src="{{ownerPhotoPreviewEdit}}" alt="Preview" style="width:100%; height:100%; object-fit:cover;" />
                                <i class="material-icons photo-placeholder-icon" ng-if="!ownerPhotoPreviewEdit">image</i>
                            </div>
                            <input id="ownerPhotoInputEdit" type="file" accept="image/*" style="display:none"
                                   onchange="angular.element(this).scope().onPhotoSelected(this.files, 'ownerEdit')" />
                        </div>
                    </div>
                </div>

                <div class="col s8">
                    <div class="row">
                        @*First name*@
                        <div class="col s6">
                            <p class="custom-label">First Name <span class="required-mark">*</span></p>
                            <input type="text"
                                   ng-model="owner.firstName"
                                   class="custom-input"
                                   maxlength="150"
                                   placeholder="Juan"
                                   required
                                   ng-change="ownerFirstNameTouched = true; ownerFirstNameValid = isNonEmpty(owner.firstName)"
                                   ng-class="{'input-valid': ownerFirstNameTouched && ownerFirstNameValid, 'input-invalid': ownerFirstNameTouched && !ownerFirstNameValid}" />
                        </div>
                        @*MIddle name*@
                        <div class="col s6">
                            <p class="custom-label">Middle Name <span class="required-mark">*</span></p>
                            <input type="text"
                                   ng-model="owner.middleName"
                                   class="custom-input"
                                   maxlength="150"
                                   placeholder="Mercado"
                                   required />
                        </div>
                    </div>
                    <div class="row">
                        @*Last name*@
                        <div class="col s12">
                            <p class="custom-label">Last Name <span class="required-mark">*</span></p>
                            <input type="text"
                                   ng-model="owner.lastName"
                                   class="custom-input"
                                   maxlength="150"
                                   placeholder="Dela Cruz"
                                   required
                                   ng-change="ownerLastNameTouched = true; ownerLastNameValid = isNonEmpty(owner.lastName)"
                                   ng-class="{'input-valid': ownerLastNameTouched && ownerLastNameValid, 'input-invalid': ownerLastNameTouched && !ownerLastNameValid}" />
                        </div>
                    </div>
                </div>
            </div>

            @*Email*@
            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Email <span class="required-mark">*</span></p>
                    <input type="text" class="custom-input"
                           ng-model="owner.email"
                           maxlength="150"
                           placeholder="juandlc@gmail.com"
                           required
                           ng-focus="ownerEmailTouched = true"
                           ng-change="validateOwnerEmailEdit(); ownerEmailTouched = true"
                           ng-class="{'input-valid': ownerEmailTouched && ownerEmailFormatValid && !ownerEmailTaken, 'input-invalid': ownerEmailTouched && (!ownerEmailFormatValid || ownerEmailTaken)}" />

                    <p class="helper-text" style="margin-top:.4rem;">
                        <span ng-show="ownerEmailTouched && owner.email" ng-style="{'color': ownerEmailFormatValid ? '#2e7d32' : '#d32f2f'}">
                            {{ ownerEmailFormatValid ? 'Email is valid' : 'Enter a valid email address' }}
                        </span>
                        <span ng-show="ownerEmailTouched && ownerEmailFormatValid && ownerEmailTaken" style="color:#d32f2f; display:block; margin-top:.2rem;">
                            Email already taken
                        </span>
                    </p>
                </div>
            </div>

            <div class="row">
                @*Gender*@
                <div class="col s3">
                    <p class="custom-label">Gender <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input" ng-model="owner.genderID" ng-options="g.genderID as g.description for g in genderArray" ng-change="/* optional */">
                        <option value="" disabled selected>Select Gender</option>
                    </select>
                </div>
                @*Birthdate*@
                <div class="col s3">
                    <p class="custom-label">Birth Date <span class="required-mark">*</span></p>
                    <div class="datepicker-wrapper">
                        <input id="owner_birthDate" ng-model="owner.birthDate" type="text" class="datepicker custom-input" readonly required />
                        <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                    </div>
                </div>

                <div class="col s3">
                    @*Civil status*@
                    <p class="custom-label">Civil Status <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input" required ng-model="owner.civilStatus">
                        <option value="" disabled selected>Select Status</option>
                        <option value="1">Single</option>
                        <option value="2">Married</option>
                        <option value="3">Widowed</option>
                    </select>
                </div>
                <div class="col s3">
                    @*Contact number*@
                    <p class="custom-label">Contact Number <span class="required-mark">*</span></p>
                    <input id="ownerContactNumber"
                           ng-model="owner.contactNumber"
                           type="text"
                           class="custom-input"
                           placeholder="09XXXXXXXXX"
                           maxlength="11"
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                           ng-change="ownerContactTouched = true; validateOwnerEditFields()"
                           ng-class="{'input-valid': ownerContactTouched && ownerContactValid, 'input-invalid': ownerContactTouched && !ownerContactValid}"
                           required />
                </div>
            </div>

            <div class="row">
                <div class="col s12">
                    @*Address*@
                    <p class="custom-label">Address <span class="required-mark">*</span></p>
                    <input id="ownerAddress"
                           ng-model="owner.address"
                           type="text"
                           class="custom-input"
                           maxlength="250"
                           required
                           ng-change="ownerAddressTouched = true; validateOwnerEditFields()"
                           ng-class="{'input-valid': ownerAddressTouched && ownerAddressValid, 'input-invalid': ownerAddressTouched && !ownerAddressValid}" />                </div>
            </div>

            <div class="row">
                @*Specialization*@
                <div class="col s12">
                    <p class="custom-label">Specialization</p>
                    <input type="text" ng-model="owner.specialization" class="custom-input" maxlength="50" />
                </div>
            </div>
        </form>
    </div>

    @*Submit or cancel*@
    <div class="modal-footer footer-center" style="margin-top:2.5vh">
        <button type="button" class="edit-btn left" style="font-weight:500;" ng-click="pickPhoto('ownerEdit')">UPLOAD PHOTO</button>
        <button class="modal-close cancel-btn" style="font-weight:500; margin-right:.5vh">CANCEL</button>
        <button type="submit" class="edit-btn" style="font-weight:500;"
                ng-click="editOwner()"
                ng-disabled="
                    !ownerFirstNameValid || !ownerLastNameValid || !ownerAddressValid ||
                    !ownerContactValid || !ownerEmailFormatValid || ownerEmailTaken ||
                    !owner.genderID || !owner.birthDate || !owner.civilStatus
                ">
            EDIT
        </button>
    </div>
</div>


                                        <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 modal-trigger responsive-btn-roundedSquare" data-target="dentistInformationFormEdit" title="View Account Details"><i class="material-icons brown-text lighten-1" ng-click="selectDentist(dentist.dentistID)">visibility</i></a>
                                    </td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr class="brown-text lighten-1">
                                    <th>Name</th>
                                    <th>Specialization</th>
                                    <th>Branch</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    <div ng-show="showDentistArchived">
                        <table id="adminClinicStaffTabTableDentistD" class="hover tableClk">
                            <thead>
                                <tr class="brown-text lighten-1">
                                    <th>Name</th>
                                    <th>Specialization</th>
                                    <th colspan="2">Branch</th>
                                </tr>
                            </thead>
                            @*table content*@
                            <tbody>
                                <tr data-href="#" ng-repeat="dentist in clinicDentistsD track by dentist.dentistID" on-finish-render table-id="adminClinicStaffTabTableDentistD">
                                    <td>{{dentist.fullName}}</td>
                                    <td>{{dentist.specialization}}</td>
                                    <td>{{dentist.description}}</td>

                    </div>
                    <div ng-show="showOwnerArchived">
                        <table id="adminClinicStaffTabTableOwnerD" class="hover tableClk">
                            <thead>
                                <tr class="brown-text lighten-1">
                                    <th>Name</th>
                                    <th colspan="2">Specialization</th>
                                </tr>
                            </thead>
                            @*table content*@
                            <tbody>
                                <tr data-href="#" ng-repeat="owner in clinicOwnersD track by owner.ownerID" on-finish-render table-id="adminClinicStaffTabTableOwnerD">
                                    <td>{{owner.fullName}}</td>
                                    <td>{{owner.specialization}}</td>
                                    <td>
                                        <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 redBtn modal-trigger" data-target="modalDeleteOwner" title="Archive Account"><i class="material-icons brown-text lighten-1" ng-click="selectArchiveOwner(owner.accID)" ng-show="isUserSAdmin">archive</i></a>
                                        <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 modal-trigger responsive-btn-roundedSquare" data-target="ownerInformationFormEdit" title="View Account Details" ng-click="selectOwner(owner.ownerID)"><i class="material-icons brown-text lighten-1">visibility</i></a>
                                    </td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr class="brown-text lighten-1">
                                    <th>Dentist Name</th>
                                    <th colspan="2">Specialization</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>



                @*pending*@
                <div id="Pending" class="containerOverflow-2 row m-0" ng-init="getPending()" ng-show="isUserOwner">
                    <div class="row m-0">
                        <p class="bold brown-text lighten-1" style="font-size:1.8rem;">Pending</p>
                    </div>
                    @*pending Table*@
                    <table id="adminClinicStaffTabTablePending" class="hover tableClk">
                        <thead>
                            <tr class="brown-text lighten-1">
                                <th>Email</th>
                                <th colspan="2">Role</th>
                            </tr>
                        </thead>
                        @*table content*@
                        <tbody>
                            <tr ng-repeat="pendingAcc in pendingAccounts track by pendingAcc.addID" on-finish-render table-id="adminClinicStaffTabTablePending">
                                <td>{{pendingAcc.email}}</td>
                                <td>{{pendingAcc.permission == "0" ? "Owner" : pendingAcc.permission == "1" ? "Dentist" : "Staff"}}</td>
                                <td>
                                    <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 redBtn " data-target="modalDeleteStaff" title="Delete Request"><i class="material-icons brown-text lighten-1" ng-click="selectRemove(pendingAcc.addID)">delete</i></a>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr class="brown-text lighten-1">
                                <th>Email</th>
                                <th colspan="2">Role</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>


            </div>
    </div>

</div>


@*ADD Owner Information Form*@
<div id="ownerInformationFormAdd" class="modal patientInformationForm-modal">
    <div>
        <h5 class="modal-form-title">Add New Owner</h5>

        @*Email*@
        <div class="row">
            <div class="col s12">
                <p class="custom-label">Email <span class="required-mark">*</span></p>
                <input type="text" class="custom-input"
                       ng-model="owner_email"
                       maxlength="150"
                       placeholder="juandlc@gmail.com"
                       ng-change="checkAddOwnerEmail()"
                       ng-focus="showOwnerEmailHint = true"
                       ng-class="{
                       'input-valid': ownerEmailFormatValid && !ownerEmailTaken,
                       'input-invalid': owner_email && !ownerEmailFormatValid
                   }"
                       required>
                <p class="helper-text" style="margin-top:.4rem;">
                    <span ng-show="owner_email"
                          ng-style="{'color': ownerEmailFormatValid ? '#2e7d32' : '#d32f2f'}">
                        {{ ownerEmailFormatValid ? 'Email is valid' : 'Enter a valid email address' }}
                    </span>
                    <span ng-show="ownerEmailFormatValid && ownerEmailTaken" style="color:#d32f2f; display:block; margin-top:.2rem;">
                        Email already taken
                    </span>
                </p>
            </div>
        </div>
    </div>


    @*Submit or cancel*@
    <div class="modal-footer" style="margin-top:2.5vh">
        <button class="modal-close cancel-btn left" style="font-weight: 500; margin-right: .5vh">CANCEL</button>
        <button type="submit"
                class="edit-btn modal-close"
                ng-click="addOwner()"
                ng-disabled="!ownerEmailFormatValid">
            ADD
        </button>
    </div>
</div>


                    <p class="custom-label">Email <span class="required-mark">*</span></p>
                    <input type="text" class="custom-input"
                           ng-model="dentist.email"
                           maxlength="150"
                           placeholder="juandlc@gmail.com"
                           required
                           ng-focus="dentistEmailTouched = true"
                           ng-change="validateDentistEmailEdit(); dentistEmailTouched = true"
                           ng-class="{'input-valid': dentistEmailTouched && dentistEmailFormatValid && !dentistEmailTaken, 'input-invalid': dentistEmailTouched && (!dentistEmailFormatValid || dentistEmailTaken)}" />
                    <p class="helper-text" style="margin-top:.4rem;">
                        <span ng-show="dentistEmailTouched && dentist.email" ng-style="{'color': dentistEmailFormatValid ? '#2e7d32' : '#d32f2f'}">
                            {{ dentistEmailFormatValid ? 'Email is valid' : 'Enter a valid email address' }}
                        </span>
                        <span ng-show="dentistEmailTouched && dentistEmailFormatValid && dentistEmailTaken" style="color:#d32f2f; display:block; margin-top:.2rem;">
                            Email already taken
                        </span>
                    </p>
                </div>
            </div>

            @*Basta eto validation para sa mga iniinvalidate nyong feelings*@
            <div class="row">
                <div class="col s3">
                    <p class="custom-label">Gender <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input" ng-model="dentist.genderID" ng-options="g.genderID as g.description for g in genderArray">
                        <option value="" disabled selected>Select Gender</option>
                    </select>
                </div>
                <div class="col s3">
                    <p class="custom-label">Birth Date <span class="required-mark">*</span></p>
                    <div class="datepicker-wrapper">
                        <input id="dentist_birthDate" type="text" ng-model="dentist.birthDate" class="datepicker custom-input" readonly required />
                        <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                    </div>
                </div>
                <div class="col s3">
                    <p class="custom-label">Civil Status <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input" required ng-model="dentist.civilStatus">
                        <option value="" disabled selected>Select Status</option>
                        <option value="1">Single</option>
                        <option value="2">Married</option>
                        <option value="3">Widowed</option>
                    </select>
                </div>
                <div class="col s3">
                    <p class="custom-label">Contact Number <span class="required-mark">*</span></p>
                    <input id="dentistContactNumber"
                           ng-model="dentist.contactNumber"
                           type="text"
                           class="custom-input"
                           placeholder="09XXXXXXXXX"
                           maxlength="11"
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                           ng-change="dentistContactTouched = true; validateDentistEditFields()"
                           ng-class="{'input-valid': dentistContactTouched && dentistContactValid, 'input-invalid': dentistContactTouched && !dentistContactValid}"
                           required />
                </div>
            </div>

            @*Address*@
            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Address <span class="required-mark">*</span></p>
                    <input id="dentistAddress"
                           ng-model="dentist.address"
                           type="text"
                           class="custom-input"
                           maxlength="250"
                           required
                           ng-change="dentistAddressTouched = true; validateDentistEditFields()"
                           ng-class="{'input-valid': dentistAddressTouched && dentistAddressValid, 'input-invalid': dentistAddressTouched && !dentistAddressValid}" />                
                </div>
            </div>

            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Specialization</p>
                    <input type="text" ng-model="dentist.specialization" class="custom-input" maxlength="50" />
                </div>
            </div>
            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Branch</p>
                    <select class="browser-default custom-input" ng-model="dentist.branchID" ng-options="b.branchID as b.description for b in branchArray">
                        <option value="" disabled selected>Select Branch</option>
                    </select>
                </div>
            </div>
        </form>
    </div>

    @*Submit or cancel*@
    <div class="modal-footer footer-center" style="margin-top:2.5vh">
        <button type="button" class="edit-btn left" style="font-weight:500;" ng-click="pickPhoto('dentistEdit')">UPLOAD PHOTO</button>
        <button class="modal-close cancel-btn" style="font-weight:500; margin-right:.5vh">CANCEL</button>
        <button type="submit" class="edit-btn" style="font-weight:500;"
                ng-click="editDentist()"
                ng-disabled="
                    !dentistFirstNameValid || !dentistLastNameValid || !dentistAddressValid ||
                    !dentistContactValid || !dentistEmailFormatValid || dentistEmailTaken ||
                    !dentist.genderID || !dentist.birthDate || !dentist.civilStatus
                ">
            EDIT
        </button>
    </div>
</div>


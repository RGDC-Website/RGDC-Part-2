                    <p class="custom-label">Religion <span class="required-mark">*</span></p>
                    <input id="religion"
                           type="text"
                           class="custom-input"
                           ng-model="dentist.religion"
                           placeholder="Roman-Catholic"
                           maxlength="50"
                           required
                           disabled />
                </div>

                <div class="col s6">
                    @*Nationality*@
                    <p class="custom-label">Nationality <span class="required-mark">*</span></p>
                    <input id="contactNumber"
                           type="text"
                           ng-model="dentist.nationality"
                           class="custom-input"
                           placeholder="Filipino"
                           maxlength="50"
                           required
                           disabled />
                </div>
            </div>
            @*Address*@
            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Address <span class="required-mark">*</span></p>
                    <input id="dentistAddress"
                           ng-model="dentist.address"
                           type="text"
                           class="custom-input"
                           maxlength="250"
                           required
                           disabled />
                </div>
            </div>

            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Specialization</p>
                    <input type="text" disabled ng-model="dentist.specialization" class="custom-input" maxlength="50" />
                </div>
            </div>
            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Branch</p>
                    <select disabled class="browser-default custom-input" ng-model="dentist.branchID" ng-options="b.branchID as b.description for b in branchArray">
                        <option value="" selected>Select Branch</option>
                    </select>
                </div>
            </div>
        </form>
    </div>

    @*Submit or cancel*@
    <div class="modal-footer footer-center" style="margin-top:2.5vh">
        <button class="modal-close cancel-btn" style="font-weight:500; margin-right:.5vh">EXIT</button>
    </div>
</div>

@*View Staff Information Form*@
<div id="staffInformationFormEdit" class="modal patientInformationForm-modal">
    <input id="ownerPhotoInputEdit" type="file" accept="image/*" style="display:none"
           onchange="angular.element(this).scope().onPhotoSelected(this.files, 'staffEdit')" />
    <div>
        <h5 class="modal-form-title">View Staff Profile</h5>


        <form>
            <div class="row">
                <div class="col s4">
                    @*Photo upload*@
                    <div class="row s4 center-align" style="margin-top: 2.5vh; margin-left: 2.5vh;">
                        <div class="col s12">
                            <div class="photo-box" style="cursor:pointer;">
                                <img ng-src="{{staff.photoLink}}" alt="Preview" style="width:100%; height:100%; object-fit:cover;" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col s8">
                    <div class="row">
                        <div class="col s6">
                            <p class="custom-label">First Name <span class="required-mark">*</span></p>
                            <input type="text"
                                   ng-model="staff.firstName"
                                   class="custom-input"
                                   maxlength="150"
                                   placeholder="Juan"
                                   required
                                   disabled />
                        </div>
                        <div class="col s6">
                            <p class="custom-label">Middle Name <span class="required-mark">*</span></p>
                            <input type="text" ng-model="staff.middleName" class="custom-input" maxlength="150" placeholder="Mercado" disabled required />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col s12">
                            <p class="custom-label">Last Name <span class="required-mark">*</span></p>
                            <input type="text"
                                   ng-model="staff.lastName"
                                   class="custom-input"
                                   maxlength="150"
                                   placeholder="Dela Cruz"
                                   required
                                   disabled />
                        </div>
                    </div>
                </div>
            </div>

            @*Email*@
            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Email <span class="required-mark">*</span></p>
                    <input type="text" class="custom-input"
                           ng-model="staff.email"
                           maxlength="150"
                           placeholder="juandlc@gmail.com"
                           required
                           disabled />
                </div>
            </div>

            <div class="row">
                <div class="col s3">
                    <p class="custom-label">Gender <span class="required-mark">*</span></p>
                    <select disabled class="browser-default custom-input" ng-model="staff.genderID" ng-options="g.genderID as g.description for g in genderArray">
                        <option value="" disabled selected>Select Gender</option>
                    </select>
                </div>
                <div class="col s3">
                    <p class="custom-label">Birth Date <span class="required-mark">*</span></p>
                    <div class="datepicker-wrapper">
                        <input id="staff_birthDate" disabled type="text" ng-model="staff.birthDate" class="datepicker custom-input" readonly required />
                    </div>
                </div>
                <div class="col s3">
                    <p class="custom-label">Civil Status <span class="required-mark">*</span></p>
                    <select disabled class="browser-default custom-input" required ng-model="staff.civilStatus">
                        <option value="" disabled selected>Select Status</option>
                        <option value="1">Single</option>
                        <option value="2">Married</option>
                        <option value="3">Widowed</option>
                        <option value="4">Legally Separated</option>
                        <option value="5">Annulled/Void</option>
                        <option value="6">Divorced</option>
                    </select>
                </div>
                <div class="col s3">
                    <p class="custom-label">Contact Number <span class="required-mark">*</span></p>
                    <input id="staffContactNumber"
                           ng-model="staff.contactNumber"
                           type="text"
                           class="custom-input"
                           placeholder="09XXXXXXXXX"
                           maxlength="11"
                           disabled
                           required />
                </div>
            </div>
            <div class="row">
                <div class="col s6">
                    @*Religion*@
                    <p class="custom-label">Religion <span class="required-mark">*</span></p>
                    <input id="religion"
                           type="text"
                           class="custom-input"
                           ng-model="staff.religion"
                           placeholder="Roman-Catholic"
                           maxlength="50"
                           required
                           disabled />
                </div>

                <div class="col s6">
                    @*Nationality*@
                    <p class="custom-label">Nationality <span class="required-mark">*</span></p>
                    <input id="contactNumber"
                           type="text"
                           ng-model="staff.nationality"
                           class="custom-input"
                           placeholder="Filipino"
                           maxlength="50"
                           required
                           disabled />
                </div>
            </div>
            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Address <span class="required-mark">*</span></p>
                    <input id="staffAddress"
                           ng-model="staff.address"
                           type="text"
                           class="custom-input"
                           maxlength="250"
                           required
                           disabled />
                </div>
            </div>

            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Clinic Role</p>
                    <input disabled type="text" ng-model="staff.staffRole" class="custom-input" maxlength="50" />
                </div>
            </div>
            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Branch</p>
                    <select disabled class="browser-default custom-input" ng-model="staff.branchID" ng-options="b.branchID as b.description for b in branchArray">
                        <option value="" disabled selected>Select Branch</option>
                    </select>
                </div>
            </div>
        </form>
    </div>

    @*Submit or cancel*@
    <div class="modal-footer footer-center" style="margin-top:2.5vh">
        <button class="modal-close cancel-btn" style="font-weight:500; margin-right:.5vh">EXIT</button>
    </div>
</div>




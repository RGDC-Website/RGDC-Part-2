@{
    Layout = "~/Views/Shared/_adminLayout.cshtml";
}

<div class="dashContainer">
    @*top part (welcome, refresh, logout)*@
    <div class="row brown-text lighten-1" style="margin-top: 1rem">
        @*user name*@
        <div class="col m8 l8"  ng-init="getClinicStaff()"><h4 class="bold">Clinic Staff</h4></div>
        @*refresh and logout buttons*@
        <div class="col m4 l4">
            <span class="right hide-on-small-only">
                <div class="col valign-wrapper"><a href="#adminClinicStaffTab" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Refresh Dashboard"> <i class="material-icons brown-text lighten-1">refresh</i></a></div>
                <div class="col valign-wrapper" ng-click="logOut()"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Logout"> <i class="material-icons brown-text lighten-1">logout</i></a></div>
            </span>
        </div>
    </div>

    <div class="card grey lighten-2" style="margin-top:2vh;">
        <nav class="nav-extended grey lighten-2 z-depth-0">
            <div class="nav-content p-1">
                <ul class="tabs tabs-transparent center-tabs">
                    <li class="tab px-1"><a class="brown-text p-0" href="#Owner">Owner</a></li>
                    <li class="tab px-1"><a class="brown-text p-0" href="#Dentist">Dentist</a></li>
                    <li class="tab px-1"><a class="brown-text p-0" href="#Staff">Staff</a></li>
                    <li class="tab px-1"><a class="brown-text p-0" href="#Pending">Pending</a></li>
                </ul>
            </div>
        </nav>

        <div class="card-content">

            <div id="Owner" class="containerOverflow-2 row m-0" n>
                <div class="row m-0">
                    <div class="col s12 m6 l6 valign-wrapper p-0">
                        <p class="bold brown-text lighten-1" style="font-size:1.8rem;">Owner</p>
                        <select class=" browser-default" style="width: 30%; margin-left: 1rem">
                            <option value="text" selected>text</option>
                        </select>
                    </div>
                    <div class="col s12 m6 l6">
                        <a class="edit-btn modal-trigger right white-text" style="margin-top:0.3rem !important" data-target="ownerInformationFormAdd">
                            <i class="material-icons left white-text">group_add</i>Add Owner
                        </a>
                    </div>
                </div>
                @*Owner Table*@
                <table id="adminClinicStaffTabTableOwner" class="hover tableClk">
                    <thead>
                        <tr class="brown-text lighten-1">
                            <th>Name</th>
                            <th colspan="2">Specialization</th>
                        </tr>
                    </thead>
                    @*table content*@
                    <tbody>
                        <tr data-href="#"  ng-repeat="owner in clinicOwners track by owner.ownerID">
                            <td>{{owner.fullName}}</td>
                            <td>{{owner.specialization}}</td>
                            <td>
                                <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 redBtn modal-trigger" data-target="modalDeleteOwner" title="Archive Account"><i class="material-icons brown-text lighten-1" ng-click="selectDeleteOwner(owner.ownerID, owner.accID)">archive</i></a>
                                <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 modal-trigger" data-target="ownerInformationFormEdit" title="View Account Details" style="margin-right: 0.5rem !important" ng-click="editSelectOwner(owner.ownerID)"><i class="material-icons brown-text lighten-1">visibility</i></a>
                            </td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr class="brown-text lighten-1">
                            <th>Dentist Name</th>
                            <th colspan="2">Specialization</th>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div id="Dentist" class="containerOverflow-2 row m-0">
                <div class="row m-0">
                    <div class="col s12 m6 l6 valign-wrapper p-0">
                        <p class="bold brown-text lighten-1" style="font-size:1.8rem;">Dentist</p>
                        <select class=" browser-default" style="width: 30%; margin-left: 1rem">
                            <option value="text" selected>text</option>
                        </select>
                    </div>
                    <div class="col s12 m6 l6">
                        <a class="edit-btn modal-trigger right white-text" style="margin-top:0.3rem !important" data-target="dentistInformationFormAdd">
                            <i class="material-icons left white-text">group_add</i>Add Dentist
                        </a>
                    </div>
                </div>
                @*Dentist Table*@
                <table id="adminClinicStaffTabTableDentist" class="hover tableClk">
                    <thead>
                        <tr class="brown-text lighten-1">
                            <th>Name</th>
                            <th>Specialization</th>
                            <th colspan="2">Branch</th>
                        </tr>
                    </thead>
                    @*table content*@
                    <tbody>
                        <tr data-href="#" ng-repeat="dentist in clinicDentists track by dentist.dentistID">
                            <td>{{dentist.fullName}}</td>
                            <td>{{dentist.specialization}}</td>
                            <td>{{dentist.description}}</td>
                            <td>
                                <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 redBtn modal-trigger" data-target="modalDeleteDentist" title="Archive Account"><i class="material-icons brown-text lighten-1" ng-click="selectDeleteDentist(dentist.dentistID, dentist.accID)">archive</i></a>
                                <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 modal-trigger" data-target="dentistInformationFormEdit" title="View Account Details" style="margin-right: 0.5rem !important"><i class="material-icons brown-text lighten-1" ng-click="editSelectDentist(dentist.dentistID)">visibility</i></a>
                            </td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr class="brown-text lighten-1">
                            <th>Name</th>
                            <th>Specialization</th>
                            <th>Branch</th>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div id="Staff" class="containerOverflow-2 row m-0">
                <div class="row m-0">
                    <div class="col s12 m6 l6 valign-wrapper p-0">
                        <p class="bold brown-text lighten-1" style="font-size:1.8rem;">Staff</p>
                        <select class=" browser-default" style="width: 30%; margin-left: 1rem">
                            <option value="text" selected>text</option>
                        </select>
                    </div>
                    <div class="col s12 m6 l6">
                        <a class="edit-btn modal-trigger right white-text" style="margin-top:0.3rem !important" data-target="staffInformationFormAdd">
                            <i class="material-icons left white-text">group_add</i>Add Staff
                        </a>
                    </div>
                </div>
                @*Staff Table*@
                <table id="adminClinicStaffTabTableStaff" class="hover tableClk">
                    <thead>
                        <tr class="brown-text lighten-1">
                            <th>Name</th>
                            <th>Role</th>
                            <th colspan="2">Branch</th>
                        </tr>
                    </thead>
                    @*table content*@
                    <tbody>
                        <tr data-href="#" ng-repeat="staff in clinicStaff track by staff.staffID">
                            <td>{{staff.fullName}}</td>
                            <td>{{staff.staffRole}}</td>
                            <td>{{staff.description}}</td>
                            <td>
                                <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 redBtn modal-trigger" data-target="modalDeleteStaff" title="Archive Account"><i class="material-icons brown-text lighten-1" ng-click="selectDeleteStaff(staff.staffID, staff.accID)">archive</i></a>
                                <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 modal-trigger" data-target="staffInformationFormEdit" title="View Account Details" style="margin-right: 0.5rem !important"><i class="material-icons brown-text lighten-1" ng-click="editSelectStaff(staff.staffID)">visibility</i></a>
                            </td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr class="brown-text lighten-1">
                            <th>Name</th>
                            <th>Role</th>
                            <th>Branch</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
            
            @*pending*@
            <div id="Pending" class="containerOverflow-2 row m-0">
                <div class="row m-0">
                    <p class="bold brown-text lighten-1" style="font-size:1.8rem;">Pending</p>
                </div>
                @*pending Table*@
                <table id="adminClinicStaffTabTablePending" class="hover tableClk">
                    <thead>
                        <tr class="brown-text lighten-1">
                            <th>Email</th>
                            <th colspan="2">Role</th>
                        </tr>
                    </thead>
                    @*table content*@
                    <tbody>
                        <tr data-href="#">
                            <td>email@gmail.com</td>
                            <td>Role</td>
                            <td>
                                <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 redBtn modal-trigger" data-target="modalDeleteStaff" title="Delete Request"><i class="material-icons brown-text lighten-1" ng-click="selectDeleteStaff(staff.staffID, staff.accID)">delete</i></a>
                            </td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr class="brown-text lighten-1">
                            <th>Email</th>
                            <th colspan="2">Role</th>
                        </tr>
                    </tfoot>
                </table>
            </div>


        </div>
    </div>

</div>


@*ADD Owner Information Form*@
<div id="ownerInformationFormAdd" class="modal patientInformationForm-modal">
    <div>
        <h5 class="modal-form-title">Add New Owner</h5>

        @*Email*@
        <div class="row">
            <div class="col s12">
                <p class="custom-label">Email <span class="required-mark">*</span></p>
                <input type="text" class="custom-input"
                       ng-model="owner_email"
                       maxlength="150"
                       placeholder="juandlc@gmail.com"
                       ng-change="checkAddOwnerEmail()"
                       ng-focus="showOwnerEmailHint = true"
                       ng-class="{
                       'input-valid': ownerEmailFormatValid && !ownerEmailTaken,
                       'input-invalid': owner_email && !ownerEmailFormatValid
                   }"
                       required>
                <p class="helper-text" style="margin-top:.4rem;">
                    <span ng-show="owner_email"
                          ng-style="{'color': ownerEmailFormatValid ? '#2e7d32' : '#d32f2f'}">
                        {{ ownerEmailFormatValid ? 'Email is valid' : 'Enter a valid email address' }}
                    </span>
                    <span ng-show="ownerEmailFormatValid && ownerEmailTaken" style="color:#d32f2f; display:block; margin-top:.2rem;">
                        Email already taken
                    </span>
                </p>
            </div>
        </div>
    </div>


    @*Submit or cancel*@
        <div class="modal-footer" style="margin-top:2.5vh">
            <button class="modal-close cancel-btn left" style="font-weight: 500; margin-right: .5vh">CANCEL</button>
            <button type="submit"
                    class="edit-btn modal-close"
                    ng-click="addOwner()"
                    ng-disabled="!isAddOwnerFormValid()">
                ADD
            </button>
        </div>
</div>


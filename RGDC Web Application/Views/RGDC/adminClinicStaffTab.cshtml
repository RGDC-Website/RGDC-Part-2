@*View Owner Information Form*@
<div id="ownerInformationFormEdit" class="modal patientInformationForm-modal">

    <input id="ownerPhotoInput" type="file" accept="image/*" style="display:none"
           onchange="angular.element(this).scope().onPhotoSelected(this.files, 'owner')" />
    <div>
        <h5 class="modal-form-title">View Owner Profile</h5>

        <form>
            <div class="row">
                <div class="col s4">
                    @*Photo upload*@
                    <div class="row s4 center-align" style="margin-top: 2.5vh; margin-left: 2.5vh;">
                        <div class="col s12">
                            <div class="photo-box" style="cursor:pointer;">
                                <img ng-src="{{owner.photoLink}}" alt="Preview" style="width:100%; height:100%; object-fit:cover;" />   
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col s8">
                    <div class="row">
                        @*First name*@
                        <div class="col s6">
                            <p class="custom-label">First Name <span class="required-mark">*</span></p>
                            <input type="text"
                                   ng-model="owner.firstName"
                                   class="custom-input"
                                   maxlength="150"
                                   placeholder="Juan"
                                   required
                                   disabled />
                        </div>
                        @*MIddle name*@
                        <div class="col s6">
                            <p class="custom-label">Middle Name</p>
                            <input type="text"
                                   ng-model="owner.middleName"
                                   class="custom-input"
                                   maxlength="150"
                                   placeholder="Mercado"
                                   disabled />
                        </div>
                    </div>
                    <div class="row">
                        @*Last name*@
                        <div class="col s12">
                            <p class="custom-label">Last Name <span class="required-mark">*</span></p>
                            <input type="text"
                                   ng-model="owner.lastName"
                                   class="custom-input"
                                   maxlength="150"
                                   placeholder="Dela Cruz"
                                   required
                                   disabled />
                        </div>
                    </div>
                </div>
            </div>

            @*Email*@
            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Email <span class="required-mark">*</span></p>
                    <input type="text" class="custom-input"
                           ng-model="owner.email"
                           maxlength="150"
                           placeholder="juandlc@gmail.com"
                           required
                           disabled />
                </div>
            </div>

            <div class="row">
                @*Gender*@
                <div class="col s3">
                    <p class="custom-label">Gender <span class="required-mark">*</span></p>
                    <select disabled class="browser-default custom-input" ng-model="owner.genderID" ng-options="g.genderID as g.description for g in genderArray" ng-change="/* optional */">
                        <option value="" disabled selected>Select Gender</option>
                    </select>
                </div>
                @*Birthdate*@
                <div class="col s3">
                    <p class="custom-label">Birth Date <span class="required-mark">*</span></p>
                    <div class="datepicker-wrapper">
                        <input id="owner_birthDate" ng-model="owner.birthDate" type="text" class="datepicker custom-input" readonly required disabled />
                    </div>
                </div>

                <div class="col s3">
                    @*Civil status*@
                    <p class="custom-label">Civil Status <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input" disabled required ng-model="owner.civilStatus">
                        <option value="" selected>Select Status</option>
                        <option value="1">Single</option>
                        <option value="2">Married</option>
                        <option value="3">Widowed</option>
                        <option value="4">Legally Separated</option>
                        <option value="5">Annulled/Void</option>
                        <option value="6">Divorced</option>
                    </select>
                </div>
                <div class="col s3">
                    @*Contact number*@
                    <p class="custom-label">Contact Number <span class="required-mark">*</span></p>
                    <input id="ownerContactNumber"
                           ng-model="owner.contactNumber"
                           type="text"
                           class="custom-input"
                           placeholder="09XXXXXXXXX"
                           maxlength="11"
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                           disabled
                           required />
                </div>
            </div>
            <div class="row">
                <div class="col s6">
                    @*Religion*@
                    <p class="custom-label">Religion <span class="required-mark">*</span></p>
                    <input id="religion"
                           type="text"
                           class="custom-input"
                           ng-model="owner.religion"
                           placeholder="Roman-Catholic"
                           maxlength="50"
                           required
                           disabled />
                </div>

                <div class="col s6">
                    @*Nationality*@
                    <p class="custom-label">Nationality <span class="required-mark">*</span></p>
                    <input id="contactNumber"
                           type="text"
                           ng-model="owner.nationality"
                           class="custom-input"
                           placeholder="Filipino"
                           maxlength="50"
                           required
                           disabled />
                </div>
            </div>
            <div class="row">
                <div class="col s12">
                    @*Address*@
                    <p class="custom-label">Address <span class="required-mark">*</span></p>
                    <input id="ownerAddress"
                           ng-model="owner.address"
                           type="text"
                           class="custom-input"
                           maxlength="250"
                           required
                           disabled />
                </div>
            </div>

            <div class="row">
                @*Specialization*@
                <div class="col s12">
                    <p class="custom-label">Specialization</p>
                    <input type="text" ng-model="owner.specialization" class="custom-input" maxlength="50" disabled/>
                    
                </div>
            </div>
        </form>
    </div>

    @*Submit or cancel*@
    <div class="modal-footer footer-center" style="margin-top:2.5vh">
        <button class="modal-close cancel-btn" style="font-weight:500; margin-right:.5vh">EXIT</button>
    </div>
</div>


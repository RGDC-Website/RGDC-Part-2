@{
    Layout = "~/Views/Shared/_adminLayout.cshtml";
}

<div class="dashContainer">
    @*top part (welcome, refresh, logout)*@
    <div class="row brown-text lighten-1" style="margin-top: 1rem">
        @*user name*@
        <div class="col m8 l8" ng-init="getClinicStaff()"><h4 class="bold">Clinic Staff</h4></div>
        @*refresh and logout buttons*@
        <div class="col m4 l4">
            <span class="right hide-on-small-only">
                <div class="col valign-wrapper" ng-click="logOut()"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Logout"> <i class="material-icons brown-text lighten-1">logout</i></a></div>
            </span>
        </div>
    </div>

    <div class="card grey lighten-2" style="margin-top:2vh;">
        <nav class="nav-extended grey lighten-2 z-depth-0">
            <div class="nav-content p-1">
                <ul class="tabs tabs-transparent center-tabs">
                    <li class="tab px-1"><a class="brown-text p-0" href="#Staff">Staff</a></li>
                    <li class="tab px-1"><a class="brown-text p-0" href="#Dentist">Dentist</a></li>
                    <li class="tab px-1"><a class="brown-text p-0" href="#Owner" ng-show="isUserSAdmin">Owner</a></li>
                    <li class="tab px-1"><a class="brown-text p-0" href="#Pending">Pending</a></li>
                </ul>
            </div>
        </nav>

        <div class="card-content">
            <div id="Staff" class="containerOverflow-2 row m-0">
                <div class="row m-0 hide-on-small-only">
                    <div class="col s12 m6 l6 valign-wrapper p-0">
                        <p class="bold brown-text lighten-1" style="font-size:1.8rem;">Staff</p>
                        @*<select class=" browser-default" style="width: 30%; margin-left: 1rem">
                                <option value="Active" selected>Active</option>
                                <option value="Inactive" selected>Inactive</option>
                            </select>*@
                    </div>
                    <div class="col s12 m6 l6">
                        <a class="btn brown lighten-1 modal-trigger right white-text" style="margin-top:0.3rem !important" data-target="staffInformationFormAdd">
                            <i class="material-icons left white-text">group_add</i>Add Staff
                        </a>
                    </div>
                </div>
                @*mobile responsive header and button*@
                <div class="row m-0 show-on-small clinicStaff-HeaderBtn">
                    <div class="col s12 m6 l6 mobileRes-headerBtn p-0">
                        <p class="bold brown-text lighten-1" style="font-size:1.8rem;">Staff</p>
                        <a class="btn brown lighten-1 modal-trigger white-text" style="margin-bottom: -1rem !important" data-target="staffInformationFormAdd">
                            <i class="material-icons left white-text">group_add</i>Add Staff
                        </a>
                    </div>
                </div>

                <a class="btn brown lighten-1 waves-light waves-effect white-text staff-inactive-active-btn" ng-show="!showStaffArchived" ng-click="toggleStaffArchive()"><i class="material-icons left">archive</i>Show Inactive</a>
                <a class="btn brown lighten-1 waves-light waves-effect white-text staff-inactive-active-btn" ng-show="showStaffArchived" ng-click="toggleStaffArchiveF()"><i class="material-icons left">archive</i>Show Active</a>
                @*Staff Table*@
                <div ng-show="!showStaffArchived">
                    <table id="adminClinicStaffTabTableStaff" class="hover tableClk">
                        <thead>
                            <tr class="brown-text lighten-1">
                                <th>Name</th>
                                <th>Role</th>
                                <th colspan="2">Branch</th>
                            </tr>
                        </thead>
                        @*table content*@
                        <tbody>
                            <tr data-href="#" ng-repeat="staff in clinicStaff track by staff.staffID" on-finish-render table-id="adminClinicStaffTabTableStaff">
                                <td>{{staff.fullName}}</td>
                                <td>{{staff.staffRole}}</td>
                                <td>{{staff.description}}</td>
                                <td>
                                    <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 redBtn modal-trigger" data-target="modalDeactivateStaff" title="Deactivate Account"><i class="material-icons brown-text lighten-1" ng-click="selectArchiveStaff(staff.accID)">archive</i></a>
                                    <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 modal-trigger responsive-btn-roundedSquare" data-target="staffInformationFormEdit" title="View Account Details"><i class="material-icons brown-text lighten-1" ng-click="selectStaff(staff.staffID)">visibility</i></a>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr class="brown-text lighten-1">
                                <th>Name</th>
                                <th>Role</th>
                                <th>Branch</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div ng-show="showStaffArchived">
                    <table id="adminClinicStaffTabTableStaffD" class="hover tableClk">
                        <thead>
                            <tr class="brown-text lighten-1">
                                <th>Name</th>
                                <th>Role</th>
                                <th colspan="2">Branch</th>
                            </tr>
                        </thead>
                        @*table content*@
                        <tbody>
                            <tr data-href="#" ng-repeat="staff in clinicStaffD track by staff.staffID" on-finish-render table-id="adminClinicStaffTabTableStaffD">
                                <td>{{staff.fullName}}</td>
                                <td>{{staff.staffRole}}</td>
                                <td>{{staff.description}}</td>
                                <td>
                                    <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 redBtn modal-trigger" data-target="modalActivateStaff" title="Activate Account"><i class="material-icons brown-text lighten-1" ng-click="selectArchiveStaff(staff.accID)">archive</i></a>
                                    <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 modal-trigger responsive-btn-roundedSquare" data-target="staffInformationFormEdit" title="View Account Details"><i class="material-icons brown-text lighten-1" ng-click="selectStaff(staff.staffID)">visibility</i></a>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr class="brown-text lighten-1">
                                <th>Name</th>
                                <th>Role</th>
                                <th>Branch</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div id="Dentist" class="containerOverflow-2 row m-0">
                    <div class="row m-0 hide-on-small-only">
                        <div class="col s12 m6 l6 valign-wrapper p-0">
                            <p class="bold brown-text lighten-1" style="font-size:1.8rem;">Dentist</p>
                        </div>
                        <div class="col s12 m6 l6">
                            <a class="btn brown lighten-1 modal-trigger right white-text" style="margin-top:0.3rem !important" data-target="dentistInformationFormAdd">
                                <i class="material-icons left white-text">group_add</i>Add Dentist
                            </a>
                        </div>
                    </div>
                    @*mobile responsive header and button*@
                    <div class="row m-0 show-on-small clinicStaff-HeaderBtn">
                        <div class="col s12 m6 l6 mobileRes-headerBtn p-0">
                            <p class="bold brown-text lighten-1" style="font-size:1.8rem;">Dentist</p>

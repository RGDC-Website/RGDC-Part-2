@{
    Layout = "~/Views/Shared/_adminLayout.cshtml";
}

<div class="dashContainer" ng-init="initPatientDashboard()">
    @*top part (welcome, refresh, logout)*@
    <div class="row brown-text lighten-1" style="margin-top: 1rem">
        @*user name*@
        <div class="col m8 l8" ng-show="currentUserName"><h4>Welcome, {{currentUserName}}</h4></div>
        @*refresh and logout buttons*@
        <div class="col m4 l4">
            <span class="right">
                <div class="col valign-wrapper"><a href="#" ng-click="loadRequestedAppointments()" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Refresh Dashboard"> <i class="material-icons brown-text lighten-1">refresh</i></a></div>
                <div class="col valign-wrapper"><a href="#" ng-click="logOut()" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Logout"> <i class="material-icons brown-text lighten-1">logout</i></a></div>
            </span>
        </div>

@* Reuse Add Appointment modal from adminAppointment *@
<div id="modal-add-appt" class="modal modal-fixed-footer add-appt-modal">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Add New Appointment</h5>

        <div class="row">
            <div class="col s6">
                @*Date*@
                <label class="custom-label">
                    Date
                    <input type="date" class="custom-input" ng-model="newApptRequest.dateTime" placeholder="MM/DD/YYYY" min="{{minApptDate}}">
                </label>

                @*Dentist Selection*@
                <label class="custom-label">
                    Dentist
                    <select class="custom-input" ng-model="newApptRequest.dentistID">
                        <option value="">Select Dentist</option>
                        <option ng-repeat="dentist in dentistArray" value="{{dentist.dentistID}}">{{dentist.dentistName}}</option>
                    </select>
                </label>
            </div>

            <div class="col s6">
                @*Time*@
                <label class="custom-label">
                    Time
                    <select class="custom-input" ng-model="newApptRequest.time">
                        <option value="">Select Time</option>
                        <option value="12:00 AM">12:00 AM</option>
                        <option value="1:00 AM">1:00 AM</option>
                        <option value="2:00 AM">2:00 AM</option>
                        <option value="3:00 AM">3:00 AM</option>
                        <option value="4:00 AM">4:00 AM</option>
                        <option value="5:00 AM">5:00 AM</option>
                        <option value="6:00 AM">6:00 AM</option>
                        <option value="7:00 AM">7:00 AM</option>
                        <option value="8:00 AM">8:00 AM</option>
                        <option value="9:00 AM">9:00 AM</option>
                        <option value="10:00 AM">10:00 AM</option>
                        <option value="11:00 AM">11:00 AM</option>
                        <option value="12:00 PM">12:00 PM</option>
                        <option value="1:00 PM">1:00 PM</option>
                        <option value="2:00 PM">2:00 PM</option>
                        <option value="3:00 PM">3:00 PM</option>
                        <option value="4:00 PM">4:00 PM</option>
                        <option value="5:00 PM">5:00 PM</option>
                        <option value="6:00 PM">6:00 PM</option>
                        <option value="7:00 PM">7:00 PM</option>
                        <option value="8:00 PM">8:00 PM</option>
                        <option value="9:00 PM">9:00 PM</option>
                        <option value="10:00 PM">10:00 PM</option>
                        <option value="11:00 PM">11:00 PM</option>
                    </select>
                </label>

                @*Patient Selection (current user) *@
                <label class="custom-label">
                    Patient
                    <input type="text" class="custom-input" value="{{currentUserFullName}}" readonly>
                </label>
            </div>

            <div class="col s12">
                @*Purpose*@
                <label class="custom-label">
                    Purpose
                    <input type="text" class="custom-input" ng-model="newApptRequest.reason" placeholder="Purpose">
                </label>
            </div>

        </div>
    </div>

    <div class="modal-footer footer-center">
        <button class="modal-close cancel-btn" style="font-weight:500;">CANCEL</button>
        <button type="submit" class="edit-btn" ng-click="createNewAppointmentRequest()" style="font-weight:500; margin-right:20px">ADD</button>
    </div>
</div>

    @* top controls *@
    </div>

    @*appointments*@
    <div class="row m-0" style="margin-bottom:1rem">
        <a class="waves-effect waves-light btn left brown lighten-4 medBtn modal-trigger" data-target="modal-add-appt"><i class="material-icons left">add</i>Create New Appointment</a>
    </div>

    <div class="row" style="padding: 0 1rem 0 1rem">

        @*appointment req*@
        <div class="col m6 l6" style="padding-left:0">
            <span class="bold brown-text lighten-1" style="margin-bottom: 0">APPOINTMENT REQUESTS <span class="badge left" style="margin:0 0.25rem 0 0">{{$root.requestedAppointments.length}}</span></span>
            <div class="card grey lighten-2">
                <div class="card-content containerOverflow appointments-render">
                    <div ng-if="$root.requestedAppointments.length === 0" class="card white z-depth-0">
                        <div class="card-content brown-text lighten-1 center-align" style="padding: 2rem 1rem">
                            <p>No appointment requests at this time</p>
                        </div>
                    </div>

                    <div ng-repeat="appt in $root.requestedAppointments track by appt.apptID" style="padding:12px; border-bottom:1px solid #e0e0e0; background:#fff; margin-bottom:8px">
                        <div style="display:flex; align-items:center; justify-content:space-between">
                            <div>
                                <div style="font-weight:600">{{appt.dentistName}} <span style="color:#2e7d32; font-weight:400; margin-left:6px">{{appt.displayStatus || appt.status}}</span></div>
                                <div style="font-size:0.9rem; color:#555">{{appt.purpose}}</div>
                                <div style="font-size:0.85rem; color:#777">{{appt.date}} • {{appt.time}}</div>
                            </div>
                            <div style="min-width:56px; text-align:center; display:flex; flex-direction:column; align-items:center; justify-content:center">
                                <a href="#" class="btn-floating btn-small waves-effect waves-light brown lighten-1 tooltipped" ng-click="acceptRequestedAppointment({ apptID: appt.apptID })" data-position="right" data-tooltip="Confirm" style="margin-bottom:6px">
                                    <i class="material-icons tiny">check</i>
                                </a>
                                <a href="#" class="btn-floating btn-small waves-effect waves-light brown lighten-1 tooltipped" ng-click="denyRequestedAppointment({ apptID: appt.apptID })" data-position="right" data-tooltip="Deny">
                                    <i class="material-icons tiny">close</i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        @*appointment sched*@
        <div class="col m6 l6" style="padding-right: 0">
            <span class="bold brown-text lighten-1" style="margin-bottom: 0">APPOINTMENT SCHEDULED <span class="badge left p-0" style="margin:0">{{$root.adminAppointments.length || 0}}</span></span>
            <div class="card grey lighten-2">
                <div class="card-content containerOverflow">
                    <div ng-if="!$root.adminAppointments || $root.adminAppointments.length === 0" class="card white z-depth-0">
                        <div class="card-content brown-text lighten-1 center-align" style="padding: 2rem 1rem">
                            <p>No scheduled appointments at this time</p>
                        </div>
                    </div>
                    <div ng-repeat="s in $root.adminAppointments track by s.apptID" class="card white z-depth-0" style="margin-bottom:8px;">
                        <div class="card-content brown-text lighten-1" style="padding: 0.75rem">
                            <div style="display:flex; justify-content:space-between; align-items:center">
                                <div>
                                    <div style="font-weight:600">{{s.dentistName}}</div>
                                    <div style="font-size:0.9rem; color:#555">{{s.purpose}}</div>
                                    <div style="font-size:0.85rem; color:#777">{{s.date}} • {{s.time}}</div>
                                </div>
                                <div style="text-align:right">
                                    <div style="font-size:0.9rem">{{s.patientName}}</div>
                                    <div style="font-size:0.85rem; color:#2e7d32">{{s.displayStatus || s.status}}</div>
                                    <div style="margin-top:8px">
                                        <button class="waves-effect waves-light btn-small brown lighten-4" ng-click="cancelAppointment(s)">Cancel</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @*<div class="footer">
        <p>Footer content goes here</p>
    </div>*@

</div>


@{
    Layout = "~/Views/Shared/_adminLayout.cshtml";
}

<div class="dashContainer">
    @*top part (title, refresh, logout)*@
    <div class="row brown-text lighten-1" style="margin-top: 1rem">
        @*user name*@
        <div class="col m8 l8"><h4 class="bold">Patients</h4></div>
        @*refresh and logout buttons*@
        <div class="col hide-on-med-and-down l4">
            <span class="right">
                <div class="col valign-wrapper" ng-click="logOut()"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Logout"> <i class="material-icons brown-text lighten-1">logout</i></a></div>
            </span>
        </div>
    </div>

    <div class="row m-0 ">
        <a class="btn brown lighten-1 waves-effect waves-light modal-trigger left white-text"
           style="margin-bottom:1.8vh"
           ng-show="!showActivePatients"
           ng-click="toggleShowActivePatients()">
            <i class="material-icons left">group_add</i>SHOW ACTIVE
        </a>
    </div>
    <div class="row m-0 ">
        <a class="btn brown lighten-1 waves-effect waves-light modal-trigger left white-text"
           style="margin-bottom:1.8vh"
           ng-show="showActivePatients"
           ng-click="toggleShowActivePatientsF()">
            <i class="material-icons left">group_add</i>SHOW INACTIVE
        </a>
    </div>


    @*patients*@
    <div  ng-show="showActivePatients">
        <table id="adminPatientsTabTable" class="hover tableClk" ng-init="getPatients()">
            <thead>
                <tr class="brown-text lighten-1">
                    <th>Patient Name</th>
                    <th>Last Visit</th>
                    <th>Appointments Scheduled</th>

                </tr>
            </thead>
            @*table content*@
            <tbody>
                <tr data-href="#" title="View patient record"
                    class="clkPointer"
                    table-id="adminPatientsTabTable"
                    ng-repeat="patient in patientArrayData"
                    ng-click="goToPatientInfo(patient)"
                    on-finish-render>
                    <td>{{patient.patientName}}</td>
                    <td>{{patient.lastVisitDisplay}}</td>
                    <td>{{patient.appointmentsScheduled || '0'}} Appointment{{patient.appointmentsScheduled == 1 ? '' : 's'}} Scheduled</td>
                </tr>
            </tbody>
            <tfoot>
                <tr class="brown-text lighten-1">
                    <th>Patient Name</th>
                    <th>Last Visit</th>
                    <th>Appointments Scheduled</th>
                </tr>
            </tfoot>
        </table>
    </div>
    <div  ng-show="!showActivePatients">
        <table id="adminPatientsTabTableDeact" class="hover tableClk">
            <thead>
                <tr class="brown-text lighten-1">
                    <th>Patient Name</th>
                    <th>Last Visit</th>
                    <th>Appointments Scheduled</th>

                </tr>
            </thead>
            @*table content*@
            <tbody>
                <tr data-href="#" title="View patient record" class="clkPointer" ng-repeat="patient in patientArrayDataDeact" ng-click="goToPatientInfo(patient)" on-finish-render table-id="adminPatientsTabTableDeact">
                    <td>{{patient.patientName}}</td>
                    <td>{{patient.lastVisitDisplay}}</td>
                    <td>{{patient.appointmentsScheduled || '0'}} Appointment{{patient.appointmentsScheduled == 1 ? '' : 's'}} Scheduled</td>
                </tr>
            </tbody>
            <tfoot>
                <tr class="brown-text lighten-1">
                    <th>Patient Name</th>
                    <th>Last Visit</th>
                    <th>Appointments Scheduled</th>
                </tr>
            </tfoot>
        </table>
    </div>

</div>


@*Patient information form*@
<div id="patientInformationFormAdd" class="modal patientInformationForm-modal">
    <div>
        <h5 class="modal-form-title">Add Patient</h5>

        <form>
            <input id="addPatient_photo_input" type="file" accept="image/*" style="display:none"
                   onchange="angular.element(this).scope().onAddPatientPhotoSelected(this.files)" />
            <div class="row">

                <div class="col s4">
                    @*Photo upload*@
                    <div class="row s4 center-align" style="margin-top: 2.5vh; margin-left: 2.5vh;">
                        <div class="col s12">
                            <div class="photo-box">
                                <img ng-if="addPatientPhotoPreview" ng-src="{{addPatientPhotoPreview}}" alt="Profile" />
                                <i class="material-icons photo-placeholder-icon" ng-if="!addPatientPhotoPreview">image</i>
                            </div>
                            <input type="file"
                                   id="signUpPhotoInput"
                                   accept="image/*"
                                   style="display:none"
                                   onchange="angular.element(this).scope().onSignUpPhotoSelected(this.files)" />
                        </div>
                    </div>
                </div>

                <div class="col s8">
                    <div class="row">
                        @*First name*@
                        <div class="col s6">
                            <p class="custom-label">First Name <span class="required-mark">*</span></p>
                            <input type="text"
                                   class="custom-input"
                                   ng-model="addPatient_firstName"
                                   maxlength="150"
                                   oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')"
                                   placeholder="Juan"
                                   required>
                        </div>
                        @*MIddle name*@
                        <div class="col s6">
                            <p class="custom-label">Middle Name</p>
                            <input type="text"
                                   class="custom-input"
                                   ng-model="addPatient_middleName"
                                   maxlength="150"
                                   oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')"
                                   placeholder="Mercado"
                                   required>
                        </div>
                    </div>
                    <div class="row">
                        @*Last name*@
                        <div class="col s12">
                            <p class="custom-label">Last Name <span class="required-mark">*</span></p>
                            <input type="text" class="custom-input"
                                   ng-model="addPatient_lastName"
                                   maxlength="150"
                                   oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')"
                                   placeholder="Dela Cruz"
                                   required>
                        </div>
                    </div>
                </div>
            </div>

            @*Email*@
            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Email <span class="required-mark">*</span></p>

                    <input class="custom-input"
                           ng-focus="active='addEmail'"
                           ng-blur="active=''"
                           ng-model="addPatient_email"
                           type="text"
                           maxlength="150"
                           ng-change="checkAddPatientEmail()"
                           ng-class="{
                      'input-valid': isAddPatientEmailValid(),
                      'input-invalid': addPatient_email && !isAddPatientEmailValid()
                   }"
                           required>

                    <span class="helper-text" style="color:#d32f2f"
                          ng-show="addPatient_email && !addPatientEmailValid">
                        Enter a valid email address
                    </span>
                    <span class="helper-text" style="color:#d32f2f"
                          ng-show="addPatient_email && addPatientEmailValid && addPatientEmailTaken">
                        Email already taken
                    </span>
                    <span class="helper-text" style="color:#388e3c"
                          ng-show="addPatient_email && addPatientEmailValid && !addPatientEmailTaken">
                        Email is valid
                    </span>
                </div>
            </div>

            <div class="row">
                @*Gender*@
                <div class="col s3">
                    <p class="custom-label">Gender <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input" ng-model="addPatient_genderID" required>
                        <option value="" disabled selected>Select Gender</option>
                        <option ng-repeat="gender in genderArray" value="{{gender.genderID}}">{{gender.description}}</option>
                    </select>
                </div>
                @*Birthdate*@
                <div class="col s3">
                    <p class="custom-label">Birth Date <span class="required-mark">*</span></p>
                    <div class="datepicker-wrapper">
                        <input id="birthDate"
                               ng-model="addPatient_birthDate"
                               type="text"
                               class="datepicker custom-input"
                               readonly
                               required>
                        <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                    </div>
                </div>

                <div class="col s3">
                    @*Civil status*@
                    <p class="custom-label">Civil Status <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input" ng-model="addPatient_civilStatus" required>
                        <option value="" disabled selected>Select Status</option>
                        <option value="1">Single</option>
                        <option value="2">Married</option>
                        <option value="3">Widowed</option>
                        <option value="4">Legally Separated</option>
                        <option value="5">Annulled/Void</option>
                        <option value="6">Divorced</option>
                    </select>
                </div>
                <div class="col s3">
                    @*Contact number*@
                    <p class="custom-label">Contact Number <span class="required-mark">*</span></p>
                    <input ng-model="addPatient_contactNumber"
                           type="text"
                           class="custom-input"
                           maxlength="11"
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                           ng-change="checkAddPatientContact()"
                           ng-class="{
                          'input-valid': isAddPatientContactValid(),
                          'input-invalid': addPatient_contactNumber && !isAddPatientContactValid()
                       }"
                           required>
                </div>
            </div>

            <div class="row">
                <div class="col s6">
                    @*Address Line 1*@
                    <p class="custom-label">Address Line 1 <span class="required-mark">*</span></p>
                    <input id="address"
                           type="text"
                           ng-model="addPatient_line1"
                           class="custom-input"
                           maxlength="250"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')"
                           ng-class="{ 'input-valid': isAddressFieldValid(), 'input-invalid': signUp_address && !isAddressFieldValid() }"
                           placeholder="street address, p.o. box, company name, c/o"
                           required>
                </div>

                <div class="col s6">
                    @*Address Line 2*@
                    <p class="custom-label">Address Line 2 <span class="required-mark">*</span></p>
                    <input id="address"
                           type="text"
                           class="custom-input"
                           ng-model="addPatient_line2"
                           maxlength="250"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')"
                           placeholder="appartment, suite, unit, building, floor, etc"
                           required>
                </div>
            </div>

            <div class="row">
                <div class="col s3">
                    @*City*@
                    <p class="custom-label">City <span class="required-mark">*</span></p>
                    <input id="address"
                           type="text"
                           ng-model="addPatient_city"
                           class="custom-input"
                           maxlength="250"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')"
                           placeholder="city"
                           required>
                </div>

                <div class="col s3">
                    @*state/province/region*@
                    <p class="custom-label">State/Province/Region <span class="required-mark">*</span></p>
                    <input id="address"
                           type="text"
                           class="custom-input"
                           ng-model="addPatient_state"
                           maxlength="250"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')"
                           placeholder="state/province/region"
                           required>
                </div>

                <div class="col s3">
                    @*zip/postal code*@
                    <p class="custom-label">Zip/Postal Code <span class="required-mark">*</span></p>
                    <input id="address"
                           type="text"
                           class="custom-input"
                           ng-model="addPatient_postal"
                           maxlength="250"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')"
                           placeholder="zip/postal code"
                           required>
                </div>

                <div class="col s3">
                    @*country*@
                    <p class="custom-label">Country <span class="required-mark">*</span></p>
                    <input id="address"
                           type="text"
                           ng-model="addPatient_country"
                           class="custom-input"
                           maxlength="250"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')"
                           placeholder="country"
                           required>
                </div>
            </div>

            <div class="row">
                <div class="col s4">
                    @*Occupation*@
                    <p class="custom-label">Occupation <span class="required-mark">*</span></p>
                    <input id="occupation"
                           type="text"
                           class="custom-input"
                           placeholder="Doctor"
                           maxlength="50"
                           required>
                </div>

                <div class="col s4">
                    @*Religion*@
                    <p class="custom-label">Religion <span class="required-mark">*</span></p>
                    <input id="religion"
                           type="text"
                           class="custom-input"
                           placeholder="Roman-Catholic"
                           maxlength="50"
                           required>
                </div>

                <div class="col s4">
                    @*Nationality*@
                    <p class="custom-label">Nationality <span class="required-mark">*</span></p>
                    <input id="contactNumber"
                           type="text"
                           class="custom-input"
                           placeholder="Filipino"
                           maxlength="50"
                           required>
                </div>
            </div>

            <div class="row">
                @*Current physician*@
                <div class="col s4">
                    <p class="custom-label">Current Physician <span class="required-mark">*</span></p>
                    <input type="text"
                           ng-model="addPatient_currentPhysician"
                           class="custom-input"
                           maxlength="150"
                           oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')"
                           ng-class="{ 'input-valid': isCurrentPhysicianValid(), 'input-invalid': signUp_currentPhysician && !isCurrentPhysicianValid() }">
                </div>
                @*Refferal*@
                <div class="col s4">
                    <p class="custom-label">Referral (if any)</p>
                    <input type="text"
                           ng-model="addPatient_referral"
                           class="custom-input"
                           maxlength="50"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')">
                </div>
                @*Last visit*@
                <div class="col s4">
                    <p class="custom-label">Last Visit <span class="required-mark">*</span></p>
                    <div class="datepicker-wrapper">
                        <input ng-model="addPatient_lastVisit"
                               type="text"
                               class="datepicker custom-input"
                               readonly
                               ng-class="{
                              'input-valid': addPatient_lastVisit,
                              'input-invalid': addPatient_lastVisit === ''}"
                               required>
                        <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                    </div>
                </div>

            </div>
        </form>
    </div>


    @*Submit , upload, cancel*@
    <div class="modal-footer" style="margin-top:2.5vh">
        <button type="button" class="edit-btn left" style="font-weight:500; margin-right:1vh;" ng-click="triggerAddPatientPhotoInput()">UPLOAD PHOTO</button>
        <button class="modal-close cancel-btn" style="font-weight: 500; margin-right: .5vh">CANCEL</button>
        <button type="submit"
                class="edit-btn modal-close"
                ng-click="addPatient()"
                ng-disabled="!isAddPatientFormValid()">
            ADD
        </button>
    </div>
</div>

@*DELETE Patient*@
<div id="modalDeletePatient" class="modal patientInformationForm-modal" style="width:30% !important; padding:0 !important">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Delete Patient Profile</h5>

        <p class="custom-label">Are you sure you want to delete this patient profile?</p>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0">DELETE</button>
    </div>
</div>

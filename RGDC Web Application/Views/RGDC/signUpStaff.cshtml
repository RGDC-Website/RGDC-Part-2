﻿@{
    Layout = "~/Views/Shared/_logInSignInLayout.cshtml";
}

<div class="split-container row">

    <div class="right-side col hide-on-med-and-down m6 l6" style="display: flex; flex-direction: column; justify-content: center; align-items: center;">

        <img src="@Url.Content("~/Content/images/dentalAppLogo.png")" alt="Logo" style="width: 500px; height: auto; margin-bottom: 30px;" />

    </div>

    <div class="right-side col s12 m6 l6" style="display: flex; flex-direction: column; justify-content: center; align-items: center;">
        <img class="hide-on-large-only" src="@Url.Content("~/Content/images/dentalAppLogo.png")" alt="Logo" style="width: 25rem; height: auto; margin-top: 30px" />

        <div style="width: 80%; max-width: 500px; text-align:center;">
            <h2 class="signup-title" ng-init="getBranch()">Staff Sign Up</h2>

            <form>

                @*Email*@
                <div class="input-field lbl-required">
                    <input id="email"
                           ng-focus="active='email'"
                           ng-blur="active = ''"
                           ng-model="signUp_email"
                           ng-init="checkAuthEmail()"
                           type="text"
                           placeholder="Email*"
                           maxlength="150"
                           oninput="this.value = this.value.replace(/^A-Za-z0-9 ._-/g, '')"
                           ng-change="checkEmail()"
                           ng-readonly="signUp_emailLocked"
                           ng-class="{ 'input-valid': isEmailFieldValid(), 'input-invalid': signUp_email && !isEmailFieldValid() }"
                           required>

                    <span class="helper-text" style="color: #d32f2f;" ng-show="!emailValid && signUp_email">
                        Enter a valid email address (e.g. "juandlc@gmail.com")
                    </span>
                    <span class="helper-text" style="color: #388e3c;" ng-show="emailValid">
                        Email is valid
                    </span>
                    <div style="text-align:left; margin-top:6px;" ng-show="(active=='email') && signUp_email">
                        <small>Email format checks:</small>
                        <ul style="list-style:none; padding-left:0; margin:4px 0 0 0; font-size:0.85rem; text-align:left;">
                            <li ng-class="{'requirement-complete': emailChecks.noSpace, 'requirement-pending': !emailChecks.noSpace}">No spaces</li>
                            <li ng-class="{'requirement-complete': emailChecks.hasAt, 'requirement-pending': !emailChecks.hasAt}">Contains "@@"</li>
                            <li ng-class="{'requirement-complete': emailChecks.hasDotAfterAt, 'requirement-pending': !emailChecks.hasDotAfterAt}">Contains . after "@@"</li>
                        </ul>
                    </div>
                </div>

                @* Password Field *@
                <div class="input-field">
                    <input id="password"
                           ng-focus="active='password'"
                           ng-blur="active = ''"
                           ng-model="signUp_password"
                           type="password"
                           placeholder="Password*"
                           maxlength="50"
                           ng-change="checkPasswordStrength()"
                           ng-class="{ 'input-valid': isPasswordFieldValid(), 'input-invalid': signUp_password && !isPasswordFieldValid() }"
                           required>

                    <span class="helper-text" ng-class="strengthColor" ng-show="passwordStrength">
                        Strength: <strong>{{ passwordStrength }}</strong>
                    </span>

                    <div class="password-requirements" ng-show="(active=='password') && signUp_password">
                        <small>Password must include:</small>
                        <ul style="list-style: none; padding-left: 0; text-align: left; margin: 5px 0;">
                            <li ng-class="{'requirement-complete': pwdChecks.length, 'requirement-pending': !pwdChecks.length}">• At least 8 characters</li>
                            <li ng-class="{'requirement-complete': pwdChecks.upper, 'requirement-pending': !pwdChecks.upper}">• One uppercase letter</li>
                            <li ng-class="{'requirement-complete': pwdChecks.lower, 'requirement-pending': !pwdChecks.lower}">• One lowercase letter</li>
                            <li ng-class="{'requirement-complete': pwdChecks.number, 'requirement-pending': !pwdChecks.number}">• One number</li>
                            <li ng-class="{'requirement-complete': pwdChecks.special, 'requirement-pending': !pwdChecks.special}">• One special character</li>
                        </ul>
                    </div>
                </div>

                @* Confirm Password Field *@
                <div class="input-field">
                    <input id="confPassword"
                           ng-focus="active='confPassword'"
                           ng-blur="active = ''"
                           ng-model="signUp_confPassword"
                           type="password"
                           placeholder="Confirm password*"
                           maxlength="50"
                           ng-class="{ 'input-valid': isConfirmFieldValid(), 'input-invalid': signUp_confPassword && !isConfirmFieldValid() }"
                           required>

                    <span class="helper-text" style="color: #d32f2f;" ng-show="!passwordsMatch && signUp_confPassword">
                        Passwords do not match
                    </span>
                    <span class="helper-text" style="color: #388e3c;" ng-show="passwordsMatch && signUp_confPassword">
                        Passwords matched
                    </span>
                </div>

                @*Code*@
                <div class="input-field lbl-required">
                    <input id="code"
                           type="text"
                           ng-model="signUp_code"
                           placeholder="Code*"
                           maxlength="6"
                           oninput="this.value = this.value.replace(/^A-Za-z0-9 ._-/g, '')"
                           required>
                </div>

                @*Already have an account*@
                <!--<div class="container" style="margin-top: -1vh; font-size: 0.95rem;">
                    <span>Already have an account?</span>
                    <a href="~/RGDC/logIn" class="signup-link" style="display:inline-block">Login</a>
                </div>-->

                @*Already have an account*@
                <div class="container" style="margin-top: -1vh; font-size: 0.95rem;">
                    <span>Already have an account?</span>
                    <a href="~/RGDC/logIn" class="signup-link" style="display:inline-block">Login</a>
                </div>

                @*Sign up as patient*@
                <div class="container" style="margin-top:.5vh; margin-bottom:.5vh; font-size: 0.95rem;">
                    <span>Need an appointment?</span>
                    <a href="~/RGDC/signUp" class="signup-link" style="display:inline-block">Patient Sign Up</a>
                </div>

                @*Sign up BTN*@
                <button class="logSignBtn"
                        data-target="modalInfoForm"
                        type="button"
                        ng-click="signUpStaffInitial()">
                    Sign Up
                </button>
            </form>
        </div>
    </div>
</div>

@*Information form*@
<div id="modalInfoForm" class="modal patientInformationForm-modal containerOverflow-2" style="max-height:95vh">
    <div>
        <h5 class="modal-form-title">{{whatStaffForm}} Information Form</h5>

        <form>
            <div class="row">
                <div class="col s12 m4 l4">
                    @*Photo upload*@
                    <div class="row s4 center-align" style="margin-top: 2.5vh; margin-left: 2.5vh;">
                        <div class="col s12">
                            <div class="photo-box">
                                <img ng-if="signupPhotoPreview || _uploadedSignUpPhotoPath" ng-src="{{ signupPhotoPreview || _uploadedSignUpPhotoPath }}" alt="Profile" />
                                <i class="material-icons photo-placeholder-icon" ng-if="!signupPhotoPreview && !_uploadedSignUpPhotoPath">image</i>
                            </div>
                            <input type="file"
                                   id="signUpPhotoInput"
                                   accept="image/*"
                                   style="display:none"
                                   onchange="angular.element(this).scope().onSignUpPhotoSelected(this.files)" />
                        </div>
                    </div>
                </div>

                <div class="col s12 m8 l8">
                    <div class="row">
                        @*First name*@
                        <div class="col s6">
                            <p class="custom-label">First Name <span class="required-mark">*</span></p>
                            <input type="text"
                                   class="custom-input"
                                   ng-model="signUp_firstName"
                                   maxlength="150"
                                   oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')"
                                   placeholder="Juan"
                                   required>
                        </div>
                        @*MIddle name*@
                        <div class="col s6">
                            <p class="custom-label">Middle Name</p>
                            <input type="text"
                                   class="custom-input"
                                   ng-model="signUp_middleName"
                                   maxlength="150"
                                   oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')"
                                   placeholder="Mercado"
                                   required>
                        </div>
                    </div>
                    <div class="row">
                        @*Last name*@
                        <div class="col s12">
                            <p class="custom-label">Last Name <span class="required-mark">*</span></p>
                            <input type="text" class="custom-input"
                                   ng-model="signUp_lastName"
                                   maxlength="150"
                                   oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')"
                                   placeholder="Dela Cruz"
                                   required>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                @*Gender*@
                <div class="col s12 m3 l3" ng-init="getGender()">
                    <p class="custom-label">Gender <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input" ng-model="signUp_genderID" required>
                        <option value="" disabled selected>Select Gender</option>
                        <option ng-repeat="gender in genderArray" value="{{gender.genderID}}">{{gender.description}}</option>
                    </select>
                </div>
                @*Birthdate*@
                <div class="col s12 m3 l3">
                    <p class="custom-label">Birth Date <span class="required-mark">*</span></p>
                    <div class="datepicker-wrapper">
                        <input id="birthDate"
                               ng-model="signUp_birthDate"
                               type="text"
                               class="datepicker custom-input"
                               readonly
                               required>
                        <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                    </div>
                </div>
                <div class="col s12 m3 l3">
                    @*Civil status*@
                    <p class="custom-label">Civil Status <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input" ng-model="signUp_civilStatus" required>
                        <option value="" disabled selected>Select Status</option>
                        <option value="1">Single</option>
                        <option value="2">Married</option>
                        <option value="3">Widowed</option>
                        <option value="4">Legally Separated</option>
                        <option value="5">Annulled/Void</option>
                        <option value="6">Divorced</option>
                    </select>
                </div>
                <div class="col s12 m3 l3">
                    @*Contact number*@
                    <p class="custom-label">Contact Number <span class="required-mark">*</span></p>
                    <input id="contactNumber"
                           ng-model="signUp_contactNumber"
                           type="text"
                           class="custom-input"
                           placeholder="09XX-XXX-XXXX"
                           maxlength="11"
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                           ng-class="{ 'input-valid': isContactFieldValid(), 'input-invalid': signUp_contactNumber && !isContactFieldValid() }"
                           required>
                </div>
            </div>

            <div class="row">
                <div class="col s12 m6 l6">
                    @*Religion*@
                    <p class="custom-label">Religion <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input">
                        <option disabled selected>Select your Religion</option>
                        <option value="Roman Catholic">Roman Catholic</option>
                        <option value="Islam">Islam</option>
                        <option value="Iglesia Ni Cristo">Iglesia Ni Cristo</option>
                        <option value="Others">Others</option>
                    </select>                
                     @*<input id="religion"
                           type="text"
                           class="custom-input"
                           ng-model="signUp_religion"
                           placeholder="Roman-Catholic"
                           maxlength="50"
                           required>*@
                </div>

                <div class="col s12 m6 l6">
                    @*Nationality*@
                    <p class="custom-label">Nationality <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input">
                        <option disbaled selected>Select your Nationality</option>
                        <option>Option 1</option>
                    </select>
                    @*<input id="contactNumber"
                           type="text"
                           ng-model="signUp_nationality"
                           class="custom-input"
                           placeholder="Filipino"
                           maxlength="50"
                           required>*@
                </div>
            </div>

            <div class="row">
                <div class="col s12">
                    @*Address*@
                    <p class="custom-label">Address <span class="required-mark">*</span></p>
                    <div class="row m-0">
                        <div class="col s12 m2 l2">
                            <input type="text" maxlength="250" placeholder="House No." class="custom-input" />
                        </div>
                        <div class="col s12 m5 l5">
                            <input type="text" maxlength="250" placeholder="Street" class="custom-input" />
                        </div>
                        <div class="col s12 m5 l5">
                            <input type="text" maxlength="250" placeholder="Baranggay" class="custom-input" />
                        </div>
                    </div>
                    <div class="row m-0">
                        <div class="col s12 m6 l6">
                            <input type="text" maxlength="250" placeholder="City/Municipality" class="custom-input" />
                        </div>
                        <div class="col s12 m6 l6">
                            <input type="text" maxlength="250" placeholder="Province" class="custom-input" />
                        </div>
                    </div>
                    @*<input id="address"
        type="text"
        ng-model="signUp_address"
        class="custom-input"
        maxlength="250"
        oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')"
        ng-class="{ 'input-valid': isAddressFieldValid(), 'input-invalid': signUp_address && !isAddressFieldValid() }"
        required>*@
                </div>
            </div>

            <div class="row" ng-show="signUpDentist || signUpOwner">
                @*Specialization*@
                <div class="col s12">
                    <p class="custom-label">Specialization <span class="required-mark">*</span></p>
                    <input type="text"
                           ng-model="signUp_specialization"
                           class="custom-input"
                           maxlength="50">
                </div>

                <div class="row" ng-show="signUpDentist">
                    <div class="col s12" style="margin-top: .5rem;">
                        <button type="button" class="btn-small edit-btn"
                                ng-click="openScheduleModal()">
                            Set Weekly Schedule
                        </button>
                        <span class="helper-text" style="margin-left:10px;">(Configure your weekly availability for appointments)</span>
                    </div>
                </div>
            </div>

            <div class="row" ng-show="signUpStaff">
                @*Clinic Role*@
                <div class="col s12">
                    <p class="custom-label">Clinic Role <span class="required-mark">*</span></p>
                    <input type="text"
                           ng-model="signUp_staffRole"
                           class="custom-input"
                           maxlength="50">
                </div>
            </div>

            <div class="row" ng-show="signUpDentist || signUpStaff">
                @*Branch*@
                <div class="col s12">
                    <p class="custom-label">Branch <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input" ng-model="signUp_branch" ng-options="b.branchID as b.description for b in branchArray">
                        <option value="" disabled selected>Select Branch</option>
                    </select>
                </div>
            </div>

            @*Agreementz*@
            <div class="row agreement-section center-align">
                <label class="agreement-label">
                    <input type="checkbox" class="filled-in" ng-model="signUp_agreement" required />
                    <span class="agreement-text">
                        I have read and agree to the
                        <a href="#" data-target="termsConditions" class="agreement-link modal-trigger">Terms and Conditions</a> and
                        <a href="#" data-target="dataPrivacy" class="agreement-link modal-trigger">Data Privacy Policy</a>
                    </span>
                    <span class="required-mark">*</span>
                </label>
            </div>
        </form>
    </div>

    @*Submit or cancel*@
    <div class="modal-footer footer-center" style="margin-top:1.5vh">
        <button type="submit" class="edit-btn left" style="font-weight:500;" ng-click="pickSignUpPhoto()">UPLOAD PHOTO</button>
        <button class="modal-close cancel-btn" style="font-weight:500; margin-right:.5vh">CANCEL</button>
        <button type="button" class="edit-btn" ng-click="openScheduleModal()" style="font-weight:500;">NEXT</button>
    </div>
</div>


@*schedule modal*@
<div id="modalSchedule" class="modal">
    <div class="modal-content">
        <h5>Weekly Schedule (Availability)</h5>
        <p class="small">Select days and time ranges when you are available. These determine appointment slots.</p>
        <table class="striped">
            <thead>
                <tr>
                    <th>Day</th>
                    <th style="width:120px">Available</th>
                    <th>Start</th>
                    <th>End</th>
                    <th style="width:100px">Slot (min)</th>
                </tr>
            </thead>
            <tbody>
                <tr ng-repeat="d in modalScheduleDays">
                    <td>{{d.dayName}}</td>
                    <td>
                        <label>
                            <input type="checkbox" ng-model="d.enabled" />
                        </label>
                    </td>
                    <td>
                        <input type="time" class="custom-input" ng-model="d.startTime" ng-disabled="!d.enabled" />
                    </td>
                    <td>
                        <input type="time" class="custom-input" ng-model="d.endTime" ng-disabled="!d.enabled" />
                    </td>
                    <td>
                        <input type="number" min="5" step="5" class="custom-input" ng-model="d.slotMinutes" ng-disabled="!d.enabled" />
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="modal-footer">
        <a href="javascript:void(0)" class="modal-close btn-flat">Close</a>
    </div>
</div>



@*Termz and condz*@
<div id="termsConditions" class="modal">
    <div class="modal-content center-align">
        <h4 class="modal-form-title-alt">Terms and Conditions</h4>
        <h5 class="modal-form-title">Reyes-Guansing Dental Clinic (RGDC)<br> Dental Management System</h5>

        <div class="terms-scroll-container preserve-format">
            1. ACCEPTANCE OF TERMS<br />
            Welcome to the Reyes-Guansing Dental Clinic (RGDC) Dental Management System. <br />These Terms and Conditions ("Terms", "T&C", or "Agreement") constitute a legally binding agreement between you ("User", "You", or "Your") and Reyes-Guansing Dental Clinic ("RGDC", "We", "Us", or "Our") governing your access to and use of the RGDC Dental Management System website and all associated services (collectively, the "System" or "Services").
            By creating an account, you explicitly agree to be bound by these Terms and Conditions. During the account registration process, you must check the acknowledgment box confirming that you have read, understood, and agree to these Terms before your account can be created. Your agreement is timestamped and stored for legal compliance purposes. If you do not agree to these Terms, you must not create an account or use the System.
            For Minor Patients: If you are creating an account for a patient under 18 years of age, you represent and warrant that you are the parent or legal guardian of the minor and have the authority to agree to these Terms on their behalf. You accept full responsibility for the minor's use of the System.<br /><br /><br />
            Continued Use: Your continued access to and use of the System after the effective date of any updates to these Terms constitutes your acceptance of such changes. It is your responsibility to review these Terms periodically.<br><br>

            2. DEFINITIONS AND USER TYPES<br><br>
            2.1 System Definitions<br>
            System: The RGDC Dental Management System, including the website interface, database, APIs, integrations, and all associated services and features.
            Account: Your unique user profile within the System, protected by login credentials and associated with a specific user type.
            Records: All data stored within the System including but not limited to patient information, dental records, treatment histories, appointments, billing information, and system logs.
            Branch: Any physical location of Reyes-Guansing Dental Clinic operating under the RGDC network.
            2.2 User Types and Access Privileges<br><br>
            The System recognizes four distinct user types, each with defined access privileges and responsibilities:
            Owner<br>
            Access Level: Full administrative control over all System functions and data<br>
            Privileges: Create, modify, and delete all user accounts; access all patient records across all branches; configure system settings and security parameters; manage branch operations; view comprehensive audit trails and reports; suspend or delete accounts that violate these Terms<br>
            Responsibilities: Ensure System security and compliance; oversee proper use by all users; maintain confidentiality of administrative credentials; make final decisions on policy violations<br>
            Dentist<br>
            Access Level: Clinical record management and patient account oversight<br>
            Privileges: Create and manage patient accounts; access and modify dental records for assigned patients; document treatments and clinical notes; schedule and manage appointments; view and update treatment plans; access patient history for clinical decision-making<br>
            Responsibilities: Ensure accuracy of clinical documentation; maintain patient confidentiality; use System only for legitimate clinical purposes; report any suspected security breaches<br>
            Staff<br>
            Access Level: Administrative support functions<br>
            Privileges: Schedule and manage appointments; update patient contact information; process billing and payments; generate reports; manage clinic calendars; send notifications to patients; perform data entry tasks<br>
            Responsibilities: Maintain accuracy of administrative data; protect patient information; assist patients with account-related questions; follow clinic policies and procedures<br>
            Patient<br>
            Access Level: Limited access to personal information only<br>
            Privileges: View personal dental records and treatment history; access appointment schedules; update personal contact information; view billing statements; receive notifications and reminders; communicate with clinic staff<br>
            Responsibilities: Provide accurate personal and medical information; maintain confidentiality of login credentials; report any unauthorized account access; notify clinic of changes to contact information or medical history<br>
            2.3 Cross-Branch Access<br>
            Access to patient records across different RGDC branches is controlled by role-based permissions. Unless explicitly authorized by an Owner, users are typically limited to accessing records within their assigned branch to maintain appropriate data segregation and security.<br><br>

            3. ACCOUNT REGISTRATION AND REQUIREMENTS<br><br>
            3.1 Account Creation<br>
            To use the RGDC Dental Management System, you must create an account by providing accurate, complete, and current information including:
            Full legal name<br>
            Valid email address<br>
            Contact phone number<br>
            Date of birth<br>
            Residential address<br>
            Emergency contact information (for patient accounts)<br>
            Any other information required during the registration process<br><br>
            For Patient Accounts: Your account will be created by an authorized RGDC Dentist or Staff member during your first visit or through the online registration portal. You will be required to set a secure password upon first login.<br>
            For Staff Accounts: Accounts are created by authorized Owners or designated administrators with appropriate role assignments.<br><br>
            3.2 Account Verification<br>
            Upon account creation, you may be required to verify your email address by clicking a verification link sent to the email you provided. Unverified accounts may have limited functionality until verification is completed.
            3.3 Mandatory Agreement to Terms<br>
            As specified in Section 1, you must explicitly agree to these Terms and Conditions by checking the acknowledgment box during registration. This requirement addresses the clinic's commitment that "every patient kailangan may consent" to avoid potential legal disputes and ensures all users acknowledge their responsibilities regarding data storage and processing within the System.
            3.4 Password Requirements and Security<br>
            You must create a strong password that meets the following minimum requirements:<br>
            At least 8 characters in length<br>
            Contains at least one uppercase letter<br>
            Contains at least one lowercase letter<br>
            Contains at least one number<br>
            Contains at least one special character (#, $, %, etc.)<br>
            You are solely responsible for maintaining the confidentiality of your password and account credentials. You must:<br>
            Never share your password with others<br>
            Change your password immediately if you suspect unauthorized access<br>
            Log out of your account when using shared or public computers<br>
            Notify RGDC immediately of any suspected security breach<br><br>
            3.5 Account Accuracy<br>
            You agree to provide accurate, current, and complete information during registration and to promptly update such information to maintain its accuracy. RGDC reserves the right to suspend or terminate accounts that contain false, inaccurate, or incomplete information.<br><br>

            4. SYSTEM FEATURES AND FUNCTIONALITY<br><br>
            4.1 Core System Features<br>
            The RGDC Dental Management System provides the following core features based on user type:<br>
            For All Users:<br>
            Secure login and authentication<br>
            Password reset functionality<br>
            Account settings management<br>
            Notification preferences<br>
            <strong>For Owners:</strong><br>
            Complete user management across all branches<br>
            System configuration and settings<br>
            Comprehensive reporting and analytics<br>
            Audit trail access<br>
            Security monitoring and controls<br>
            <strong>For Dentists:</strong><br>
            Patient record management<br>
            Treatment planning and documentation<br>
            Appointment scheduling<br>
            Clinical notes and progress tracking<br>
            Prescription management<br>
            Access to patient dental history<br>
            <strong>For Staff:</strong><br>
            Appointment booking and calendar management<br>
            Patient registration and data entry<br>
            Billing and payment processing<br>
            Report generation<br>
            Email and SMS notification management<br>
            <strong>For Patients:</strong><br>
            View personal dental records<br>
            Access appointment history and schedules<br>
            Update contact information<br>
            View treatment plans and recommendations<br>
            Receive appointment reminders<br>
            Access billing statements<br>
            4.2 Google Calendar API Integration<br>
            The System integrates with Google Calendar API to provide appointment synchronization features. By enabling this integration, you authorize the System to:<br>
            Create calendar events for your dental appointments<br>
            Update existing appointment events when changes occur<br>
            Delete calendar events when appointments are cancelled<br>
            Access your Google Calendar to prevent scheduling conflicts<br>
            You can enable or disable this integration at any time through your account settings. Disabling integration will not affect your appointments within the RGDC System but will stop synchronization with your Google Calendar.<br>
            4.3 Gmail API Integration<br>
            The System uses Gmail API to send automated email notifications for:<br>
            Appointment confirmations and reminders<br>
            Treatment updates and follow-up instructions<br>
            Password reset requests<br>
            System announcements and policy updates<br>
            Billing statements and payment receipts<br>
            Security alerts and account notifications<br>
            By creating an account, you consent to receive these automated emails. You can manage notification preferences in your account settings, though certain critical notifications (security alerts, legal notices) cannot be disabled.<br>
            4.4 Record Archival Period<br>
            When any record is deleted from the System—whether patient records, appointments, treatment notes, or user accounts—it enters a 30-day archival period before permanent deletion. During this period:<br>
            The record is marked as "deleted" but remains in the System database<br>
            The record is not visible through normal System operations<br>
            Authorized Owners can restore the record if deletion was made in error<br>
            The record cannot be modified during the archival period<br>
            After 30 days, the record is permanently and irreversibly deleted from all systems and backups<br>
            This archival period provides protection against accidental deletion and allows reasonable time for data recovery requests.<br>
            4.5 Patient Record Deletion<br>
            Patient records can be deleted under the following circumstances:<br>
            Patient requests account closure and record deletion<br>
            Owner determines records should be removed for policy violations<br>
            Legal requirements mandate record deletion<br>
            However, deletion requests are subject to:<br>
            The <strong>30-day archival period</strong> described in Section 4.4<br>
            Legal record retention requirements (minimum 10 years for medical records)<br>
            Ongoing legal proceedings or disputes requiring record preservation<br>
            RGDC reserves the right to retain records beyond deletion requests when legally required or when deletion would compromise patient safety or clinic operations.<br>
            4.6 Appointment Management<br>
            The System provides comprehensive appointment scheduling features:<br>
            Real-time availability checking across dentists and branches<br>
            Automated conflict detection<br>
            Appointment reminders via email (24 hours and 1 hour before appointment)<br>
            Rescheduling and cancellation options<br>
            Waitlist management for fully booked time slots<br>
            Cancellation Policy: Patients should cancel or reschedule appointments at least 24 hours in advance when possible. Repeated missed appointments without notice may result in limitations on future booking privileges.<br>
            4.7 Treatment Record Management<br>
            Dentists document all treatments within the System, creating comprehensive records that include:<br>
            Clinical examinations and findings<br>
            Diagnoses and treatment plans<br>
            Procedures performed<br>
            Materials used<br>
            Post-treatment instructions<br>
            Follow-up recommendations<br>
            These records enter the 30-day archival period if deleted but are generally retained for the legally required minimum of 10 years to support continuity of care and emergency reference.<br>
            4.8 Security Features<br>
            The System implements multiple security measures to protect user accounts and patient data:<br>
            Password Encryption: All passwords are encrypted using industry-standard bcrypt hashing algorithms before storage. Passwords are never stored in plain text, and even system administrators cannot view your actual password.<br>
            Role-Based Access Control (RBAC): Access to data and System functions is strictly controlled based on user type. Users can only access information and perform actions appropriate to their assigned role.<br>
            Account Lockout: After 5 consecutive failed login attempts, your account is automatically locked for security purposes. You must contact RGDC support or wait 30 minutes for automatic unlock. This prevents brute force password attacks.<br>
            Session Timeout: User sessions automatically expire after 30 minutes of inactivity, requiring re-authentication. This protects against unauthorized access when devices are left unattended.<br>
            Audit Trails: All significant actions within the System are logged with user identity, timestamp, IP address, and action details. These logs are retained for security monitoring and compliance purposes as detailed in Section 4.12.<br>
            Two-Factor Authentication (Optional): Users may enable two-factor authentication for enhanced account security, requiring both password and a verification code from their mobile device.<br>
            4.9 Communication Features<br>
            The System facilitates communication between users through:<br>
            Automated email notifications for appointments and updates<br>
            Internal messaging between patients and clinic staff (where available)<br>
            Bulk announcements from clinic administration<br>
            Emergency contact notifications<br>
            All communications through the System are subject to monitoring for security and quality assurance purposes.<br>
            4.10 Billing and Payment Features<br>
            The System tracks billing information including:<br>
            Treatment costs and service fees<br>
            Payment history and outstanding balances<br>
            Insurance claims and coverage details<br>
            Payment receipts and statements<br>
            Patients can view their billing history and statements through their account dashboard. Actual payment processing may be handled separately and is subject to the clinic's payment policies.<br>
            4.11 Reporting and Analytics<br>
            Owners and authorized users can generate various reports:<br>
            Appointment statistics and trends<br>
            Patient demographics and visit frequencies<br>
            Treatment outcomes and success rates<br>
            Financial reports and revenue analysis<br>
            System usage and performance metrics<br>
            Reports containing patient information are subject to the same confidentiality and access control requirements as the underlying data.<br>
            4.12 Audit Trails and Compliance Logging<br>
            The System maintains comprehensive audit trails for compliance with healthcare regulations and data privacy laws:<br>
            Logged Activities:<br>
            All user login and logout events<br>
            Patient record access (viewing, editing, creation)<br>
            Appointment creation, modification, and deletion<br>
            Treatment record documentation<br>
            User account changes and administrative actions<br>
            System configuration changes<br>
            Security events and alerts<br>
            Audit Trail Retention: Audit logs are retained for a minimum of 3 years for compliance purposes and may be retained longer if required by legal proceedings or regulatory investigations.<br>
            Audit Trail Access: Only Owners and authorized system administrators can access audit trails. Audit logs cannot be modified or deleted by any user, ensuring integrity for compliance and legal purposes.<br><br>


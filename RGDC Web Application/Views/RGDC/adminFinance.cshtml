@{
    Layout = "~/Views/Shared/_adminLayout.cshtml";
}

<div class="dashContainer">
    @*top buttons*@
    <div class="row brown-text lighten-1" style="margin-top: 1rem">
        @*refresh and logout buttons*@
        <div class="col m4 l4 offset-md-8 offset-l8">
            <span class="right m-0">
                <div class="col valign-wrapper"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Refresh Tab"> <i class="material-icons brown-text lighten-1">refresh</i></a></div>
                <div class="col valign-wrapper"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Logout"> <i class="material-icons brown-text lighten-1">logout</i></a></div>
            </span>
        </div>
    </div>

    @*create new finance record button*@
    <div class="row m-0">
        <a class="waves-effect waves-light btn left brown lighten-4 medBtn modal-trigger" data-target="modalAddPayrec"><i class="material-icons left">add</i>Create New Payment Record</a>
    </div>

    @*admin finance table*@
    <div class="row" style="padding: 2rem">
        <table id="adminFinance" class="hover tableClk">
            @*table headers*@
            <thead>
                <tr class="brown-text lighten-1">
                    <th>Patient Name</th>
                    <th>Dentist</th>
                    <th colspan="2">Date</th>
                    @*<th></th>*@
                </tr>
            </thead>
            @*table content*@
            <tbody>
                <tr data-href="#" title="View patient record" class="clkPointer">
                    <td class="valign-wrapper"><img src="https://placehold.co/400" class="circle responsive-img" style="max-width:3rem; margin-right:0.5rem" />Name</td>
                    <td>Name</td>
                    <td>MM/DD/YYYY</td>
                    @*view button*@
                    <td>
                        <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 redBtn modal-trigger" data-target="modalDeletePayrec" data-position="bottom" data-tooltip="Delete Payment Record">
                            <i class="material-icons brown-text lighten-1">delete</i>
                        </a>
                        <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 modal-trigger" data-target="modalEditPayrec" data-position="bottom" data-tooltip="Edit Payment Record" style="margin-right: 0.5rem !important"><i class="material-icons brown-text lighten-1">edit</i></a>
                    </td>
                </tr>
            </tbody>
            @*table footer*@
            <tfoot>
                <tr class="brown-text lighten-1">
                    <th>Patient Name</th>
                    <th>Dentist</th>
                    <th>Date</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@*ADD Payment Record*@
<div id="modalAddPayrec" class="modal payrec-modal">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Add New Payment Record</h5>

        <div class="row">
            <div class="col s12">
                @*Patient*@
                <label class="custom-label">
                    Patient
                    <input type="text" class="custom-input" placeholder="Patient name...">
                </label>
            </div>
        </div>

        <div class="row">
            <div class="col s6">
                @*Dentist*@
                <label class="custom-label">
                    Dentist
                    <input type="text" class="custom-input" placeholder="Dentist name...">
                </label>
            </div>

            <div class="col s6">
                @*Date*@
                <label class="custom-label">Date</label>
                <div class="datepicker-wrapper">
                    <input id="date" type="text" class="datepicker custom-input" placeholder="MM/DD/YYYY">
                    <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col s4">
                @*Mode of Payment*@
                <label class="custom-label">
                    Mode of Payment
                    <input type="text" class="custom-input" placeholder="Mode of payment...">
                </label>
            </div>

            <div class="col s4">
                @*Cost*@
                <label class="custom-label">
                    Cost
                    <input type="text" class="custom-input" placeholder="Cost...">
                </label>
            </div>

            <div class="col s4">
                @*Discount*@
                <label class="custom-label">
                    Discount
                    <input type="text" class="custom-input" placeholder="Discount...">
                </label>
            </div>
        </div>

        <div class="row">
            <div class="col s6">
                @*Total*@
                <label class="custom-label">
                    Total Ammount Due
                    <input type="text" class="custom-input" placeholder="Total ammount due...">
                </label>
            </div>

            <div class="col s6">
                @*Paid*@
                <label class="custom-label">
                    Total Ammount Paid
                    <input type="text" class="custom-input" placeholder="Total ammount paid...">
                </label>
            </div>
        </div>

        <div class="row">
            <div class="col s12">
                @*Description*@
                <label class="custom-label">
                    Description
                    <textarea style="flex: 1; height: 10vh; padding: 1vh; background-color:white; border:none;" placeholder="Description..."></textarea>
                </label>
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0">ADD</button>
    </div>
</div>




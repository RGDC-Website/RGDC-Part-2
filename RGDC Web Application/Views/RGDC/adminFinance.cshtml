@{
    Layout = "~/Views/Shared/_adminLayout.cshtml";
}

<div class="dashContainer">
    @*top buttons*@
    <div class="row brown-text lighten-1" style="margin-top: 1rem">
        @*refresh and logout buttons*@
        <div class="col m4 l4 offset-md-8 offset-l8">
            <span class="right m-0">
                <div class="col valign-wrapper"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Refresh Tab"> <i class="material-icons brown-text lighten-1">refresh</i></a></div>
                <div class="col valign-wrapper"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Logout"> <i class="material-icons brown-text lighten-1">logout</i></a></div>
            </span>
        </div>
    </div>

    @*create new finance record button*@
    <div class="row m-0">
        <a class="waves-effect waves-light btn left brown lighten-4 medBtn modal-trigger" data-target="modal-add-payrec"><i class="material-icons left">add</i>Create New Payment Record</a>
    </div>

    @*admin finance table*@
    <div class="row" style="padding: 2rem">
        <table id="adminFinance" class="hover tableClk" ng-init="getPayments()">
            @*table headers*@
            <thead>
                <tr class="brown-text lighten-1">
                    <th>Patient Name</th>
                    <th>Dentist</th>
                    <th colspan="2">Date</th>
                    @*<th></th>*@
                </tr>
            </thead>
            @*table content*@
            <tbody>
                <tr data-href="#" title="View patient record" class="clkPointer" ng-repeat="payment in paymentsArray">
                    <td class="valign-wrapper"><img src="https://placehold.co/400" class="circle responsive-img" style="max-width:3rem; margin-right:0.5rem" />{{payment.patientName}}</td>
                    <td>{{payment.dentistName}}</td>
                    <td>{{payment.paymentDate | date:'MM/dd/yyyy'}}</td>
                    @*view button*@
                    <td>
                        <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 redBtn modal-trigger" data-target="modal-delete-payrec" data-position="bottom" data-tooltip="Delete Payment Record" ng-click="deletePayRec(payment.paymentID)">
                            <i class="material-icons brown-text lighten-1">delete</i>
                        </a>
                        <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 modal-trigger" data-target="modal-edit-payrec" data-position="bottom" data-tooltip="Edit Payment Record" style="margin-right: 0.5rem !important"><i class="material-icons brown-text lighten-1" ng-click="editPayRec(payment.paymentID)">edit</i></a>
                    </td>
                </tr>
            </tbody>
            @*table footer*@
            <tfoot>
                <tr class="brown-text lighten-1">
                    <th>Patient Name</th>
                    <th>Dentist</th>
                    <th>Date</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@*ADD Payment Record*@
<div id="modal-add-payrec" class="modal modal-fixed-footer add-payrec-modal" ng-init="getPatientsNDentist()">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Add New Payment Record</h5>

        <div class="row">
            <div class="col s12">
                @*Patient*@
                <label class="custom-label">
                    Patient
                    <input list="patients" id="patientSelect" class="custom-input" ng-model="selectedPatient" placeholder="Type patient name..." />
                    <datalist id="patients">
                        <option ng-repeat="patient in patientArray" value="{{patient.patientName}} {{patient.patientID}}">{{patient.patientName}}</option>
                    </datalist>
                </label>
            </div>
        </div>

        <div class="row">
            <div class="col s6">
                @*Dentist*@
                <label class="custom-label">
                    Dentist
                    <input list="dentists" id="dentistSelect" class="custom-input" ng-model="selectedDentist" placeholder="Type dentist name..." />
                    <datalist id="dentists">
                        <option ng-repeat="dentist in dentistArray" value="{{dentist.dentistName}} {{dentist.dentistID}}">{{dentist.dentistName}}</option>
                    </datalist>
                </label>
            </div>

            <div class="col s6">
                @*Date*@
                <label class="custom-label">
                    Date
                    <input type="text" class="custom-input" placeholder="MM/DD/YYYY">
                </label>
            </div>
        </div>

        <div class="row">
            <div class="col s4">
                @*Mode of Payment*@
                <label class="custom-label">
                    Mode of Payment
                    <input type="text" class="custom-input" ng-model="paymentMethod" placeholder="Mode of payment...">
                </label>
            </div>

            <div class="col s4">
                @*Cost*@
                <label class="custom-label">
                    Cost
                    <input type="text" class="custom-input" ng-model="paymentCost" placeholder="Cost...">
                </label>
            </div>

            <div class="col s4">
                @*Discount*@
                <label class="custom-label">
                    Discount
                    <input type="text" class="custom-input" ng-model="paymentDiscount" placeholder="Discount...">
                </label>
            </div>
        </div>

        <div class="row">
            <div class="col s6">
                @*Total*@
                <label class="custom-label">
                    Total Amount Due
                    <input type="text" class="custom-input" ng-model="paymentDue" placeholder="Total amount due...">
                </label>
            </div>

            <div class="col s6">
                @*Paid*@
                <label class="custom-label">
                    Total Amount Paid
                    <input type="text" class="custom-input" ng-model="paymentPaid" placeholder="Total amount paid...">
                </label>
            </div>
        </div>

        <div class="row">
            <div class="col s12">
                @*Description*@
                <label class="custom-label">
                    Description
                    <textarea style="flex: 1; height: 10vh; padding: 1vh;  background-color:white; border:none;" placeholder="Description..." ng-model="paymentDescription"></textarea>
                </label>
            </div>
        </div>
    </div>

    <div class="modal-footer footer-center">
        <button class="modal-close cancel-btn" style="font-weight:500;">CANCEL</button>
        <button type="submit" class="edit-btn modal-close" style="font-weight:500; margin-right:20px" ng-click="addPayment()">ADD</button>
    </div>
</div>



@*EDIT Payment Record*@
<div id="modal-edit-payrec" class="modal modal-fixed-footer add-payrec-modal" >
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Add New Payment Record</h5>

        <div class="row">
            <div class="col s12">
                @*Patient*@
                <label class="custom-label">
                    Patient
                    <input list="patients" id="patientSelect" class="custom-input" placeholder="Type patient name..." ng-model="paymentInfo.patientName" readonly />

                </label>
            </div>
        </div>

        <div class="row">
            <div class="col s6">
                @*Dentist*@
                <label class="custom-label">
                    Dentist
                    <input list="dentists" id="dentistSelect" class="custom-input"  placeholder="Type dentist name..." ng-model="paymentInfo.dentistName" readonly/>
                </label>
            </div>

            <div class="col s6">
                @*Date*@
                <label class="custom-label">
                    Date
                    <input type="text" class="custom-input" placeholder="MM/DD/YYYY">
                </label>
            </div>
        </div>

        <div class="row">
            <div class="col s4">
                @*Mode of Payment*@
                <label class="custom-label">
                    Mode of Payment
                    <input type="text" class="custom-input" placeholder="Mode of payment..." ng-model="paymentInfo.paymentMethod">
                </label>
            </div>

            <div class="col s4">
                @*Cost*@
                <label class="custom-label">
                    Cost
                    <input type="text" class="custom-input" placeholder="Cost..." ng-model="paymentInfo.cost">
                </label>
            </div>

            <div class="col s4">
                @*Discount*@
                <label class="custom-label">
                    Discount
                    <input type="text" class="custom-input" placeholder="Discount..." ng-model="paymentInfo.discount">
                </label>
            </div>
        </div>

        <div class="row">
            <div class="col s6">
                @*Total*@
                <label class="custom-label">
                    Total Amount Due
                    <input type="text" class="custom-input" placeholder="Total amount due..." ng-model="paymentInfo.amountDue">
                </label>
            </div>

            <div class="col s6">
                @*Paid*@
                <label class="custom-label">
                    Total Amount Paid
                    <input type="text" class="custom-input"  placeholder="Total amount paid..." ng-model="paymentInfo.amountPaid">
                </label>
            </div>
        </div>

        <div class="row">
            <div class="col s12">
                @*Description*@
                <label class="custom-label">
                    Description
                    <textarea style="flex: 1; height: 10vh; padding: 1vh;  background-color:white; border:none;" placeholder="Description..."  ng-model="paymentInfo.description"></textarea>
                </label>
            </div>
        </div>
    </div>

    <div class="modal-footer footer-center">
        <button class="modal-close cancel-btn" style="font-weight:500;">CANCEL</button>
        <button type="submit" class="edit-btn modal-close" style="font-weight:500; margin-right:20px" ng-click="editPayment()">EDIT</button>
    </div>
</div>

@*DELETE Peyment Record*@
<div id="modal-delete-payrec" class="modal modal-fixed-footer delete-payrec-modal">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Delete Payment Record</h5>

        <p class="custom-label">Are you sure you want to delete this payment record?</p>
    </div>

    <div class="modal-footer footer-center">
        <button class="modal-close cancel-btn" style="font-weight:500;">CANCEL</button>
        <button type="submit" class="modal-close edit-btn" style="font-weight:500; margin-right:20px" ng-click="deletePaymentThis()">DELETE</button>
    </div>
</div>
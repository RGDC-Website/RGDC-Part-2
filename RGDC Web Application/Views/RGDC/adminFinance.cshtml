@*VIEW Payment Record*@
<div id="modalViewPayrec" class="modal payrec-modal">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Payment Record</h5>
        <div class="row">
            <div class="col s6">
                @*Patient*@
                <label class="custom-label">Patient</label>
                <p class="custom-input">{{paymentInfo.patientName}}</p>
            </div>

            <div class="col s6">
                @*Date*@
                <label class="custom-label">Date</label>
                <p class="custom-input">{{paymentInfo.paymentDate}}</p>
            </div>
        </div>


        <div class="row">
            <div class="col s6">
                @*Dentist*@
                <label class="custom-label">Dentist</label>
                <p class="custom-input">{{paymentInfo.dentistName}}</p>
            </div>

            <div class="col s6">
                @*Tooth Number*@
                <label class="custom-label">Tooth Number</label>
                <p class="custom-input">{{paymentInfo.toothNumber}}</p>
            </div>
        </div>

        <div class="row">
            <div class="col s12">
                @*Procedure*@
                <label class="custom-label">Procedure</label>
                <p class="custom-input">{{paymentInfo.procedures}}</p>
            </div>
        </div>

        <h5 class="modal-form-title" style="margin: 4vh 0 1.5vh 0;">Payment</h5>

        <div class="row">
            <div class="col s4">
                @*Mode of Payment*@
                <label class="custom-label">Mode of Payment</label>
                <p class="custom-input">{{paymentInfo.paymentMethod}}</p>
            </div>
            <div class="col s4">
                @*Cost*@
                <label class="custom-label">Cost</label>
                <p class="custom-input">{{paymentInfo.cost}}</p>
            </div>
            <div class="col s4">
                @*Discount*@
                <label class="custom-label">Discount</label>
                <p class="custom-input">{{paymentInfo.discount}}</p>
            </div>
        </div>


        <div class="row">
            <div class="col s6">
                @*Paid*@
                <label class="custom-label">Total Amount Paid</label>
                <p class="custom-input">{{paymentInfo.amountPaid}}</p>
            </div>

            <div class="col s6">
                @*Total*@
                <label class="custom-label">Balance Payment</label>
                <p class="custom-input">{{paymentInfo.amountDue}}</p>
            </div>
        </div>

        <div class="row">
            <div class="col s12">
                @*Description*@
                <label class="custom-label">Description</label>
                <p style="flex: 1; min-height: 10vh; padding: 1vh; background-color: white;">{{paymentInfo.description}}</p>
            </div>
        </div>
    </div>


    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">
            CLOSE
        </button>

    </div>
</div>

@*Archive Peyment Record*@
<div id="modalDeletePayrec" class="modal payrec-modal" style="width:30% !important">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Arhive Payment Record</h5>

        <p class="custom-label">Are you sure you want to archive this payment record?</p>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0" ng-click="deletePaymentThis()">ARCHIVE</button>
    </div>
</div>

@*Unrchive Peyment Record*@
<div id="modalDeletePayrecNo" class="modal payrec-modal" style="width:30% !important">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Arhive Payment Record</h5>

        <p class="custom-label">Are you sure you want to unarchive this payment record?</p>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>
        <button type="submit" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0" ng-click="undeletePaymentThis()">UNARCHIVE</button>
    </div>
</div>

                                name="gender"
                                ng-class="{'valid-input': addFormForm.gender.$dirty && !addFormForm.gender.$invalid, 'invalid-input': addFormForm.gender.$dirty && addFormForm.gender.$invalid}">
                            <option value="" disabled>Select Gender</option>
                        </select>
                    </label>
                    <span class="helper-text error-text" ng-show="addFormForm.gender.$dirty && addFormForm.gender.$invalid">This field is required</span>

                    <label class="custom-label">
                        Date of Birth
                        <input name="birthDate" type="date" class="custom-input" ng-model="newForm.birthDate" max="@DateTime.Now.ToString("yyyy-MM-dd")" required
                               ng-class="{'valid-input': addFormForm.birthDate.$dirty && !addFormForm.birthDate.$invalid, 'invalid-input': addFormForm.birthDate.$dirty && addFormForm.birthDate.$invalid}" />
                    </label>
                    <span class="helper-text error-text" ng-show="addFormForm.birthDate.$dirty && addFormForm.birthDate.$invalid">This field is required</span>
                </div>

                <div class="col s12 m6">
                    <label class="custom-label">
                        Civil Status
                        <select class="browser-default custom-input" ng-model="newForm.civilStatus" name="civilStatus" required
                                ng-class="{'valid-input': addFormForm.civilStatus.$dirty && !addFormForm.civilStatus.$invalid, 'invalid-input': addFormForm.civilStatus.$dirty && addFormForm.civilStatus.$invalid}">
                            <option value="" disabled selected>Select Status</option>
                            <option value="Single">Single</option>
                            <option value="Married">Married</option>
                            <option value="Widowed">Widowed</option>
                        </select>
                    </label>
                    <span class="helper-text error-text" ng-show="addFormForm.civilStatus.$dirty && addFormForm.civilStatus.$invalid">This field is required</span>

                    <label class="custom-label">
                        Contact Number
                        <input name="contactNumber"
                               type="text"
                               class="custom-input"
                               placeholder="09XXXXXXXXX"
                               ng-model="newForm.contactNumber"
                               required
                               ng-pattern="/^09\d{9}$/"
                               maxlength="11"
                               oninput="this.value = this.value.replace(/[^0-9]/g,'')"
                               ng-class="{'valid-input': addFormForm.contactNumber.$dirty && !addFormForm.contactNumber.$invalid, 'invalid-input': addFormForm.contactNumber.$dirty && addFormForm.contactNumber.$invalid}" />
                    </label>
                    <span class="helper-text error-text" ng-show="addFormForm.contactNumber.$dirty && addFormForm.contactNumber.$error.required">This field is required</span>
                    <span class="helper-text error-text" ng-show="addFormForm.contactNumber.$dirty && addFormForm.contactNumber.$error.pattern">Enter a valid contact number (09#########)</span>

                    <label class="custom-label">
                        Address
                        <input name="address"
                               type="text"
                               class="custom-input"
                               placeholder="Address"
                               ng-model="newForm.address"
                               required
                               ng-minlength="5"
                               ng-class="{'valid-input': addFormForm.address.$dirty && !addFormForm.address.$invalid, 'invalid-input': addFormForm.address.$dirty && addFormForm.address.$invalid}" />
                    </label>
                    <span class="helper-text error-text" ng-show="addFormForm.address.$dirty && addFormForm.address.$error.required">This field is required</span>
                    <span class="helper-text error-text" ng-show="addFormForm.address.$dirty && addFormForm.address.$error.minlength">Address must be at least 5 characters</span>

                    <label class="custom-label">
                        Upload form file / image (optional)
                        <input type="file" class="custom-input" onchange="angular.element(this).scope().pickFormFile(this)" />
                    </label>
                </div>
            </div>

            <div class="row" style="margin-top:8px;">

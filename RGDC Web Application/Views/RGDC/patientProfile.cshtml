        <button class="modal-close cancel-btn" style="font-weight:500; margin: 0 .5vh -6vh 0">CANCEL</button>
        <button type="button" ng-show="!isUserPatient" class="edit-btn" style="font-weight: 500; margin: 0 2vh -6vh 0" ng-click="saveDentalChart()">SAVE</button>
    </div>
</div>



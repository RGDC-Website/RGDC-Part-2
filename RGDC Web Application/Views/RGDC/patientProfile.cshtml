@*ADD Payment Record*@
<div id="modalAddPayrec" class="modal payrec-modal" ng-init="getPatientsNDentist()">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:1.5vh;">Add New Payment Record</h5>

        <div class="row">
            <div class="col s6">
                @*Patient*@
                <label class="custom-label">Patient <span class="required-mark">*</span></label>
                <select class="custom-input browser-default" ng-model="selectedPatient"
                        ng-class="{'invalid-input': addSubmitted && !selectedPatient}">
                    <option value="" disabled selected>Select patient...</option>
                    <option ng-repeat="patient in patientArray" value="{{patient.patientID}}">{{patient.patientName}}</option>
                </select>
                <span class="validation-msg" ng-show="addSubmitted && !selectedPatient">Patient is required.</span>
            </div>

            <div class="col s6">
                @*Date*@
                <label class="custom-label">Date <span class="required-mark">*</span></label>
                <div class="datepicker-wrapper">
                    <input id="date" type="text" class="datepicker custom-input" ng-model="paymentDate" placeholder="MM/DD/YYYY"
                           ng-class="{'invalid-input': addSubmitted && !paymentDate}">
                    <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                </div>
                <span class="validation-msg" ng-show="addSubmitted && !paymentDate">Date is required.</span>
            </div>
        </div>

        <div class="row">
            <div class="col s6">
                @*Dentist*@
                <label class="custom-label">Dentist <span class="required-mark">*</span></label>
                <select class="custom-input browser-default" ng-model="selectedDentist"
                        ng-class="{'invalid-input': addSubmitted && !selectedDentist}">
                    <option value="" disabled selected>Select dentist...</option>
                    <option ng-repeat="dentist in dentistArray" value="{{dentist.dentistID}}">{{dentist.dentistName}}</option>
                </select>
                <span class="validation-msg" ng-show="addSubmitted && !selectedDentist">Dentist is required.</span>
            </div>

            <div class="col s6">
                @*Tooth Number*@
                <label class="custom-label">Tooth Number/s <span class="required-mark">*</span></label>
                <input type="text" class="custom-input browser-default" ng-model="paymentToothNumber"
                       ng-class="" />
            </div>
        </div>

        <div class="row">
            <div class="col s12">
                @*Procedure*@
                <label class="custom-label">Procedures Done <span class="required-mark">*</span></label>
                <input type="text" class="custom-input browser-default" ng-model="paymentProcedures"
                       ng-class="" />
            </div>
        </div>


        <h5 class="modal-form-title" style="margin: 4vh 0 1.5vh 0;">Payment</h5>

        <div class="row">
            <div class="col s6">
                @*Mode of Payment*@
                <label class="custom-label">
                    Mode of Payment
                    <span class="required-mark">*</span>
                    <select class="custom-input"
                            ng-model="paymentMethod"
                            ng-class="{'invalid-input': addSubmitted && !paymentMethod}">
                        <option value="" disabled selected>Select mode of payment...</option>
                        <option value="GCash">GCash</option>
                        <option value="Card">Card</option>
                        <option value="Cash">Cash</option>
                        <option value="Others">Others</option>
                    </select>
                </label>
                <span class="validation-msg" ng-show="addSubmitted && !paymentMethod">Mode of payment is required.</span>
            </div>
            <div class="col s6">
                @*Reference*@
                <label class="custom-label">
                    Reference
                    <input type="text" class="custom-input" ng-model="paymentReference" placeholder="Reference Number..." max="50" />
                </label>
            </div>
        </div>
        <div class="row">
            <div class="col s6">
                @*Cost*@
                <label class="custom-label">
                    Cost
                    <span class="required-mark">*</span>
                    <input type="text" class="custom-input" ng-model="paymentCost" placeholder="Cost..."
                           oninput="this.value = this.value.replace(/[^0-9.]/g, '')"
                           ng-class="{'invalid-input': addSubmitted && !paymentCost}">
                </label>
                <span class="validation-msg" ng-show="addSubmitted && !paymentCost">Cost is required.</span>
            </div>
            <div class="col s6">
                @*Discount*@
                <label class="custom-label">
                    Discount
                    <span class="required-mark">*</span>
                    <input type="text" class="custom-input" ng-model="paymentDiscount" placeholder="Discount..."
                           oninput="this.value = this.value.replace(/[^0-9.]/g, '')">
                </label>
            </div>
        </div>
        <div class="row">
            <div class="col s6">
                @*Paid*@
                <label class="custom-label">
                    Total Amount Paid
                    <span class="required-mark">*</span>
                    <input type="text" class="custom-input" ng-model="paymentPaid" placeholder="Total amount paid..."
                           oninput="this.value = this.value.replace(/[^0-9.]/g, '')"
                           ng-class="{'invalid-input': addSubmitted && !paymentPaid}">
                </label>
                <span class="validation-msg" ng-show="addSubmitted && !paymentPaid">Total amount paid is required.</span>
            </div><div class="col s6">
                @*Balance*@
                <label class="custom-label">
                    Balance
                    <span class="required-mark">*</span>
                    <input type="text" class="custom-input"
                           ng-value="(paymentCost || 0) - (paymentDiscount || 0) - (paymentPaid || 0)"
                           placeholder="Balance..."
                           ng-class="{'invalid-input': addSubmitted && ((paymentCost - paymentDiscount - paymentPaid) < 0)}"
                           disabled>
                </label>
                <span class="validation-msg" ng-show="addSubmitted && paymentDue === null">Balance is required.</span>
            </div>

        </div>

        <div class="row">
            <div class="col s12">
                @*Description*@
                <label class="custom-label">
                    Description
                    <textarea style="flex: 1; height: 10vh; padding: 1vh; background-color:white; border:none;"
                              placeholder="Description..." ng-model="paymentDescription"></textarea>
                </label>
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh"
                ng-click="addSubmitted = false">
            CANCEL
        </button>
        <button type="submit" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0"
                ng-click="addPayment()">
            ADD
        </button>
    </div>
</div>



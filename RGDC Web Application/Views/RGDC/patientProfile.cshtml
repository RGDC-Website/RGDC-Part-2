@*Dental Chart modal*@
<div id="modalDentalChart" class="modal dentalChart-modal containerOverflow-2">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:3.5vh;">Upload Image</h5>

        <div class="row">
            <div class="col s12 m6">
                <label class="custom-label">Type <span class="required-mark">*</span></label>
                <select class="browser-default custom-input" ng-model="dentalUploadType">

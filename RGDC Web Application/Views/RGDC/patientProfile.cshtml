        <h5 class="modal-form-title" style="margin-bottom:15px;">Add Form</h5>
        <form name="addFormForm" novalidate ng-submit="addForm(newForm)">

            <div class="row">
                <div class="col s12 m6">
                    <label class="custom-label">
                        First Name
                        <input name="firstName"
                               type="text"
                               class="custom-input"
                               placeholder="First Name"
                               ng-model="newForm.firstName"
                               required
                               ng-class="{'valid-input': addFormForm.firstName.$dirty && !addFormForm.firstName.$invalid, 'invalid-input': addFormForm.firstName.$dirty && addFormForm.firstName.$invalid}" />
                    </label>
                    <span class="helper-text error-text" ng-show="addFormForm.firstName.$dirty && addFormForm.firstName.$invalid">This field is required</span>

                    <label class="custom-label">
                        Middle Name
                        <input name="middleName"
                               type="text"
                               class="custom-input"
                               placeholder="Middle Name"
                               ng-model="newForm.middleName" />
                    </label>

                    <label class="custom-label">
                        Last Name
                        <input name="lastName"
                               type="text"
                               class="custom-input"
                               placeholder="Last Name"
                               ng-model="newForm.lastName"
                               required
                               ng-class="{'valid-input': addFormForm.lastName.$dirty && !addFormForm.lastName.$invalid, 'invalid-input': addFormForm.lastName.$dirty && addFormForm.lastName.$invalid}" />

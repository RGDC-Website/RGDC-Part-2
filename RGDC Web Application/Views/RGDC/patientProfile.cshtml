                        <img ng-if="!newForm.previewLink" src="https://placehold.co/2550x3300" style="max-height: 14rem;" alt="Placeholder" />
                    </div>
                </div>
            </div>

            <!-- Terms & Submit area -->
            <div class="row" style="margin-top: 6px;">
                <div class="col s12">
                    <label style="display:flex; align-items:center; gap:10px;">
                        <input name="acceptedTerms" type="checkbox" class="filled-in" ng-model="newForm.acceptedTerms" required />
                        <span>I agree to the terms and conditions</span>
                    </label>
                    <span class="helper-text error-text" ng-show="addFormForm.acceptedTerms.$dirty && addFormForm.acceptedTerms.$invalid">You must accept terms & conditions</span>
                </div>
            </div>

        </form>
    </div>

    <div class="modal-footer footer-center">

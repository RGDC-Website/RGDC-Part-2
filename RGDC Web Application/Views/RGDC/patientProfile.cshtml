@{
    Layout = "~/Views/Shared/_adminLayout.cshtml";
}

<div class="dashContainer">
    @*top buttons*@
    <div class="row brown-text lighten-1" style="margin-top: 1rem">
        @*back button*@
        <div class="col m8 l8 valign-wrapper" style="margin-top: 7px;">
            <a href="/RGDC/adminPatientsTab" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Back to Patients Tab"><i class="material-icons brown-text lighten-1 left">arrow_back</i></a>
        </div>

        @*refresh and logout buttons*@
        <div class="col m4 l4">
            <span class="right" style="margin-top:7px;">
                <div class="col valign-wrapper"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Refresh Tab"> <i class="material-icons brown-text lighten-1">refresh</i></a></div>
                <div ng-click="logOut()" class="col valign-wrapper"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" data-position="bottom" data-tooltip="Logout"> <i class="material-icons brown-text lighten-1">logout</i></a></div>
            </span>
        </div>
    </div>

    @*content*@
    <div class="row" style="padding: 0 1rem 0 1rem;" ng-init="getSelectedPatientDetails(); getGender()">

        @*left column*@
        <div class="col m4 l4" style="padding-left:0">
            @*user name, img, visit*@
            <div class="card grey lighten-2">
                <div class="card-content">
                    @*user pfp and name*@
                    <div class="row center">
                        @*lagyan nalang ng src for image source*@
                        <img src="https://placehold.co/400" class="circle responsive-img" style="max-width:9rem" />
                    </div>

                    @*user name and role*@
                    <div class="row center"> 
                        <h5 class="bold brown-text lighten-1">{{selectedPatient.patientName}}</h5>
                        <h6 class="bold brown-text lighten-1">ID: {{selectedPatient.patientID}}</h6>

                        @*last and next visit*@
                        <p class="brown-text lighten-1">Last Visit: {{selectedPatient.lastVisit}}</p>
                        <p class="brown-text lighten-1">Next Visit: {{selectedPatient.nextVisit || "---"}}</p>

                        <button class="edit-btn right modal-trigger" data-target="modal-patient-info">EDIT</button>
                    </div>
                </div>
            </div>
            @*user info*@
            <div class="card grey lighten-2">
                <div class="card-content">
                    <div class="row m-0">
                        <div class="col m6 l6">
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">AGE</p>
                                <p class="brown-text lighten-1">{{selectedPatient.age}}</p>
                            </div>
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">GENDER</p>
                                <p class="brown-text lighten-1">{{selectedPatient.gender}}</p>
                            </div>
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">EMAIL ADDRESS</p>
                                <p class="brown-text lighten-1">{{selectedPatient.email}}</p>
                            </div>
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">ADDRESS</p>
                                <p class="brown-text lighten-1">{{selectedPatient.address}}</p>
                            </div>
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">RELIGION</p>
                                <p class="brown-text lighten-1">{{selectedPatient.religion}}</p>
                            </div>
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">REFERRAL</p>
                                <p class="brown-text lighten-1">{{selectedPatient.referral}}</p>
                            </div>
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">INSURANCE</p>
                                <p class="brown-text lighten-1">{{selectedPatient.insurance}}</p>
                            </div>
                        </div>
                        <div class="col m6 l6">
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">BIRTHDAY</p>
                                <p class="brown-text lighten-1">{{selectedPatient.birthDate}}</p>
                            </div>
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">CONTACT NUMBER</p>
                                <p class="brown-text lighten-1">{{selectedPatient.contactNumber}}</p>
                            </div>
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">CIVIL STATUS</p>
                                <p class="brown-text lighten-1">{{selectedPatient.civilStatus}}</p>
                            </div>
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">OCCUPATION</p>
                                <p class="brown-text lighten-1">n</p>
                            </div>
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">NATIONALITY</p>
                                <p class="brown-text lighten-1">{{selectedPatient.nationality}}</p>
                            </div>
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">GUARDIAN</p>
                                <p class="brown-text lighten-1">{{selectedPatient.guar}}</p>
                            </div>
                            <div class="mb-1">
                                <p class="bold brown-text lighten-1">ACCOUNT CREATION</p>
                                <p class="brown-text lighten-1">{{selectedPatient.accCreated}}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @*right column*@
        <div class="col m8 l8" style="padding-right: 0">
            <div class="card grey lighten-2">
                <nav class="nav-extended grey lighten-2 z-depth-0">
                    <div class="nav-content p-1">
                        <ul class="tabs tabs-transparent center-tabs">
                            <li class="tab px-1"><a class="active brown-text p-0" href="#med">Medical History</a></li>
                            <li class="tab px-1"><a class="brown-text p-0" href="#prog">Progress Notes</a></li>
                            <li class="tab px-1"><a class="brown-text p-0" href="#dent">Dental Chart</a></li>
                            <li class="tab px-1"><a class="brown-text p-0" href="#forms">Forms</a></li>
                            <li class="tab px-1"><a class="brown-text p-0" href="#postOp">Post Op</a></li>
                        </ul>
                    </div>
                </nav>
                <div class="card-content">

                    @*medical history*@
                    <div id="med" class="containerOverflow-2 row m-0">
                        <div class="medical-history-container">
                            <div class="form-header">
                                @*previous physician info*@
                                <div class="physician-info">
                                    <p class="medInfo">
                                        Name of previous physician:
                                        <span style="font-weight:bold"> {{selectedPatient.prevPhy || '---'}}</span>
                                    </p>
                                    <p>
                                        Physician's Office:
                                        <span style="font-weight:bold"> {{selectedPatient.prevPhyOffice || '---'}}</span>
                                    </p>
                                    <p>
                                        Physician's Contacts:
                                        <span style="font-weight:bold"> {{selectedPatient.prevPhyContact || '---'}}</span>
                                    </p>
                                </div>
                                @*update button and last updated*@
                                <div class="col">
                                    <div class="row">
                                        <button class="update-btn right modal-trigger" data-target="medical-history-modal">UPDATE</button>
                                    </div>
                                    <div class="row" style="margin-top:-15px">
                                        <p class="last-update">Last Update: {{selectedPatient.medHistUpdate || '...'}}</p>
                                    </div>
                                </div>

                            </div>
                            <hr class="form-divider" style="margin-bottom:10px;">

                            @*medical history*@
                            <ol class="medical-questions">
                                <li>
                                    Are you in good health?
                                    <span class="placeholder-text">{{medical.history.goodHealth }}</span>
                                </li>
                                <li>
                                    Are you under medical treatment now?
                                    <span class="placeholder-text">{{medical.history.underTreatment }}</span>
                                </li>
                                <li>
                                    Have you ever had a serious illness or surgical operation?
                                    <span class="placeholder-text">{{medical.history.seriousIllness }}</span>
                                </li>
                                <li>
                                    Have you ever been hospitalized?
                                    <span class="placeholder-text">{{medical.history.hospitalized }}</span>
                                </li>
                                <li>
                                    Are you taking prescription/non-prescription medication?
                                    <span class="placeholder-text">{{medical.history.prescription }}</span>
                                </li>
                                <li>
                                    Are you taking tobacco products?
                                    <span class="placeholder-text">{{medical.history.tobacco }}</span>
                                </li>
                                <li>
                                    Do you use alcohol, cocaine, or other dangerous drugs?
                                    <span class="placeholder-text">{{medical.history.drugs }}</span>
                                </li>
                                <li>
                                    Allergies:
                                    <span class="placeholder-text">{{medical.history.allergies || '---'}}</span>
                                </li>
                                <li>
                                    Bleeding Time:
                                    <span class="placeholder-text">{{medical.history.bleedingTime || '---'}}</span>
                                </li>

                                <li>
                                    For women only:
                                    <div class="women-only-options view-only">
                                        <label><input type="checkbox" ng-model="medical.history.pregnant" class="filled-in" /><span>Are you pregnant?</span></label>
                                        <label><input type="checkbox" ng-model="medical.history.nursing" class="filled-in" /><span>Are you nursing?</span></label>
                                        <label><input type="checkbox" ng-model="medical.history.pills" class="filled-in" /><span>Are you taking birth control pills?</span></label>
                                    </div>
                                </li>

                                <li>
                                    Blood type:
                                    <span class="placeholder-text">{{medical.history.bloodType || '---'}}</span>
                                </li>
                                <li>
                                    Blood pressure:
                                    <span class="placeholder-text">{{medical.history.bloodPressure || '---'}}</span>
                                </li>
                                <li>Do you have or have had any of the following?</li>
                            </ol>

                            <div class="checkbox-grid view-only">
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.highBloodPressure" /><span>High Blood Pressure</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.lowBloodPressure" /><span>Low Blood Pressure</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.epilepsy" /><span>Epilepsy / Convulsions</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.hiv" /><span>AIDS or HIV Infection</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.std" /><span>Sexually Transmitted Disease</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.stomachUlcer" /><span>Stomach Troubles / Ulcer</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.faintingSeizure" /><span>Fainting Seizure</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.rapidWeightLoss" /><span>Rapid Weight Loss</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.radiationTherapy" /><span>Radiation Therapy</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.jointReplacement" /><span>Joint Replacement / Implant</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.heartSurgery" /><span>Heart Surgery</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.heartAttack" /><span>Heart Attack</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.thyroidProblem" /><span>Thyroid Problem</span></label>

                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.heartDisease" /><span>Heart Disease</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.heartMurmur" /><span>Heart Murmur</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.liverDisease" /><span>Hepatitis / Liver Disease</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.rheumaticFever" /><span>Rheumatic Fever</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.allergies" /><span>Hay Fever / Allergies</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.respiratoryProblems" /><span>Respiratory Problems</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.hepatitisJaundice" /><span>Hepatitis / Jaundice</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.tuberculosis" /><span>Tuberculosis</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.swollenAnkles" /><span>Swollen Ankles</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.kidneyDisease" /><span>Kidney Disease</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.diabetes" /><span>Diabetes</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.chestPain" /><span>Chest Pain</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.stroke" /><span>Stroke</span></label>

                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.cancer" /><span>Cancer / Tumors</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.anemia" /><span>Anemia</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.angina" /><span>Angina</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.asthma" /><span>Asthma</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.emphysema" /><span>Emphysema</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.bleedingProblems" /><span>Bleeding Problems</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.bloodDiseases" /><span>Blood Diseases</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.headInjuries" /><span>Head Injuries</span></label>
                                <label><input type="checkbox" class="filled-in" ng-model="medical.conditions.arthritis" /><span>Arthritis / Rheumatism</span></label>

                                <div class="other-section">
                                    <label>
                                        <input type="checkbox" class="filled-in" ng-model="medical.history.checkedd" />
                                        <span>Other/s:</span>
                                    </label>
                                    <input type="text" class="other-input" ng-model="medical.history.text" ng-disabled="!medical.history.checkedd">
                                </div>
                            </div>

                            @*signature*@
                            <div class="signature-container">
                                <div class="signature-pad" style="margin-top: 20px; width:250px; height:100px; display:flex; align-items:center; justify-content:center; background:white; border:1px solid #ddd;">
                                    <img ng-if="selectedPatient.signatureLink || signaturePreview" ng-src="{{ signaturePreview || selectedPatient.signatureLink }}" alt="Signature" style="max-width:250px; max-height:100px; object-fit:contain;" />
                                    <i ng-if="!(selectedPatient.signatureLink || signaturePreview)" class="material-icons">image</i>
                                </div>
                                <div class="signature-line"></div>
                                <span class="signature-label">Signature</span>
                            </div>
                        </div>
                    </div>

                    @*Progress Notes*@
                    <div id="prog" class="row m-0">

                        <div class="row">
                            <a ng-show="isUserAdmin" class="edit-btn right modal-trigger" data-target="modal-progress-notes">ADD NOTE</a>
                        </div>

                        <table id="progressNotes" class="hover">
                            @*table headers*@
                            <thead>
                                <tr class="brown-text lighten-1">
                                    <th>Date</th>
                                    <th>Procedures</th>
                                    <th>Tooth #</th>
                                    <th>Dentist</th>
                                    <th>Amount</th>
                                    <th>Paid</th>
                                    <th colspan="2">Balance</th>
                                </tr>
                            </thead>
                            @*table content*@
                            <tbody>
                                <tr ng-repeat="patientTreatment in patientTreatments">
                                    <td>{{patientTreatment.date}}</td>
                                    <td>{{patientTreatment.procedureID}}</td>
                                    <td>{{patientTreatment.toothNumber}}</td>
                                    <td>{{patientTreatment.dentist}}</td>
                                    <td>{{patientTreatment.amount}}</td>
                                    <td>{{patientTreatment.paid}}</td>
                                    <td>{{patientTreatment.amount - patientTreatment.paid}}</td>
                                    <td>
                                        <a ng-click="editPatient(patientTreatment.trtPlanID)" ng-show="isUserAdmin" class="btn-floating btn-small waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 redBtn modal-trigger" data-target="modal-delete-progress-note" data-position="bottom" data-tooltip="Delete Progress Note">
                                            <i class="material-icons brown-text lighten-1">delete</i>
                                        </a>
                                        <a ng-show="isUserAdmin" class="btn-floating btn-small waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped right m-0 modal-trigger" data-target="modal-edit-progress-note" data-position="bottom" data-tooltip="Edit Progress Note" style="margin-right: 0.5rem !important"><i class="material-icons brown-text lighten-1">edit</i></a>
                                    </td>
                                </tr>
                            </tbody>
                            @*table footer*@
                            <tfoot>
                                <tr class="brown-text lighten-1">
                                    <th>Date</th>
                                    <th>Procedures</th>
                                    <th>Tooth #</th>
                                    <th>Dentist</th>
                                    <th>Amount</th>
                                    <th>Paid</th>
                                    <th>Balance</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    @*Dental Chart*@
                    <div id="dent" class="row m-0 containerOverflow-2" style="padding:5px 20px 0 0;">

                        <div class="row">
                            <a ng-show="isUserAdmin" class="edit-btn right modal-trigger" data-target="modal-dental-chart">EDIT CHART</a>
                        </div>

                        <div class="row m-0 center">
                            <img id="dentalChartMain"
                                 ng-src="{{selectedPatient.dentalChartLink || 'https://placehold.co/2550x3300'}}"
                                 alt="Dental Chart"
                                 style="max-height: 47rem" />
                        </div>

                    </div>

                    @*Forms*@
                    <div id="forms" class="row m-0">
                        <div class="row">
                            <a ng-show="isUserAdmin" class="edit-btn right modal-trigger" data-target="modal-add-form">ADD FORM</a>
                        </div>

                        <table id="patientForms" class="hover tableClk">
                            @*table headers*@
                            <thead>
                                <tr class="brown-text lighten-1">
                                    <th>Date</th>
                                    <th>Form</th>
                                    <th colspan="2">Dentist</th>
                                </tr>
                            </thead>
                            @*table content*@
                            <tbody>
                                <tr data-href="#" title="View Form" class="clkPointer">
                                    <td>MM/DD/YYYY</td>
                                    <td>Form</td>
                                    <td>Name</td>
                                    @*edit and delete button*@
                                    <td>
                                        <a ng-show="isUserAdmin" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped m-0 redBtn modal-trigger" data-target="modal-delete-form" data-position="bottom" data-tooltip="Delete Form">
                                            <i class="material-icons brown-text lighten-1">delete</i>
                                        </a>
                                        <a ng-show="isUserAdmin" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped m-0 modal-trigger" data-target="modal-edit-form" data-position="bottom" data-tooltip="Edit Form" style="margin-right: 0.5rem !important"><i class="material-icons brown-text lighten-1">edit</i></a>
                                    </td>
                                </tr>
                            </tbody>
                            @*table footer*@
                            <tfoot>
                                <tr class="brown-text lighten-1">
                                    <th>Date</th>
                                    <th>Form</th>
                                    <th>Dentist</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    @*post op*@
                    <div id="postOp" class="row m-0">

                        <div class="row">
                            <div class="card white z-depth-0" style="max-height: 47rem; overflow-y: auto">
                                <div class="card-content brown-text lighten-1">
                                    @*post op title*@
                                    <span class="card-title bold">Post OP</span>
                                    <div class="divider"></div>
                                    @*post op content*@
                                    <p>Nothing here.</p>
                                </div>
                            </div>
                        </div>
                        @*edit and delete buttons*@
                        <div class="row m-0 left">
                            <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped modal-trigger" data-target="modal-edit-postOp" data-position="bottom" data-tooltip="Edit Post Op" style="margin-right: 0.5rem !important"><i class="material-icons brown-text lighten-1">edit</i></a>
                            <a class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped redBtn modal-trigger" data-target="modal-delete-postOp" data-position="bottom" data-tooltip="Delete Post Op">
                                <i class="material-icons brown-text lighten-1">delete</i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@*Patient info*@
<div id="modal-patient-info" class="modal modal-fixed-footer patient-info-modal">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Edit Patient Information</h5>

        <div class="row">
            @*Firstname*@
            <div class="col s4">
                <label class="custom-label">
                    First Name
                    <input type="text" class="custom-input" placeholder="First Name" ng-model="selectedPatient.firstName">
                </label>
            </div>

            @*Middlename*@
            <div class="col s4">
                <label class="custom-label">
                    Middle Name
                    <input type="text" class="custom-input" placeholder="Middle Name" ng-model="selectedPatient.middleName">
                </label>
            </div>

            @*Lastname*@
            <div class="col s4">
                <label class="custom-label">
                    Last Name
                    <input type="text" class="custom-input" placeholder="Last Name" ng-model="selectedPatient.lastName">
                </label>
            </div>
        </div>


        <div class="row">
            <div class="col s6">
                @*Gender*@
                <label class="custom-label">
                    Gender
                    <select class="browser-default custom-input"
                            ng-model="selectedPatient.genderID"
                            ng-options="g.genderID as g.description for g in genderArray"
                            style="margin-bottom:15px;">
                        <option value="" disabled>Select Gender</option>
                    </select>
                </label>

                @*Birthday*@
                <label class="custom-label">
                    Birthday
                    <div style="position: relative;">
                        <input id="birthDate"
                               ng-model="selectedPatient.birthDateRaw"
                               type="date"
                               class="custom-input"
                               placeholder="Select Birthday"
                               max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                </label>

                @*Address*@
                <label class="custom-label">
                    Address
                    <input type="text" class="custom-input" placeholder="Address" ng-model="selectedPatient.address">
                </label>

                @*Nationality*@
                <label class="custom-label">
                    Nationality
                    <input type="text" class="custom-input" placeholder="Nationality" ng-model="selectedPatient.nationality">
                </label>

                @*Guardian*@
                <label class="custom-label">
                    Guardian
                    <input type="text" class="custom-input" placeholder="Guardian" ng-model="selectedPatient.guar">
                </label>

                @*Email*@
                <label class="custom-label">
                    Email Address
                    <input type="text" class="custom-input" placeholder="Email Address" ng-model="selectedPatient.email">
                </label>
            </div>

            <div class="col s6">
                @*Civil status*@
                <label class="custom-label">
                    Civil Status
                    <select class="browser-default custom-input" style="margin-bottom:15px;" ng-model="selectedPatient.civilStatus" required>
                        <option value="" disabled selected>Select Status</option>
                        <option value="Single">Single</option>
                        <option value="Married">Married</option>
                        <option value="Widowed">Widowed</option>
                    </select>
                </label>

                @*Occupation*@
                <label class="custom-label">
                    Occupation
                    <input type="text" class="custom-input" placeholder="Occupation">
                </label>

                @*Religion*@

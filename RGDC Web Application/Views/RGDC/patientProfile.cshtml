@*medical history modal*@
<div id="medical-history-modal" class="modal modal-fixed-footer med-his-modal">
    <div class="medical-history-container">
        <h5 class="modal-form-title">Edit Medical History</h5>

        <div class="form-header">
            @*previous physician info*@
            <div class="row" style="padding: 0 10px; flex:1">
                <p style="display: flex; align-items: center; white-space: nowrap; gap: 10px; margin:0 0 -15px 0;">
                    <span>Name of previous physician:</span>
                    <input type="text" class="custom-input" style="flex: 1;" placeholder="Name of previous physician" ng-model="prevPhy">
                </p>

                <p style="display: flex; align-items: center; white-space: nowrap; gap: 10px; margin: -15px 0 -15px 0;">
                    <span>Physician's office:</span>
                    <input type="text" class="custom-input" style="flex: 1;" placeholder="Physician's office" ng-model="prevPhyOffice">
                </p>

                <p style="display: flex; align-items: center; white-space: nowrap; gap: 10px; margin: -15px 0 5px 0;">
                    <span>Physician's contact:</span>
                    <input type="text" class="custom-input" style="flex: 1;" placeholder="Physician's contact" ng-model="prevPhyContact">
                </p>
            </div>

        </div>
        <hr class="form-divider" style="margin-bottom:10px;">

        @*medical history*@
        <ol class="medical-questions">
            <li>
                @*Are you in good health? *@
                <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                    <span>Are you in good health?</span>

                    <div style="display: flex; gap: 15px; margin-right:-25px;">
                        <label style="display: flex; align-items: center;">
                            <input name="1" value="Yes" type="radio" class="with-gap" ng-model="medical.history.goodHealth" />
                            <span>Yes</span>
                        </label>
                        <label style="display: flex; align-items: center;">
                            <input name="1" type="radio" value="No" class="with-gap" ng-model="medical.history.goodHealth" />
                            <span>No</span>
                        </label>
                    </div>
                </div>
            </li>
            <li>
                @*Are you under medical treatment now? *@
                <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                    <span>Are you under medical treatment now?</span>

                    <div style="display: flex; gap: 15px; margin-right: -25px;">
                        <label style="display: flex; align-items: center;">
                            <input name="2" type="radio" value="Yes" class="with-gap" ng-model="medical.history.underTreatment" />
                            <span>Yes</span>
                        </label>
                        <label style="display: flex; align-items: center;">
                            <input name="2" type="radio" value="No" class="with-gap" ng-model="medical.history.underTreatment" />
                            <span>No</span>
                        </label>
                    </div>
                </div>
            </li>
            <li>
                @*Have you ever had a serious illness or surgical operation? *@
                <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                    <span>Have you ever had a serious illness or surgical operation?</span>

                    <div style="display: flex; gap: 15px; margin-right: -25px;">
                        <label style="display: flex; align-items: center;">
                            <input name="3" type="radio" value="Yes" class="with-gap" ng-model="medical.history.seriousIllness" />
                            <span>Yes</span>
                        </label>
                        <label style="display: flex; align-items: center;">
                            <input name="3" type="radio" value="No" class="with-gap" ng-model="medical.history.seriousIllness" />
                            <span>No</span>
                        </label>
                    </div>
                </div>
            </li>
            <li>
                @*Have you ever been hospitalized? *@
                <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                    <span>Have you ever been hospitalized?</span>

                    <div style="display: flex; gap: 15px; margin-right: -25px;">
                        <label style="display: flex; align-items: center;">
                            <input name="4" type="radio" value="Yes" class="with-gap" ng-model="medical.history.hospitalized" />
                            <span>Yes</span>
                        </label>
                        <label style="display: flex; align-items: center;">
                            <input name="4" type="radio" value="No" class="with-gap" ng-model="medical.history.hospitalized" />
                            <span>No</span>
                        </label>
                    </div>
                </div>
            </li>
            <li>
                @*Are you taking prescription/non-prescription medication? *@
                <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                    <span>Are you taking prescription/non-prescription medication?</span>

                    <div style="display: flex; gap: 15px; margin-right: -25px;">
                        <label style="display: flex; align-items: center;">
                            <input name="5" type="radio" value="Yes" class="with-gap" ng-model="medical.history.prescription" />
                            <span>Yes</span>
                        </label>
                        <label style="display: flex; align-items: center;">
                            <input name="5" type="radio" value="No" class="with-gap" ng-model="medical.history.prescription" />
                            <span>No</span>
                        </label>
                    </div>
                </div>
            </li>
            <li>
                @*Are you taking tobacco products? *@
                <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                    <span>Are you taking tobacco products?</span>

                    <div style="display: flex; gap: 15px; margin-right: -25px;">
                        <label style="display: flex; align-items: center;">
                            <input name="6" type="radio" value="Yes" class="with-gap" ng-model="medical.history.tobacco" />
                            <span>Yes</span>
                        </label>
                        <label style="display: flex; align-items: center;">
                            <input name="6" type="radio" value="No" class="with-gap" ng-model="medical.history.tobacco" />
                            <span>No</span>
                        </label>
                    </div>
                </div>
            </li>
            <li>
                @*Do you use alcohol, cocaine, or other dangerous drugs? *@
                <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                    <span>Do you use alcohol, cocaine, or other dangerous drugs?</span>

                    <div style="display: flex; gap: 15px; margin-right: -25px;">
                        <label style="display: flex; align-items: center;">
                            <input name="7" type="radio" value="Yes" class="with-gap" ng-model="medical.history.drugs" />
                            <span>Yes</span>
                        </label>
                        <label style="display: flex; align-items: center;">
                            <input name="7" type="radio" value="No" class="with-gap" ng-model="medical.history.drugs" />
                            <span>No</span>
                        </label>
                    </div>
                </div>
            </li>
            <li style="margin: -10px 0 10px 0;">
                @*Allergies*@
                <div style="display: flex; align-items: center; white-space: nowrap; gap: 10px;">
                    <span>Allergies:</span>
                    <input type="text" class="custom-input" style="flex: 1; margin-right: -30px;" placeholder="Allergies..." ng-model="medical.history.allergies">
                </div>
            </li>
            <li style="margin: -25px 0 0 0;">
                @*Bleeding time:*@
                <div style="display: flex; align-items: center; white-space: nowrap; gap: 10px;">
                    <span>Bleeding time:</span>
                    <input type="text" class="custom-input" style="flex: 1; margin-right: -30px;" placeholder="Bleeding time..." ng-model="medical.history.bleedingTime">>
                </div>
            </li>

            <li>
                For women only:
                <div class="women-only-options">
                    <label><input type="checkbox" ng-model="medical.history.pregnant" class="filled-in" /><span>Are you pregnant?</span></label>
                    <label><input type="checkbox" ng-model="medical.history.nursing" class="filled-in" /><span>Are you nursing?</span></label>
                    <label><input type="checkbox" ng-model="medical.history.pills" class="filled-in" /><span>Are you taking birth control pills?</span></label>
                </div>
            </li>

            <li style="margin: -10px 0 10px 0;">
                @*Blood ppressure*@
                <div style="display: flex; align-items: center; white-space: nowrap; gap: 10px;">
                    <span>Blood pressure:</span>
                    <input type="text" class="custom-input" ng-model="medical.history.bloodPressure" style="flex: 1; margin-right: -30px;" placeholder="Blood pressure...">
                </div>
            </li>
            <li style="margin: -25px 0 0 0;">
                @*Blood type:*@
                <div style="display: flex; align-items: center; white-space: nowrap; gap: 10px;">
                    <span>Blood type:</span>
                    <input type="text" class="custom-input" ng-model="medical.history.bloodType" style="flex: 1; margin-right: -30px;" placeholder="Blood Type...">
                </div>
            </li>
            <li>Do you have or have had any of the following?</li>
        </ol>

        <div class="checkbox-grid">


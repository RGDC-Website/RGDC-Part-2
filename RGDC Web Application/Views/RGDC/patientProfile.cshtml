                        <div class="row">
                            <a ng-show="isUserAdmin && !isUserStaff" class="edit-btn right modal-trigger" data-target="modalAddForm">ADD FORM</a>
                        </div>

                        <table id="patientForms" class="hover tableClk" ng-if="patientFormsReady">-->

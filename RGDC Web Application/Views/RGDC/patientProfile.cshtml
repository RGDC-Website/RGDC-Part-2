@*Patient information form*@
<div id="modalEditPatientInfo" class="modal patientInformationForm-modal containerOverflow-2">
    <div>
        <h5 class="modal-form-title">Edit Patient Information</h5>

        <form>
            <div class="row">
                <div class="col s4">
                    @*Photo upload*@
                    <div class="row s4 center-align" style="margin-top: 2.5vh; margin-left: 2.5vh;">
                        <div class="col s12">
                            <div class="photo-box">
                                <img ng-if="selectedPatient && (selectedPatient._photoPreview || selectedPatient.photoLink)"
                                     ng-src="{{ selectedPatient._photoPreview || selectedPatient.photoLink }}"
                                     alt="Profile" />
                                <i class="material-icons photo-placeholder-icon" ng-if="!selectedPatient || (!selectedPatient._photoPreview && !selectedPatient.photoLink)">image</i>
                            </div>
                            <input id="patient_photo_input"
                                   type="file"
                                   accept="image/*"
                                   style="display:none"
                                   onchange="angular.element(this).scope().onPatientPhotoSelected(this.files)" />
                        </div>
                    </div>
                </div>

                <div class="col s8">
                    <div class="row">
                        @*First name*@
                        <div class="col s6">
                            <p class="custom-label">First Name <span class="required-mark">*</span></p>
                            <input type="text"
                                   class="custom-input"
                                   maxlength="150"
                                   ng-model="selectedPatient.firstName"
                                   oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')"
                                   placeholder="Juan"
                                   required>
                        </div>
                        @*MIddle name*@
                        <div class="col s6">
                            <p class="custom-label">Middle Name</p>
                            <input type="text"
                                   class="custom-input"
                                   maxlength="150"
                                   ng-model="selectedPatient.middleName"
                                   oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')"
                                   placeholder="Mercado"
                                   required>
                        </div>
                    </div>
                    <div class="row">
                        @*Last name*@
                        <div class="col s12">
                            <p class="custom-label">Last Name <span class="required-mark">*</span></p>
                            <input type="text" class="custom-input"
                                   maxlength="150"
                                   ng-model="selectedPatient.lastName"
                                   oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')"
                                   placeholder="Dela Cruz"
                                   required>
                        </div>
                    </div>
                </div>
            </div>

            @*Email*@
            <div class="row">
                <div class="col s12">
                    <p class="custom-label">Email <span class="required-mark">*</span></p>
                    <input type="text" class="custom-input"
                           disabled
                           ng-model="selectedPatient.email"
                           placeholder="juandlc@gmail.com" maxlength="150">

                </div>
            </div>

            <div class="row">
                @*Gender*@
                <div class="col s3">
                    <p class="custom-label">Gender <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input"
                            ng-model="selectedPatient.genderID"
                            ng-options="g.genderID as g.description for g in genderArray"
                            required>
                        <option value="" disabled>Select Gender</option>
                    </select>
                </div>
                @*Birthdate*@
                <div class="col s3">
                    <p class="custom-label">Birth Date <span class="required-mark">*</span></p>
                    <div class="datepicker-wrapper">
                        <input id="birthDate"
                               type="text"
                               ng-model="selectedPatient.birthDate"
                               class="datepicker custom-input"
                               readonly
                               max="@DateTime.Now.ToString("yyyy-MM-dd")"
                               required>
                        <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                    </div>
                </div>
                <div class="col s3">
                    @*Civil status*@
                    <p class="custom-label">Civil Status <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input" required ng-model="selectedPatient.civilStatus">
                        <option value="" disabled selected>Select Status</option>
                        <option value="1">Single</option>
                        <option value="2">Married</option>
                        <option value="3">Widowed</option>
                        <option value="4">Legally Separated</option>
                        <option value="5">Annulled/Void</option>
                        <option value="6">Divorced</option>
                    </select>
                </div>
                <div class="col s3">
                    @*Contact number*@
                    <p class="custom-label">Contact Number <span class="required-mark">*</span></p>
                    <input id="contactNumber"
                           type="text"
                           ng-model="selectedPatient.contactNumber"
                           class="custom-input"
                           placeholder="09XX-XXX-XXXX"
                           maxlength="11"
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                           required>
                </div>
            </div>

            <div class="row">
                <div class="col s6">
                    @*Address Line 1*@
                    <p class="custom-label">Address Line 1 <span class="required-mark">*</span></p>
                    <input id="address"
                           type="text"
                           ng-model="selectedPatient.line1"
                           class="custom-input"
                           maxlength="250"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')"
                           placeholder="street address, p.o. box, company name, c/o"
                           required>
                </div>

                <div class="col s6">
                    @*Address Line 2*@
                    <p class="custom-label">Address Line 2 <span class="required-mark">*</span></p>
                    <input id="address"
                           type="text"
                           ng-model="selectedPatient.line2"
                           class="custom-input"
                           maxlength="250"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')"
                           placeholder="appartment, suite, unit, building, floor, etc"
                           required>
                </div>
            </div>

            <div class="row">
                <div class="col s3">
                    @*City*@
                    <p class="custom-label">City <span class="required-mark">*</span></p>
                    <input id="address"
                           type="text"
                           class="custom-input"
                           ng-model="selectedPatient.city"
                           maxlength="250"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')"
                           placeholder="city"
                           required>
                </div>

                <div class="col s3">
                    @*state/province/region*@
                    <p class="custom-label">State/Province/Region <span class="required-mark">*</span></p>
                    <input id="address"
                           type="text"
                           class="custom-input"
                           ng-model="selectedPatient.state"
                           maxlength="250"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')"
                           placeholder="state/province/region"
                           required>
                </div>

                <div class="col s3">
                    @*zip/postal code*@
                    <p class="custom-label">Zip/Postal Code <span class="required-mark">*</span></p>
                    <input id="address"
                           type="text"
                           class="custom-input"
                           maxlength="250"
                           ng-model="selectedPatient.postal"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')"
                           placeholder="zip/postal code"
                           required>
                </div>

                <div class="col s3">
                    @*country*@
                    <p class="custom-label">Country <span class="required-mark">*</span></p>
                    <input id="address"
                           type="text"
                           class="custom-input"
                           maxlength="250"
                           ng-model="selectedPatient.country"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')"
                           placeholder="country"
                           required>
                </div>
            </div>

            <div class="row">
                <div class="col s4">
                    @*Occupation*@
                    <p class="custom-label">Occupation <span class="required-mark">*</span></p>
                    <input id="occupation"
                           type="text"
                           class="custom-input"
                           ng-model="selectedPatient.occupation"
                           placeholder="Doctor"
                           maxlength="50"
                           required>
                </div>

                <div class="col s4">
                    @*Religion*@
                    <p class="custom-label">Religion <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input" ng-model="selectedPatient.religion">
                        <option disabled selected>Select your Religion</option>
                        <option value="Roman Catholic">Roman Catholic</option>
                        <option value="Islam">Islam</option>
                        <option value="Iglesia Ni Cristo">Iglesia Ni Cristo</option>
                        <option value="Others">Others</option>
                    </select>
                </div>

                <div class="col s4">
                    @*Nationality*@
                    <p class="custom-label">Nationality <span class="required-mark">*</span></p>
                    <select class="browser-default custom-input" ng-model="selectedPatient.nationality">
                        <option disbaled selected>Select your Nationality</option>
                        <option ng-repeat="n in nationalities" value="{{n}}">{{n}}</option>
                    </select>
                </div>
            </div>

            <div class="row">
                @*Guradian*@
                <div class="col s4">
                    <p class="custom-label">Guradian <span class="required-mark">*</span></p>
                    <input type="text"
                           ng-model="selectedPatient.guar"
                           class="custom-input"
                           maxlength="150"
                           oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')" />
                </div>

                @*Guradian Number*@
                <div class="col s4">
                    <p class="custom-label">Guradian's Contact Number' <span class="required-mark">*</span></p>
                    <input type="text"
                           class="custom-input"
                           ng-model="selectedPatient.guarNum"
                           maxlength="150"
                           oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')" />
                </div>

                @*Refferal*@
                <div class="col s4">
                    <p class="custom-label">Referral (if any)</p>
                    <input type="text"
                           ng-model="selectedPatient.referral"
                           class="custom-input"
                           maxlength="50"
                           oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')">
                </div>
            </div>
        </form>
    </div>

    @*Submit , upload, cancel*@
    <div class="modal-footer" style="margin-top:2.5vh">
        <button type="button" class="edit-btn left" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh" ng-click="triggerPatientPhotoInput()">UPLOAD</button>
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh .5vh -1.2vh 0">CANCEL</button>
        <button type="submit" class="edit-btn" style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0" ng-click="updatePatientProfile()">SAVE</button>
        @*New Password*@
        <!--<div class="forgot-password-container right" ng-show="isUserPatient" style="margin: -8vh 0 0 0 !important;" ">
            <a href="#" class="forgot-link modal-trigger" data-target="modalOTP" style="margin: 0 3vh 0 0 !important; font-weight:500">Set New Password?</a>
        </div>-->
    </div>
</div>


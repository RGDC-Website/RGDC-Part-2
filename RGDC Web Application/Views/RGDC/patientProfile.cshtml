<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (typeof M === 'undefined' || !M.Datepicker) return;

        var dateElems = document.querySelectorAll('.datepicker');
        var dateOptions = {
            format: 'mmmm dd, yyyy',
            yearRange: 100,
            showClearBtn: true,
            container: document.body
        };

        var instances = M.Datepicker.init(dateElems, dateOptions);
        document.querySelectorAll('.datepicker-icon, .datepicker-trigger').forEach(function (icon) {
            icon.addEventListener('click', function (e) {
                var input = icon.closest('.datepicker-wrapper') ? icon.closest('.datepicker-wrapper').querySelector('.datepicker') : null;
                if (!input) {
                    var sib = icon.previousElementSibling || icon.nextElementSibling;
                    if (sib && sib.classList && sib.classList.contains('datepicker')) input = sib;
                }
                if (input) {
                    var inst = M.Datepicker.getInstance(input);
                    if (inst) inst.open();
                    else input.focus();
                }
            });
        });

        var modalElems = document.querySelectorAll('.modal');
        modalElems.forEach(function (modal) {
            modal.addEventListener('modalOpen', function () {
            });

            try {
                var mi = M.Modal.getInstance(modal);
                if (mi) {
                    var origOpen = mi.open;
                    mi.open = function () {
                        M.Datepicker.init(dateElems, dateOptions);
                        origOpen.apply(mi, arguments);
                    };
                }
            } catch (_) { /* ignore if modal instance unavailable */ }
        });
    });
</script>

@*ADD Progress botes*@
<div id="modalAddProgNotes" class="modal progNotes-modal">
    <div class="modal-content">
        <h5 class="modal-form-title" style="margin-bottom:15px;">Add Progress Note</h5>


        <form name="addProgForm" novalidate ng-submit="addProgressNotes()">
            <div class="row">
                <div class="col s6">
                    @*Date*@
                    <label class="custom-label">Date <span class="required-mark">*</span></label>
                    <div class="datepicker-wrapper">
                        <input id="date" name="date" type="text" class="datepicker custom-input" placeholder="Date"
                               ng-model="progNote_date" required>
                        <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                    </div>
                    <span class="helper-text" style="color:#d32f2f" ng-show="addProgForm.date.$invalid && (addProgForm.date.$touched || addProgForm.$submitted)">
                        Date is required
                    </span>

                    @*Dentist*@
                    <label class="custom-label" ng-init="getDentistOwner()">
                        Dentist
                        <span class="required-mark">*</span>
                        <select name="dentist" ng-model="progNote_accID" class="browser-default custom-input"
                                ng-options="d.accID as d.fullName for d in dentistArrays track by d.accID" required>
                            <option value="" disabled selected>Select Dentist</option>
                        </select>
                    </label>
                    <span class="helper-text" style="color:#d32f2f" ng-show="addProgForm.dentist.$invalid && (addProgForm.dentist.$touched || addProgForm.$submitted)">
                        Dentist is required
                    </span>

                    @*Amount*@
                    <label class="custom-label">
                        Amount
                        <span class="required-mark">*</span>
                        <input name="amount" type="number" class="custom-input" placeholder="Amount"
                               ng-model="progNote_amount" step="0.01" min="0" required
                               oninput="this.value = this.value === '' ? '' : this.value.replace(/[^0-9.]/g,'');">
                    </label>
                    <span class="helper-text" style="color:#d32f2f" ng-show="addProgForm.amount.$invalid && (addProgForm.amount.$touched || addProgForm.$submitted)">
                        <span ng-show="addProgForm.amount.$error.required">Amount is required</span>
                        <span ng-show="addProgForm.amount.$error.number || addProgForm.amount.$error.min">Enter a valid non-negative amount</span>
                    </span>
                </div>

                <div class="col s6">
                    @*Procedures*@
                    <label class="custom-label">
                        Procedures
                        <span class="required-mark">*</span>
                        <input name="procedures" type="text" class="custom-input" placeholder="Procedures"
                               ng-model="progNote_procedures" required>
                    </label>
                    <span class="helper-text" style="color:#d32f2f" ng-show="addProgForm.procedures.$invalid && (addProgForm.procedures.$touched || addProgForm.$submitted)">
                        Procedures is required
                    </span>

                    @*Tooth Number*@
                    <label class="custom-label">
                        Tooth Number
                        <input name="toothNumber" type="number" class="custom-input" placeholder="Tooth Number"
                               ng-model="progNote_toothNumber" min="1" max="32" step="1" required
                               oninput="this.value = this.value.replace(/[^0-9]/g,''); if(this.value){ this.value = Math.max(1, Math.min(32, parseInt(this.value)||0)); }">
                    </label>


                    @*Paid*@
                    <label class="custom-label">
                        Paid
                        <span class="required-mark">*</span>
                        <input name="paid" type="number" class="custom-input" placeholder="Paid"
                               ng-model="progNote_paid" step="0.01" min="0" required
                               oninput="this.value = this.value === '' ? '' : this.value.replace(/[^0-9.]/g,'');">
                    </label>
                    <span class="helper-text" style="color:#d32f2f" ng-show="addProgForm.paid.$invalid && (addProgForm.paid.$touched || addProgForm.$submitted)">
                        <span ng-show="addProgForm.paid.$error.required">Paid is required</span>
                        <span ng-show="addProgForm.paid.$error.number || addProgForm.paid.$error.min">Enter a valid non-negative paid amount</span>
                    </span>
                </div>
            </div>
        </form>
    </div>

    <div class="modal-footer">
        <button class="modal-close cancel-btn" style="font-weight: 500; margin: -.8vh 0 -1.2vh 2.3vh">CANCEL</button>


        <button type="submit" class="edit-btn"
                style="font-weight: 500; margin: -.8vh 2.3vh -1.2vh 0"
                ng-click="addProgressNotes()"
                ng-disabled="addProgForm.$invalid">
            ADD
        </button>
    </div>
</div>


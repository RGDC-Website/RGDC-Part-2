@{
    Layout = "~/Views/Shared/_logInSignInLayout.cshtml";
}

<div class="split-container">

    <div class="right-side" style="display: flex; flex-direction: column; justify-content: center; align-items: center;">

        <img src="@Url.Content("~/Content/images/dentalAppLogo.png")" alt="Logo" style="width: 500px; height: auto; margin-bottom: 30px;" />

    </div>

    <div class="right-side" style="display: flex; flex-direction: column; justify-content: center; align-items: center;">

        <div style="width: 80%; max-width: 500px; text-align:center;">
            <h2 class="signup-title">Sign Up</h2>

            <form>

                @*Email*@
                <div class="input-field lbl-required">
                    <input id="email"
                           ng-model="signUp_email"
                           type="email"
                           placeholder="Email *"
                           maxlength="150"
                           oninput="this.value = this.value.replace(/^A-Za-z0-9 ._-/g, '')"
                           required>
                </div>

                @* Password Field *@
                <div class="input-field">
                    <input id="password"
                           ng-model="signUp_password"
                           type="password"
                           placeholder="Password"
                           maxlength="50"
                           ng-change="checkPasswordStrength()"
                           required>

                    @* Strength Indicator - Only shows when user starts typing *@
                    <!--<span class="helper-text"
                          ng-class="strengthColor"
                          ng-show="signUp_password.length > 0"
                          style="font-weight:bold; font-size: 12px;">
                        Strength: {{ passwordStrength }}
                    </span>-->
                </div>

                @* Confirm Password Field *@
                <div class="input-field">
                    <input id="confPassword"
                           ng-model="signUp_confPassword"
                           type="password"
                           placeholder="Confirm password"
                           maxlength="50"
                           required>

                    @* Mismatch Error - Shows instantly if they don't match *@
                    <!--<span class="helper-text red-text"
                          ng-show="signUp_password !== signUp_confPassword && signUp_confPassword.length > 0">
                        Passwords do not match!
                    </span>-->
                </div>

                @*Already have an account*@
                <div class="forgot-password-container">
                    <a href="#" class="forgot-link">Already have an account?</a>
                </div>

                @*Agree to termz and condz*@
                <div class="checkbox-container">
                    <label>
                        <input type="checkbox" class="filled-in" required />
                        <span>I Agree to the terms and conditions</span>
                    </label>
                </div>

                @*Sign up BTN*@
                <button class="logSignBtn modal-trigger"
                        data-target="patientInformationForm"
                        type="submit"
                        ng-disabled="signUp_password !== signUp_confPassword || passwordStrength == 'Weak'">
                    Sign Up
                </button>

                <div class="login-divider">
                    <span>or sign up with</span>
                </div>

                @*Google sign up*@
                <div class="social-login-container">
                    <a href="#" class="google-btn">
                        <img src="~/Content/images/google.png" alt="Google" />
                    </a>
                </div>
            </form>
        </div>

    </div>

    @*Patient information form*@
    <div id="patientInformationForm" class="modal">
        <div class="modal-content">
            <h5 class="modal-form-title">Patient Information Form</h5>

            <form>
                <div class="row">
                    <div class="col s4">
                        @*Photo upload*@
                        <div class="row s4 center-align photo-upload-container">
                            <div class="col s12">
                                <div class="photo-box">
                                    <i class="material-icons photo-placeholder-icon">image</i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col s8">
                        <div class="row">
                            @*First name*@
                            <div class="col s6">
                                <p class="custom-label">First Name <span class="required-mark">*</span></p>
                                <input type="text" 
                                       class="custom-input" 
                                       maxlength="150" 
                                       oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')" 
                                       required>
                            </div>
                            @*MIddle name*@
                            <div class="col s6">
                                <p class="custom-label">Middle Name <span class="required-mark">*</span></p>
                                <input type="text" 
                                       class="custom-input" 
                                       maxlength="150" 
                                       oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')" 
                                       required>
                            </div>
                        </div>
                        <div class="row">
                            @*Last name*@
                            <div class="col s12">
                                <p class="custom-label">Last Name <span class="required-mark">*</span></p>
                                <input type="text" class="custom-input" 
                                       maxlength="150" 
                                       oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')" 
                                       required>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    @*Gender*@
                    <div class="col s3">
                        <p class="custom-label">Gender <span class="required-mark">*</span></p>
                        <select class="browser-default custom-input" required>
                            <option value="" disabled selected>Select Gender</option>
                            <option value="1">Male</option>
                            <option value="2">Female</option>
                            <option value="3">Others</option>
                        </select>
                    </div>
                    @*Birthdate*@
                    <div class="col s3">
                        <p class="custom-label">Birth Date <span class="required-mark">*</span></p>
                        <div class="datepicker-wrapper">
                            <input id="birthDate" 
                                   ng-model="signUp_birthDate" 
                                   type="text" 
                                   class="datepicker custom-input"
                                   readonly
                                   required>
                            <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                        </div>
                    </div>
                    <div class="col s3">
                        @*Civil status*@
                        <p class="custom-label">Civil Status <span class="required-mark">*</span></p>
                        <select class="browser-default custom-input" required>
                            <option value="" disabled selected>Select Status</option>
                            <option value="1">Single</option>
                            <option value="2">Married</option>
                            <option value="3">Widowed</option>
                        </select>
                    </div>
                    <div class="col s3">
                        @*Contact number*@
                        <p class="custom-label">Contact Number <span class="required-mark">*</span></p>
                        <input id="contactNumber"
                               ng-model="signUp_contactNumber"
                               type="text" 
                               class="custom-input" 
                               placeholder="09XX-XXX-XXXX" 
                               maxlength="13" 
                               oninput="this.value = this.value.replace(/[^0-9]/g, '')" 
                               required>
                    </div>
                </div>

                <div class="row">
                    <div class="col s12">
                        @*Address*@
                        <p class="custom-label">Address <span class="required-mark">*</span></p>
                        <input id="address" 
                               type="text" 
                               class="custom-input"
                               maxlength="250" 
                               oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')" 
                               required>
                    </div>
                </div>

                <div class="row">
                    @*Current physician*@
                    <div class="col s4">
                        <p class="custom-label">Current Physician</p>
                        <input type="text" 
                               class="custom-input" 
                               maxlength="150" 
                               oninput="this.value = this.value.replace(/[^A-Za-z .]/g, '')">
                    </div>
                    @*Refferal*@
                    <div class="col s4">
                        <p class="custom-label">Referral (if any)</p>
                        <input type="text" 
                               class="custom-input"
                               maxlength="50" 
                               oninput="this.value = this.value.replace(/[^A-Za-z0-9 ,.-]/g, '')">
                    </div>
                    @*Last visit*@
                <div class="col s4">
                    <p class="custom-label">Last Visit</p>
                    <div class="datepicker-wrapper">
                        <input id="lastVisit"
                               ng-model="signUp_lastVisit"
                               type="text" 
                               class="datepicker custom-input"
                               readonly
                               required>
                        <i class="material-icons datepicker-icon datepicker-trigger">event</i>
                    </div>
                </div>

                </div>

                @*Agreementz*@
                <div class="row agreement-section center-align">
                    <label class="agreement-label">
                        <input type="checkbox" class="filled-in" required />
                        <span class="agreement-text">
                            I have read and agree to the
                            <a href="#" data-target="termsConditions" class="agreement-link modal-trigger">Terms and Conditions</a> and
                            <a href="#" data-target="dataPrivacy" class="agreement-link modal-trigger">Data Privacy Policy</a>
                        </span>
                        <span class="required-mark">*</span>
                    </label>
                </div>
            </form>
        </div>

        @*Submit or cancel*@
        <div class="modal-footer patient-modal-footer">
            <a href="#!" class="modal-close btn btn-cancel">Cancel</a>
            <button type="submit" class="btn btn-next">Submit</button>
        </div>
    </div>

    @*Termz and condz*@
    <div id="termsConditions" class="modal">
        <div class="modal-content center-align">
            <h4 class="modal-form-title-alt">Terms and Conditions</h4>
            <h5 class="modal-form-title">Reyes-Guansing Dental Clinic (RGDC) Dental Management System</h5>

            <div class="terms-scroll-container preserve-format">
                Last Updated: December 17, 2025
                Effective Date: [Date]

                1. ACCEPTANCE OF TERMS
                Welcome to the Reyes-Guansing Dental Clinic (RGDC) Dental Management System. These Terms and Conditions ("Terms", "T&C", or "Agreement") constitute a legally binding agreement between you ("User", "You", or "Your") and Reyes-Guansing Dental Clinic ("RGDC", "We", "Us", or "Our") governing your access to and use of the RGDC Dental Management System website and all associated services (collectively, the "System" or "Services").
                By creating an account, you explicitly agree to be bound by these Terms and Conditions. During the account registration process, you must check the acknowledgment box confirming that you have read, understood, and agree to these Terms before your account can be created. Your agreement is timestamped and stored for legal compliance purposes. If you do not agree to these Terms, you must not create an account or use the System.

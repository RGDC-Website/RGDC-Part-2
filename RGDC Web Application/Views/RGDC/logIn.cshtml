@{
    Layout = "~/Views/Shared/_logInSignInLayout.cshtml";
}

<div class="split-container">

    <div class="left-side">

    </div>

    <div class="right-side" style="display: flex; flex-direction: column; justify-content: center; align-items: center;">

        <img src="@Url.Content("~/Content/images/dentalAppLogo.png")" alt="Logo" style="width: 350px; height: auto; margin-bottom: 30px;" />

        <div style="width: 80%; max-width: 500px;">
            <form>
                @*Email*@
                <div class="input-field">
                    <p class="custom-label">Email <span class="required-mark">*</span></p>
                    <input id="email"
                           ng-model="login_email"
                           type="email"
                           placeholder="juandelacruz@gmail.com"
                           maxlength="150"
                           oninput="this.value = this.value.replace(/^A-Za-z0-9 ._-/g, '')"
                           required>
                </div>

                @*Password*@
                <div class="input-field">
                    <p class="custom-label">Password <span class="required-mark">*</span></p>
                    <input id="password"
                           ng-model="login_password"
                           type="password"
                           placeholder="Password"
                           maxlength="150"
                           oninput="this.value = this.value.replace(/^A-Za-z0-9 ._-/g, '')"
                           required>
                </div>

                @*Forgot password?*@
                <div class="forgot-password-container">
                    <a href="#" class="forgot-link modal-trigger" data-target="modal-password">Forgot password?</a>
                </div>

                @*Agree to termz and condz*@
                <div class="checkbox-container">
                    <label>
                        <input type="checkbox" class="filled-in" required />
                        <span>I Agree to the terms and conditions</span>
                    </label>
                </div>

                @*Log in BTN*@
                <button class="logSignBtn" type="submit" ng-click="login()">
                    Log In
                </button>

                @*Dont have an account?*@
                <div class="signup-footer">
                    <span>Don't have an Account yet? </span>
                    <a href="~/Views/RGDC/signUp.cshtml" class="signup-link">Sign Up</a>
                </div>

                <div class="login-divider">
                    <span>or sign in with</span>
                </div>

                @*Google log in*@
            <div class="social-login-container">
                <a href="@Url.Action("ExternalLogin", "RGDC", new { provider = "Google" })" class="google-btn">
                    <img src="~/Content/images/google.png" alt="Google" />
                </a>
            </div>
            </form>
        </div>

    </div>

</div>

@*Forgot Password*@
<div id="modal-password" class="modal password-modal">
    <div class="modal-content">
        <h5 class="modal-form-title">Reset Your Password</h5>
        <p class="signup-footer" style="text-align: left; margin-bottom: -5px;">
            Please check your email for a captcha code.
        </p>

        <div class="row">
            @* otp Section *@
            <div class="col s12">
                <p class="custom-label">OTP Code <span class="required-mark">*</span></p>
                <input type="text" class="custom-input" placeholder="Enter code" style="margin-top: 0 !important;">
                @* Resend Link *@
                <div style="text-align: right; margin-top: 5px; margin-bottom: -20px;">
                    <a href="#!" class="forgot-link">Didn't receive a code? Resend</a>
                </div>
            </div>

            @* New Password Field *@
            <div class="col s12">
                <p class="custom-label">New Password <span class="required-mark">*</span></p>
                <input type="password" class="custom-input" placeholder="Enter new password">
            </div>

            @* Confirm Password Field *@
            <div class="col s12">
                <p class="custom-label">Confirm New Password <span class="required-mark">*</span></p>
                <input type="password" class="custom-input" placeholder="Re-type new password">
            </div>
        </div>
    </div>

    @*cancel and reset*@
    <div class="modal-footer patient-modal-footer">
        <a href="#!" class="modal-close btn btn-cancel">Cancel</a>
        <button type="button" class="btn btn-next">Reset</button>
    </div>
</div>




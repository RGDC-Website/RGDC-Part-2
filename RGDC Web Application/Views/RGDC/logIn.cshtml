@{
    Layout = "~/Views/Shared/_logInSignInLayout.cshtml";
}

<div class="split-container">
   
    <div class="left-side">
        
    </div>

    <div class="right-side" style="display: flex; flex-direction: column; justify-content: center; align-items: center;">

        <img src="@Url.Content("~/Content/images/dentalAppLogo.png")" alt="Logo" style="width: 350px; height: auto; margin-bottom: 30px;" />

        <div style="width: 80%; max-width: 500px;">
            <form>
                @*Email*@
                <div class="input-field">
                    <input id="email" ng-model="login_email" type="email" placeholder="Email">
                </div>

                @*Password*@
                <div class="input-field">
                    <input id="password" ng-model="login_password" type="password" placeholder="Password">
                </div>

                @*Forgot password?*@
                <div class="forgot-password-container">
                    <a href="#" class="forgot-link">Forgot password?</a>
                </div>

                @*Agree to termz and condz*@
                <div class="checkbox-container">
                    <label>
                        <input type="checkbox" class="filled-in" />
                        <span>I Agree to the terms and conditions</span>
                    </label>
                </div>

                @*Log in BTN*@
                <button class="logSignBtn" type="submit">
                    Log In
                </button>

                @*Dont have an account?*@
                <div class="signup-footer">
                    <span>Don't have an Account yet? </span>
                    <a href="#" class="signup-link">Sign Up</a>
                </div>

                <div class="login-divider">
                    <span>or sign in with</span>
                </div>

                @*Google log in*@
                <div class="social-login-container">
                    <a href="#" class="google-btn">
                        <img src="~/Content/images/google.png" alt="Google" />
                    </a>
                </div>
            </form>
        </div>

    </div>


</div>



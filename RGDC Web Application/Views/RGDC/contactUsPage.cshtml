@{
    Layout = "~/Views/Shared/_adminLayout.cshtml";
}
<div class="dashContainer">
    @*top part (welcome, refresh, logout)*@
    <div class="row brown-text lighten-1" style="margin-top: 1rem">
        @*user name*@
        <div class="col l8"><h4 class="bold">Contact Us</h4></div>
        @*refresh and logout buttons*@
        <div class="col hide-on-med-and-down l4">
            <span class="right">
                <div class="col valign-wrapper"><a href="#" class="btn-floating btn-medium waves-effect waves-light brown lighten-4 p-0 smallBtn tooltipped" ng-click="logOut()" data-position="bottom" data-tooltip="Logout"> <i class="material-icons brown-text lighten-1">logout</i></a></div>
            </span>
        </div>
    </div>


    @*socials*@
    <div class="row">
        @*fb card*@
        <div class="col s12 m3 l3">
            <div class="card grey lighten-2 center">
                <div class="card-content brown-text lighten-1">
                    <a href="https://www.facebook.com/profile.php?id=100089697375149" target="_blank">
                        <img src="~/Content/images/facebook.png" alt="Facebook" class="img-responsive socmed-img"/>
                        <p class="bold">Facebook</p>
                        <p class="truncate">Reyes-Guansing Dental Clinic</p>
                    </a>
                </div>
            </div>
        </div>
        @*IG card*@
        <div class="col s12 m3 l3">
            <div class="card grey lighten-2 center">
                <div class="card-content brown-text lighten-1">
                    <a href="https://www.instagram.com/_reyesguansingdentalclinic" target="_blank">
                        <img src="~/Content/images/instagram.png" alt="Instagram" class="img-responsive socmed-img"/>
                        <p class="bold">Instagram</p>
                        <p class="truncate">_reyesguansingdentalcinic</p>
                    </a>
                </div>
            </div>
        </div>
        @*phone card*@
        <div class="col s12 m3 l3">
            <div class="card grey lighten-2 center">
                <div class="card-content brown-text lighten-1">
                        <i class="material-icons large">call</i>
                        <p class="bold">Phone</p>
                        <p>+63 963 220 1556</p>
                </div>
            </div>
        </div>
        @*email card*@
        <div class="col s12 m3 l3">
            <div class="card grey lighten-2 center">
                <div class="card-content brown-text lighten-1">
                    <a href="mailto:dentalclinicreyesguansing@gmail.com" target="_blank">
                        <i class="material-icons large">email</i>
                        <p class="bold">Email</p>
                        <p class="truncate" title="dentalclinicreyesguansing@gmail.com">dentalclinicreyesguansing@gmail.com</p>
                    </a>
                </div>
            </div>
        </div>

    </div>

    @*maps*@
    <div class="row">
        <div class="col s12 m12 l12">
            <div class="card grey lighten-2 center">
                <div class="card-content brown-text lighten-1">
                    <div class="row m-0 valign-wrapper hide-on-med-and-down">
                        <div class="col s12 m6 l6 ">
                            @*insert gmaps kayo na bahala jan hehe*@
                            <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d240.30282883058445!2d120.9727415!3d15.4927533!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x339729705358d8cd%3A0x9d190a180b8bf331!2sReyes-Guansing%20Dental%20Clinic!5e0!3m2!1sen!2sph!4v1774454099419!5m2!1sen!2sph" width="100%" height="300" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"/></iframe>
                        </div>
                        <div class="col s12 m6 l6">
                            <a href="https://tinyurl.com/RGDentalClinic" target="_blank"> 
                                <i class="material-icons large">location_on</i>
                                <p class="bold">Our Main Branch</p>
                                <p>1191 Velarde Bldg., Del Pilar St., Cabanatuan City </p>
                            </a>
                        </div>
                    </div>

                    @*mobile responsive maps*@
                    <div class="row m-0 valign-wrapper show-on-medium-and-down hide-on-large-only">
                        <div class="col s12 m6 l6 ">
                            @*insert gmaps kayo na bahala jan hehe*@
                            <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d240.30282883058445!2d120.9727415!3d15.4927533!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x339729705358d8cd%3A0x9d190a180b8bf331!2sReyes-Guansing%20Dental%20Clinic!5e0!3m2!1sen!2sph!4v1774454099419!5m2!1sen!2sph" width="100%" height="300" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" /></iframe>
                            <a href="https://tinyurl.com/RGDentalClinic" target="_blank">
                                <i class="material-icons large">location_on</i>
                                <p class="bold">Our Main Branch</p>
                                <p>1191 Velarde Bldg., Del Pilar St., Cabanatuan City </p>
                            </a>
                        
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


</div>


